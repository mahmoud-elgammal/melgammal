---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/atoms/Container.astro";
import ProjectCard from "@components/molecules/ProjectCard.astro";
import { SITE } from "@consts";

const title = `Work | ${SITE.TITLE}`;
const description = "Selected projects and case studies.";

const projects = (await getCollection("projects"))
    .filter((p) => !p.data.draft)
    .sort(
        (a, b) =>
            new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
    );
---

<PageLayout title={title} description={description}>
    <Container>
        <div class="work-layout">
            <!-- Header -->
            <section class="work-header">
                <div class="header-meta" id="wk-meta">
                    <span class="meta-label">SELECTED WORK</span>
                    <span class="meta-sep">//</span>
                    <span class="meta-label">{projects.length} PROJECTS</span>
                </div>
                <h1 class="work-title" id="wk-title">Projects</h1>
            </section>

            <!-- Grid -->
            <ul class="projects-grid" id="wk-grid">
                {
                    projects.map((project, index) => (
                        <li>
                            <ProjectCard
                                project={project}
                                loading={index < 2 ? "eager" : "lazy"}
                                fetchpriority={index < 2 ? "high" : "auto"}
                            />
                        </li>
                    ))
                }
            </ul>
        </div>
    </Container>
</PageLayout>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .work-layout {
        display: flex;
        flex-direction: column;
        gap: 5rem;
        padding-bottom: 10rem;
    }

    /* ── Header ── */
    .work-header {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding-top: 1rem;
    }

    .header-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;

        .meta-label {
            font-family: ui-monospace, monospace;
            font-size: 0.6rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            opacity: 0.3;
        }

        .meta-sep {
            font-family: ui-monospace, monospace;
            font-size: 0.6rem;
            opacity: 0.15;
        }
    }

    .work-title {
        font-size: clamp(2.5rem, 7vw, 5.5rem);
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1;
        margin: 0;
    }

    /* ── Grid ── */
    .projects-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;

        @include screen(md) {
            grid-template-columns: repeat(2, 1fr);
            gap: 3rem;
        }
    }
</style>

<script>
    import { gsap } from "gsap";

    function initWork() {
        const meta = document.getElementById("wk-meta");
        const title = document.getElementById("wk-title");
        const items = document.querySelectorAll("#wk-grid li");

        const tl = gsap.timeline();

        if (meta) {
            tl.fromTo(
                meta,
                { opacity: 0 },
                { opacity: 1, duration: 0.5 },
                0.05,
            );
        }

        if (title) {
            tl.fromTo(
                title,
                { opacity: 0, y: 20 },
                { opacity: 1, y: 0, duration: 0.8, ease: "power4.out" },
                0.15,
            );
        }

        if (items.length) {
            tl.fromTo(
                items,
                { opacity: 0, y: 24 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.7,
                    stagger: 0.12,
                    ease: "power4.out",
                },
                0.35,
            );
        }
    }

    initWork();
    document.addEventListener("astro:page-load", initWork);
</script>
