---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/atoms/Container.astro";
import PlaygroundItem from "@components/molecules/PlaygroundItem.astro";
import { SITE } from "@consts";
import { getCollection } from "astro:content";

const artifacts = (await getCollection("playground"))
    .filter((item) => !item.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const title = `Playground | ${SITE.NAME}`;
const description =
    "Technical artifacts, open-source tools, and digital experiments.";
---

<PageLayout title={title} description={description}>
    <Container>
        <div class="playground-layout">
            <!-- Page header with dramatic reveal -->
            <section class="playground-header">
                <div class="header-top">
                    <span class="header-label" id="pg-label">ARTIFACT_LAB</span>
                    <span class="header-count" id="pg-count">
                        {String(artifacts.length).padStart(2, "0")} TOOLS
                    </span>
                </div>
                <h1 class="page-title" id="pg-title">Playground</h1>
            </section>

            <!-- Artifact Grid -->
            <div class="artifacts-grid" id="pg-list">
                {
                    artifacts.map((artifact, i) => (
                        <PlaygroundItem
                            title={artifact.data.title}
                            description={artifact.data.description}
                            tags={artifact.data.tags}
                            demoURL={artifact.data.demoURL}
                            repoURL={artifact.data.repoURL}
                            date={artifact.data.date}
                            index={i}
                        />
                    ))
                }
            </div>
        </div>
    </Container>
</PageLayout>

<style lang="scss">
    @use "../styles/variables" as *;
    @use "../styles/mixins" as *;

    .playground-layout {
        display: flex;
        flex-direction: column;
        gap: 5rem;
        margin-bottom: 10rem;
    }

    /* ── Header ── */
    .playground-header {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding-top: 2rem;
    }

    .header-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-label {
        font-family: ui-monospace, monospace;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 0.25em;
        opacity: 0.3;
    }

    .header-count {
        font-family: ui-monospace, monospace;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        opacity: 0.2;
    }

    .page-title {
        font-weight: 950;
        letter-spacing: -0.05em;
        line-height: 0.9;
        margin: 0;
    }

    /* ── Architectural Grid ── */
    .artifacts-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;

        @include screen(md) {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        @include screen(xl) {
            grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
        }
    }
</style>

<script>
    import {
        registerAnimation,
        prefersReducedMotion,
    } from "@lib/animation";

    document.addEventListener("astro:page-load", () => {
        registerAnimation("playground:hero", (gsap) => {
            const title = document.getElementById("pg-title");
            const headerTop = document.querySelector(
                ".header-top",
            ) as HTMLElement | null;
            const items = document.querySelectorAll(".playground-card");

            if (prefersReducedMotion()) {
                if (headerTop) gsap.set(headerTop, { opacity: 1 });
                if (title) gsap.set(title, { opacity: 1, y: 0 });
                gsap.set(items, { opacity: 1, y: 0 });
                return;
            }

            const tl = gsap.timeline();

            if (headerTop) {
                tl.fromTo(
                    headerTop,
                    { opacity: 0 },
                    { opacity: 1, duration: 0.5 },
                    0.05,
                );
            }

            if (title) {
                tl.fromTo(
                    title,
                    { opacity: 0, y: 30 },
                    { opacity: 1, y: 0, duration: 0.8, ease: "power4.out" },
                    0.15,
                );
            }

            items.forEach((item) => {
                gsap.from(item, {
                    opacity: 0,
                    y: 24,
                    duration: 0.6,
                    ease: "power4.out",
                    scrollTrigger: {
                        trigger: item,
                        start: "top 95%",
                        toggleActions: "play none none none",
                    },
                });
            });
        });
    });
</script>
