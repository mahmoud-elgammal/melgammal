---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/atoms/Container.astro";
import { dateRange } from "@lib/utils";
import { SITE, SOCIALS } from "@consts";

const work = (await getCollection("work")).sort(
    (a, b) =>
        new Date(b.data.dateStart).valueOf() -
        new Date(a.data.dateStart).valueOf(),
);

const projects = (await getCollection("projects"))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 4);

// Skills from Expertise.astro context or general common knowledge for this user
const skills = [
    {
        category: "Core",
        items: [
            "Node.js",
            "TypeScript",
            "System Design",
            "Technical Architecture",
        ],
    },
    {
        category: "Frontend",
        items: ["React", "Astro", "Three.js", "GSAP", "Tailwind CSS"],
    },
    {
        category: "DevOps",
        items: ["Docker", "Kubernetes", "AWS", "Prometheus", "Grafana"],
    },
    {
        category: "Tools",
        items: ["Git", "PostgreSQL", "TypeORM", "Linux", "k6"],
    },
];
---

<PageLayout
    title="Resume"
    description="Professional Resume of Mahmoud S. El-Gammal"
>
    <Container>
        <div class="resume-wrapper">
            <header class="resume-header">
                <div class="header-left">
                    <h1 class="name">{SITE.NAME}</h1>
                    <p class="tagline">
                        Creative Technologist & System Architect
                    </p>
                </div>
                <div class="header-right contact-info">
                    <p>{SITE.EMAIL}</p>
                    <div class="social-links">
                        {
                            SOCIALS.map((s) => (
                                <a
                                    href={s.HREF}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    {s.NAME}
                                </a>
                            ))
                        }
                    </div>
                    <p>Cairo, Egypt</p>
                </div>
            </header>

            <section class="resume-section">
                <h2 class="section-title">Professional Summary</h2>
                <p class="summary">
                    Architectural engineer turned creative technologist with a
                    passion for building high-performance, visually stunning web
                    experiences. Specialized in bridging the gap between complex
                    system architecture and fluid user interface design. Expert
                    in Node.js, TypeScript, and modern frontend stacks, with a
                    strong foundation in DevOps and scalability.
                </p>
            </section>

            <section class="resume-section">
                <h2 class="section-title">Experience</h2>
                <div class="experience-list">
                    {
                        work.map((item) => (
                            <div class="experience-item">
                                <div class="item-header">
                                    <h3 class="company">{item.data.company}</h3>
                                    <span class="date">
                                        {dateRange(
                                            item.data.dateStart,
                                            item.data.dateEnd,
                                        )}
                                    </span>
                                </div>
                                <p class="role">{item.data.role}</p>
                                <div class="content">
                                    {/* Dynamically render content if available */}
                                    {item.body && (
                                        <div class="markdown-body">
                                            {item.body}
                                        </div>
                                    )}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </section>

            <section class="resume-section">
                <h2 class="section-title">Selected Projects</h2>
                <div class="projects-grid">
                    {
                        projects.map((p) => (
                            <div class="project-item">
                                <h3 class="project-name">{p.data.title}</h3>
                                <p class="project-desc">{p.data.description}</p>
                                {p.data.tags && (
                                    <div class="project-tags">
                                        {p.data.tags.slice(0, 3).map((tag) => (
                                            <span>{tag}</span>
                                        ))}
                                    </div>
                                )}
                            </div>
                        ))
                    }
                </div>
            </section>

            <section class="resume-section">
                <h2 class="section-title">Technical Expertise</h2>
                <div class="skills-grid">
                    {
                        skills.map((skill) => (
                            <div class="skill-category">
                                <h4>{skill.category}</h4>
                                <ul>
                                    {skill.items.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                            </div>
                        ))
                    }
                </div>
            </section>

            <div class="print-footer">
                <p>Generated from melgammal.com</p>
            </div>
        </div>
    </Container>
</PageLayout>

<style lang="scss">
    @use "../styles/variables" as *;
    @use "../styles/mixins" as *;

    .resume-wrapper {
        padding: 2rem 0 4rem 0;
        max-width: 900px;
        margin: 0 auto;
        color: $color-black;

        @include screen(md) {
            padding: 4rem 0 8rem 0;
        }

        :global(.dark) & {
            color: $color-white;
        }

        @media print {
            padding: 0;
            color: black !important;
            background: white !important;

            :global(.dark) & {
                color: black !important;
            }
        }
    }

    .resume-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-bottom: 2px solid currentColor;
        padding-bottom: 2rem;
        margin-bottom: 3rem;

        @include screen(max-md) {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }

        @include screen(md) {
            margin-bottom: 4rem;
        }

        .name {
            font-family: $font-display;
            font-size: clamp(2rem, 8vw, 3rem);
            font-weight: 900;
            text-transform: uppercase;
            line-height: 0.9;
            margin: 0;
        }

        .tagline {
            font-size: 1rem;
            opacity: 0.6;
            margin-top: 0.5rem;

            @include screen(md) {
                font-size: 1.25rem;
            }
        }

        .contact-info {
            text-align: right;
            font-family: $font-mono;
            font-size: 0.875rem;
            opacity: 0.8;

            @include screen(max-md) {
                text-align: left;
            }

            .social-links {
                display: flex;
                gap: 1rem;
                justify-content: flex-end;
                margin: 0.5rem 0;

                @include screen(max-md) {
                    justify-content: flex-start;
                }

                a {
                    color: currentColor;
                    text-decoration: none;
                    &:hover {
                        text-decoration: underline;
                    }
                }
            }
        }
    }

    .resume-section {
        margin-bottom: 4rem;

        .section-title {
            font-family: $font-mono;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            opacity: 0.4;
            border-bottom: 1px solid currentColor;
            padding-bottom: 0.5rem;
            margin-bottom: 2rem;
        }

        .summary {
            font-size: 1.25rem;
            line-height: 1.6;
            max-width: 75ch;
        }
    }

    .experience-item {
        margin-bottom: 3rem;

        .item-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 0.5rem;
            margin-bottom: 0.5rem;

            .company {
                font-size: clamp(1.25rem, 5vw, 1.75rem);
                font-weight: 800;
                text-transform: uppercase;
            }

            .date {
                font-family: $font-mono;
                font-size: 0.8rem;
                opacity: 0.5;
            }
        }

        .role {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            opacity: 0.8;
            font-style: italic;
        }

        .content {
            line-height: 1.6;
            opacity: 0.9;
        }
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;

        @include screen(max-md) {
            grid-template-columns: 1fr;
        }

        .project-item {
            padding: 1.5rem;
            background: rgba($color-black, 0.03);
            border-radius: 8px;

            :global(.dark) & {
                background: rgba($color-white, 0.03);
            }

            .project-name {
                font-size: 1.25rem;
                font-weight: 700;
                margin-bottom: 0.5rem;
            }

            .project-desc {
                font-size: 0.9375rem;
                opacity: 0.7;
                margin-bottom: 1rem;
            }

            .project-tags {
                display: flex;
                gap: 0.5rem;
                span {
                    font-size: 0.75rem;
                    font-family: $font-mono;
                    padding: 0.2rem 0.5rem;
                    background: rgba(0, 0, 0, 0.05); // Fixed for LCP and build
                    border-radius: 4px;

                    :global(.dark) & {
                        background: rgba(255, 255, 255, 0.05);
                    }
                }
            }
        }
    }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;

        @include screen(md) {
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
        }

        .skill-category {
            h4 {
                font-family: $font-mono;
                font-size: 0.875rem;
                margin-bottom: 1rem;
                text-transform: uppercase;
                opacity: 0.6;
            }

            ul {
                list-style: none;
                padding: 0;
                margin: 0;
                li {
                    font-size: 1rem;
                    margin-bottom: 0.4rem;
                    opacity: 0.9;
                }
            }
        }
    }

    .print-footer {
        display: none;
        @media print {
            display: block;
            margin-top: 4rem;
            text-align: center;
            font-family: $font-mono;
            font-size: 0.75rem;
            opacity: 0.5;
        }
    }

    // General Print Overrides
    @media print {
        :global(body) {
            background: white !important;
        }
        :global(nav, footer, #back-to-top, .immersive-monolith) {
            display: none !important;
        }
        .resume-wrapper {
            padding: 0 !important;
            margin: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }
        .resume-section {
            page-break-inside: avoid;
        }
    }
</style>
