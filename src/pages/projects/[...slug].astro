  }
</style>

<!-- ══════════════════════════════════════════ -->
<!-- ═══════════════ SCRIPT ═══════════════ -->
<!-- ══════════════════════════════════════════ -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin } from "gsap/ScrollToPlugin";

  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  function initCaseStudy() {
    // ── Brand theme takeover ──
    const hero = document.querySelector(".editorial-hero") as HTMLElement;
    if (hero) {
      const brand = hero.dataset.brand || "#8B5CF6";
      document.documentElement.style.setProperty("--brand", brand);

      const isDark = document.documentElement.classList.contains("dark");
      const baseBg = isDark ? "#1c1917" : "#f5f5f4";
      document.body.style.background = `color-mix(in srgb, ${brand} 3%, ${baseBg})`;

      gsap.to(hero, {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power4.out",
        scrollTrigger: {
          trigger: hero,
          start: "top 90%",
        },
      });
    }

    // ── Scroll animations (standard) ──
    document
      .querySelectorAll(
        ".editorial-image-monolith.animate, .editorial-meta.animate, .editorial-title.animate, .cs-overview .animate, .cs-gallery .animate, .cs-impact.animate, .cs-impact .animate, .cs-cta .animate, .cs-footer.animate, .cs-gantt-section .animate, .gantt-container.animate",
      )
      .forEach((el) => {
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 1.2,
          ease: "power4.out",
          scrollTrigger: {
            trigger: el,
            start: "top 92%",
            toggleActions: "play none none none",
          },
        });
      });

    // ── Impact Row Stagger ──
    const impactRows = document.querySelectorAll(".impact-row");
    if (impactRows.length > 0) {
      gsap.fromTo(impactRows, 
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 1,
          stagger: 0.15,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".cs-impact",
            start: "top 80%",
            toggleActions: "play none none none"
          }
        }
      );
    }

    // ── Granular Prose Reveals & Highlights ──
    const highlights = [
      "Challenge:",
      "Decision:",
      "Risk:",
      "Impact:",
      "System Design:",
      "Business Decision:",
      "Project Management:",
    ];

    document
      .querySelectorAll(".prose-monolith > *:not(.inline-gallery)")
      .forEach((el) => {
        // Auto-highlight based on keywords
        const text = el.textContent || "";
        if (highlights.find((h) => text.trim().startsWith(h))) {
          el.classList.add("p-highlight");
        }

        // Inline keyword highlights
        highlights.forEach((h) => {
          const keyword = h.replace(":", "");
          if (
            el.innerHTML.includes(keyword) &&
            !el.classList.contains("p-highlight")
          ) {
            el.innerHTML = el.innerHTML.replaceAll(
              keyword,
              `<span class="txt-highlight">${keyword}</span>`,
            );
          }
        });

        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power4.out",
          scrollTrigger: {
            trigger: el,
            start: "top 95%",
            onEnter: () => {
              el.classList.add("in-view");
              el.querySelectorAll(".txt-highlight").forEach((span) =>
                span.classList.add("in-view"),
              );
            },
          },
        });
      });

    // ── Gantt Timeline Reveals ──
    document.querySelectorAll(".gantt-bar").forEach((bar) => {
      gsap.to(bar, {
        scrollTrigger: {
          trigger: bar,
          start: "top 90%",
          onEnter: () => bar.classList.add("in-view"),
        },
      });
    });

    // ── Floating Dock (GSAP Refined) ──
    const dock = document.getElementById("cs-dock");
    if (dock) {
      const topBtn = dock.querySelector('[data-action="top"]');
      const progressFill = dock.querySelector(".progress-ring-fill") as SVGCircleElement;
      const shareBtn = dock.querySelector('[data-action="share"]');

      // 1. Visibility & Hide on Scroll logic
      ScrollTrigger.create({
        trigger: "body",
        start: "top -500", // Start after hero
        onUpdate: (self) => {
          const isScrollingDown = self.direction === 1;
          const isAtTop = self.scroll() < 400;
          const isAtBottom = self.progress > 0.92; // Show when near footer
          
          if (isAtTop) {
            dock.classList.remove("visible");
          } else if (isAtBottom) {
            dock.classList.add("visible");
          } else {
            // Hide on scroll down, show on scroll up
            dock.classList.toggle("visible", !isScrollingDown);
          }

          // 2. Specialized Progress logic
          const progressPercent = dock.querySelector(".progress-percent") as HTMLElement;
          if (progressFill) {
            const progress = self.progress; // 0 to 1
            const radius = progressFill.r.baseVal.value;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - progress * circumference;
            progressFill.style.strokeDasharray = `${circumference}`;
            progressFill.style.strokeDashoffset = `${offset}`;
            
            if (progressPercent) {
                progressPercent.innerText = Math.round(progress * 100) + "%";
            }
          }
        }
      });

      topBtn?.addEventListener("click", () => {
        gsap.to(window, { scrollTo: 0, duration: 1.2, ease: "power4.inOut" });
      });

      // Chapter Index Logic
      const chaptersTrigger = dock.querySelector("#chapters-trigger");
      const chaptersPopover = dock.querySelector("#chapters-popover");
      const chaptersList = dock.querySelector("#chapters-list");
      
      const sections = [
        { id: "cs-title", label: "Intro" },
        { id: "cs-overview", label: "Overview" },
        { id: "cs-impact", label: "Impact" },
        { id: "cs-gantt", label: "Timeline" },
        { id: "cs-next-case", label: "Next" }
      ];

      if (chaptersList) {
        chaptersList.innerHTML = sections.map(s => {
          const el = document.getElementById(s.id);
          if (!el) return "";
          return `<a href="#${s.id}" class="chapter-link" data-target="${s.id}">${s.label}</a>`;
        }).join("");

        chaptersList.querySelectorAll(".chapter-link").forEach(link => {
            link.addEventListener("click", (e) => {
                e.preventDefault();
                const target = link.getAttribute("data-target");
                if (target) {
                    gsap.to(window, { 
                        scrollTo: `#${target}`, 
                        duration: 1.2, 
                        ease: "power4.inOut" 
                    });
                    chaptersPopover?.classList.remove("open");
                }
            });
        });
      }

      if (chaptersTrigger && chaptersPopover) {
        chaptersTrigger.addEventListener("click", (e) => {
          e.stopPropagation();
          chaptersPopover.classList.toggle("open");
          if (sharePopover) sharePopover.classList.remove("open");
        });
      }

      // Share Popover Logic
      const shareTrigger = dock.querySelector(".share-trigger");
      const sharePopover = dock.querySelector(".share-popover");
      
      if (shareTrigger && sharePopover) {
        shareTrigger.addEventListener("click", (e) => {
          e.stopPropagation();
          const isOpen = sharePopover.classList.toggle("open");
          
          if (isOpen) {
            gsap.fromTo(".share-item", 
              { opacity: 0, y: 15, scale: 0.95 },
              { 
                opacity: 1, 
                y: 0, 
                scale: 1, 
                stagger: 0.05, 
                duration: 0.4, 
                ease: "back.out(1.4)" 
              }
            );
          }
        });

        // Close on outside click
        document.addEventListener("click", (e) => {
          const target = e.target as Node;
          if (!sharePopover.contains(target) && !shareTrigger.contains(target)) {
            sharePopover.classList.remove("open");
          }
          if (chaptersPopover && chaptersTrigger && !chaptersPopover.contains(target) && !chaptersTrigger.contains(target)) {
            chaptersPopover.classList.remove("open");
          }
        });
      }

      // Copy link inside popover
      const copyBtn = dock.querySelector('[data-action="copy-link"]');
      copyBtn?.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const span = copyBtn.querySelector(".share-name");
          if (span instanceof HTMLElement) {
            const original = span.innerText;
            span.innerText = "Copied!";
            setTimeout(() => (span.innerText = original), 2000);
          }
        });
      });
    }

    // ── Next Case Background Animation ──
    const nextBgText = document.querySelector(".next-bg-text");
    if (nextBgText) {
      // Horizontal Parallax on Scroll
      gsap.to(nextBgText, {
        x: -150,
        scrollTrigger: {
          trigger: ".cs-next-case",
          start: "top bottom",
          end: "bottom top",
          scrub: 1,
        },
      });

      // Subtle "Living" Drift
      gsap.to(nextBgText, {
        xPercent: -2,
        duration: 15,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
      });
    }

    return () => {
      document.body.style.background = "";
    };
  }

  let cleanup: (() => void) | undefined;
  document.addEventListener("astro:before-swap", () => cleanup?.());
  document.addEventListener("astro:page-load", () => {
    if (window.location.pathname.startsWith("/projects/")) {
      cleanup = initCaseStudy();
    }
  });
</script>
