---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/atoms/Container.astro";
import BackToPrev from "@components/atoms/BackToPrev.astro";
import MediaSwiper from "@components/molecules/MediaSwiper.astro";
import InteractiveMedia from "@components/molecules/InteractiveMedia.astro";
import CustomVideoPlayer from "@components/molecules/CustomVideoPlayer.astro";
import ProjectCard from "@components/molecules/ProjectCard.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      nextProject: projects[index + 1] ?? projects[0],
    },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
  nextProject: CollectionEntry<"projects">;
}

const { project, nextProject } = Astro.props;
const { Content } = await project.render();
const {
  title,
  description,
  date,
  tags,
  demoURL,
  repoURL,
  imageWeb,
  imageMobile,
  color,
  status,
  role,
  duration,
  client,
  stats,
  timeline,
  gallery,
  inlineMedia,
} = project.data;

const brandColor = color || "#8B5CF6";

// Pre-process inline gallery data
const inlineLightboxGallery = (inlineMedia || [])
  .filter((i) => i.type !== "cinematic-video")
  .map((i) => ({
    src: i.src,
    type: i.type || "image",
  }));
const inlineGalleryJsonString = JSON.stringify(inlineLightboxGallery);

const statusConfig: Record<
  string,
  { label: string; color: string; pulse: boolean }
> = {
  shipped: { label: "SHIPPED", color: "#10b981", pulse: false },
  "in-progress": { label: "IN PROGRESS", color: "#f59e0b", pulse: true },
  concept: { label: "CONCEPT", color: "#3b82f6", pulse: false },
};
const st = statusConfig[status] || statusConfig.shipped;
---

<PageLayout title={title} description={description}>
  <!-- ═══════════════ EDITORIAL HERO ═══════════════ -->
  <section class="editorial-hero" data-brand={brandColor}>
    <Container size="lg">
      <h1 class="editorial-title animate" id="cs-title">{title}</h1>

      <div class="editorial-meta animate">
        <div class="meta-col">
          <span class="meta-label">Project Type</span>
          <span class="meta-val">{client || "Product"}</span>
        </div>
        <div class="meta-col">
          <span class="meta-label">Stage</span>
          <span class="meta-val">{status || "Leader"}</span>
        </div>
        <div class="meta-col">
          <span class="meta-label">Deliverables</span>
          <span class="meta-val"
            >{
              role ||
                (tags && tags.length > 0
                  ? tags.join(", ")
                  : "Strategy & Research, Product Design, Frontend Engineering")
            }</span
          >
        </div>
      </div>
    </Container>
  </section>

  <!-- ═══════════════ IMAGE MONOLITH ═══════════════ -->
  {
    imageWeb && (
      <div class="editorial-image-monolith animate">
        <img src={imageWeb} alt={`${title} cover`} loading="eager" />
      </div>
    )
  }



  <!-- ═══════════════ OVERVIEW ═══════════════ -->
  <section
    class="cs-overview"
    id="cs-overview"
    data-scroll-personality="cinematic"
  >
    <Container size="md">
      <div class="overview-grid">
        <div class="overview-body animate">
          <article class="prose-monolith">
            <Content />
          </article>

          {
            inlineMedia && inlineMedia.length > 0 && (
              <div class="inline-media-showcase">
                {inlineMedia.map((item, index) => {
                  const isCinematic = item.type === "cinematic-video";
                  let lightboxIndex = -1;
                  if (!isCinematic) {
                    lightboxIndex = inlineLightboxGallery.findIndex(
                      (g) => g.src === item.src,
                    );
                  }
                  return (
                    <figure class="inline-media-block animate">
                      <div class="media-wrapper">
                        {isCinematic ? (
                          <CustomVideoPlayer
                            src={item.src}
                            poster={item.poster}
                            autoPlay={false}
                          />
                        ) : (
                          <InteractiveMedia
                            type={item.type as "image" | "ambient-video"}
                            src={item.src}
                            poster={item.poster}
                            alt={item.alt || `Inline Media ${index + 1}`}
                            galleryJson={inlineGalleryJsonString}
                            galleryIndex={lightboxIndex}
                          />
                        )}
                      </div>
                      {item.caption && (
                        <figcaption class="slide-caption">
                          {item.caption}
                        </figcaption>
                      )}
                    </figure>
                  );
                })}
              </div>
            )
          }
        </div>
      </div>
    </Container>

    <!-- Massive Bleed Swiper -->
    {
      gallery && gallery.length > 0 && (
        <div class="cs-gallery animate">
          <MediaSwiper items={gallery as any} />
        </div>
      )
    }
  </section>

  <!-- ═══════════════ PROJECT IMPACT ═══════════════ -->
  {
    stats && stats.length > 0 && (
      <section class="cs-impact animate" id="cs-impact">
        <Container size="md">
          <div class="impact-header">
            <h2 class="impact-headline">Small details, massive reach</h2>
            <div class="impact-intro-grid">
              <div class="impact-intro-label">Impact</div>
              <div class="impact-intro-text">
                Metrics and outcomes achieved over the course of the project lifecycle, demonstrating tangible value and scaling potential.
              </div>
            </div>
          </div>
          
          <div class="impact-list">
            <div class="impact-divider"></div>
            {stats.map((s, i) => (
              <div class="impact-row" style={`--delay: ${i * 0.1}s`}>
                <div class="impact-val" data-count-target={s.value}>{s.value}</div>
                <div class="impact-label">{s.label}</div>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <!-- ═══════════════ GANTT TIMELINE ═══════════════ -->
  {
    timeline && timeline.length > 0 && (
      <section
        class="cs-gantt-section"
        id="cs-gantt"
        style={`--brand: ${brandColor}`}
      >
        <Container size="lg">
          <div class="section-header animate">
            <span class="section-tag">[PROJECT_CHRONOLOGY]</span>
            <h2 class="section-title">Timeline</h2>
          </div>

          <div class="gantt-container animate">
            <div class="gantt-grid-bg">
              {[...Array(5)].map((_, i) => (
                <div class="gantt-grid-line" />
              ))}
            </div>

            <div class="gantt-body">
              {timeline.map((t, i) => (
                <div class="gantt-row" style={`--row-index: ${i}`}>
                  <div class="gantt-meta">
                    <span class="gantt-phase-tag">{t.phase}</span>
                    <span class="gantt-phase-date">{t.date}</span>
                  </div>
                  <div class="gantt-track">
                    <div class="gantt-bar-wrap">
                      <div
                        class="gantt-bar"
                        style={`--bar-offset: ${i * 15}%; --bar-width: 35%;`}
                      >
                        <div class="gantt-content">
                          <h4 class="gantt-h4">{t.title}</h4>
                          <p class="gantt-p">{t.description}</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="gantt-axis">
              <span class="axis-point">PROJ_START</span>
              <span class="axis-point">MILESTONE_01</span>
              <span class="axis-point">MILESTONE_02</span>
              <span class="axis-point">PROJ_LAUNCH</span>
            </div>
          </div>
        </Container>
      </section>
    )
  }

  <!-- ═══════════════ FOOTER ═══════════════ -->
  <Container size="sm">
    <div class="cs-footer animate">
      <div class="bracket-label">[V_END_OF_CASE]</div>
      <div class="footer-divider"></div>
      <BackToPrev href="/work">Return to work</BackToPrev>
    </div>
  </Container>

  <!-- ═══════════════ MONUMENTAL NEXT CASE STUDY ═══════════════ -->
  {
    nextProject && nextProject.slug !== project.slug && (
      <section class="cs-next-case">
        <!-- Massive background typography -->
        <div class="next-bg-text" aria-hidden="true">next case study</div>
        
        <!-- Standard Project Card -->
        <div class="next-project-wrapper">
          <ProjectCard project={nextProject} />
        </div>
      </section>
    )
  }

  <!-- ═══════════════ FLOATING DOCK (ACTIONS) ═══════════════ -->
  <nav class="cs-dock" id="cs-dock" style={`--brand: ${brandColor}`}>
    <div class="dock-inner">
      <button class="dock-pill chapters-trigger" id="chapters-trigger" title="Page Chapters">
        <span class="dock-label">Index</span>
        <div class="chapters-popover" id="chapters-popover">
            <div class="chapters-header">CHAPTERS</div>
            <div class="chapters-list" id="chapters-list">
                <!-- Build dynamically -->
            </div>
            <div class="popover-arrow"></div>
        </div>
      </button>

      <div class="dock-divider"></div>

      <button class="dock-pill" data-action="top" title="Scroll to Top">
        <div class="scroll-progress-ring">
          <span class="progress-percent">0%</span>
          <svg width="32" height="32" viewBox="0 0 32 32">
            <circle
              class="progress-ring-bg"
              cx="16"
              cy="16"
              r="14"
              fill="none"
              stroke-width="2.5"></circle>
            <circle
              class="progress-ring-fill"
              cx="16"
              cy="16"
              r="14"
              fill="none"
              stroke-width="2.5"></circle>
          </svg>
          <span class="progress-arrow">↑</span>
        </div>
        <span class="dock-label">Top</span>
      </button>

      {
        demoURL && (
          <a
            href={demoURL}
            target="_blank"
            rel="noopener"
            class="dock-pill dock-pill--live"
          >
            <span>View Live ↗</span>
          </a>
        )
      }

      {
        repoURL && (
          <a href={repoURL} target="_blank" rel="noopener" class="dock-pill">
            <span>Source ↗</span>
          </a>
        )
      }

      <div class="share-wrapper">
        <div class="share-popover" id="share-popover">
          <div class="share-items">
            <a href={`https://wa.me/?text=${encodeURIComponent(`${title} - ${Astro.url}`)}`} target="_blank" rel="noopener" class="share-item" title="Share on WhatsApp">
               <span class="share-icon">WA</span>
               <span class="share-name">WhatsApp</span>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-item" title="Share on Facebook">
               <span class="share-icon">FB</span>
               <span class="share-name">Facebook</span>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="share-item" title="Share on LinkedIn">
               <span class="share-icon">IN</span>
               <span class="share-name">LinkedIn</span>
            </a>
            <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(Astro.url.toString())}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener" class="share-item" title="Share on Reddit">
               <span class="share-icon">RD</span>
               <span class="share-name">Reddit</span>
            </a>
            <button class="share-item" data-action="copy-link" title="Copy URL">
               <span class="share-icon">CP</span>
               <span class="share-name">Copy</span>
            </button>
          </div>
          <div class="popover-arrow"></div>
        </div>
        <button class="dock-pill share-trigger" data-action="share" title="Share Project">
          <span>Share</span>
        </button>
      </div>

      <div class="dock-divider"></div>

      <a href="mailto:hello@melgammal.com" class="dock-pill">
        <span>Contact</span>
      </a>
    </div>
  </nav>
</PageLayout>

<!-- ══════════════════════════════════════════ -->
<!-- ═══════════════ STYLES ═══════════════ -->
<!-- ══════════════════════════════════════════ -->
<style lang="scss">
  @use "../../styles/variables" as *;

  /* ── Editorial Hero ── */
  .editorial-hero {
    position: relative;
    padding: 8rem 0 4rem;
    background: transparent;
  }

  .editorial-title {
    font-size: clamp(4rem, 12vw, 10rem);
    font-family: $font-serif;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 6rem 0;
    color: $color-black;
    :global(.dark) & {
      color: $color-white;
    }
  }

  .editorial-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba($color-black, 0.1);
    :global(.dark) & {
      border-color: rgba($color-white, 0.1);
    }

    @media (max-width: $screen-md) {
      flex-direction: column;
      gap: 2rem;
    }
  }

  .meta-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;

    &:first-child {
      flex: 1.5;
    }
  }

  .meta-label {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: $color-black;
    line-height: 1;
    :global(.dark) & {
      color: $color-white;
    }
  }

  .meta-val {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.9rem;
    color: rgba($color-black, 0.6);
    line-height: 1.4;
    :global(.dark) & {
      color: rgba($color-white, 0.6);
    }
  }

  /* ── Image Monolith ── */
  .editorial-image-monolith {
    width: 100%;
    margin-top: 2rem;
    img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }
  }

  /* ═══════════════ OVERVIEW ═══════════════ */
  .cs-overview {
    padding: 6rem 0;
  }
  .overview-grid {
    display: block;
    max-width: 800px; /* Optional: limit width for readability since it's now full width */
    margin: 0 auto;
  }

  .overview-meta {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .meta-block {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .meta-key {
    font-family: ui-monospace, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.3;
  }
  .meta-val {
    font-size: 0.9rem;
    font-weight: 700;
    color: $color-black;
    :global(.dark) & {
      color: $color-white;
    }
  }

  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tech-pill {
    font-family: ui-monospace, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    background: rgba($color-black, 0.04);
    color: rgba($color-black, 0.7);
    :global(.dark) & {
      background: rgba($color-white, 0.06);
      color: rgba($color-white, 0.7);
    }
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: ui-monospace, monospace;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dot-color, #10b981);
  }
  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--dot-color, #10b981);
    border-radius: 50%;
  }
  .status-pulse .status-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  .overview-body {
    min-width: 0;
  }

  .prose-monolith {
    color: rgba($color-black, 0.82);
    line-height: 1.9;
    font-size: 1.15rem;
    :global(.dark) & {
      color: rgba($color-white, 0.82);
    }

    :global(p),
    :global(h2),
    :global(h3),
    :global(ul),
    :global(ol),
    :global(blockquote),
    :global(hr) {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);

      &.in-view {
        opacity: 1;
        transform: translateY(0);
      }
    }

    :global(p) {
      margin-bottom: 2.5rem;
    }
    :global(h2) {
      font-size: 1.75rem;
      font-weight: 900;
      margin: 5rem 0 1.5rem;
      letter-spacing: -0.02em;
      color: $color-black;
      :global(.dark) & {
        color: $color-white;
      }
    }
    :global(h3) {
      font-size: 1.25rem;
      font-weight: 800;
      margin: 4rem 0 1.25rem;
      color: $color-black;
      :global(.dark) & {
        color: $color-white;
      }
    }
    :global(strong) {
      font-weight: 900;
      color: $color-black;
      :global(.dark) & {
        color: $color-white;
      }
    }
    :global(ul) {
      list-style: none;
      padding: 0;
      margin-bottom: 3rem;
      :global(li) {
        position: relative;
        padding-left: 2rem;
        margin-bottom: 1rem;
        &::before {
          content: "—";
          position: absolute;
          left: 0;
          opacity: 0.4;
          font-weight: 900;
        }
      }
    }

    // ── Animated Highlights (Refined: Borderless Swipe Reveal) ──
    :global(.p-highlight) {
      position: relative;
      background: #000;
      color: #fff;
      padding: 3rem 4rem;
      border-radius: 2.5rem;
      border: none;
      margin: 5rem 0;
      overflow: hidden;
      transform: translateY(30px);
      opacity: 0;
      transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);

      :global(.dark) & {
        background: #fff;
        color: #000;
      }

      &.in-view {
        transform: translateY(0);
        opacity: 1;
        &::after {
          transform: scaleX(0);
        }
      }

      // Leading swipe bar
      &::after {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--brand);
        z-index: 10;
        transform: scaleX(1);
        transform-origin: right;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: 0.1s;
      }

      :global(strong) {
        color: var(--brand);
        :global(.dark) & {
          color: var(--brand);
        }
      }
    }

    // ── Inline Highlights ──
    :global(.txt-highlight) {
      background-image: linear-gradient(var(--brand), var(--brand));
      background-repeat: no-repeat;
      background-size: 0% 100%;
      background-position: left center;
      transition: background-size 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      color: inherit;
      padding: 0 4px;
      margin: 0 -4px;
      border-radius: 4px;
      font-weight: 800;
      white-space: nowrap;

      &.in-view {
        background-size: 100% 100%;
        color: #fff;
        :global(.dark) & {
          color: #000;
        }
      }
    }
  }

  /* ═══════════════ SECTION HEADERS ═══════════════ */
  .section-header {
    margin-bottom: 4rem;
  }
  .section-tag {
    font-family: ui-monospace, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    opacity: 0.3;
    display: block;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
    color: $color-black;
    :global(.dark) & {
      color: $color-white;
    }
  }

  /* ═══════════════ INLINE MEDIA SHOWCASE ═══════════════ */
  .inline-media-showcase {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 5rem;
  }

  .inline-media-block {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;

    .media-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      background: rgba($color-black, 0.05);
      border-radius: 1rem;
      overflow: hidden;
      :global(.dark) & {
        background: rgba($color-white, 0.05);
      }
    }

    .slide-caption {
      font-family: ui-monospace, monospace;
      font-size: 0.65rem;
      letter-spacing: 0.05em;
      font-weight: 500;
      opacity: 0.5;
      text-align: right;
    }
  }

  /* ═══════════════ PROJECT IMPACT ═══════════════ */
  .cs-impact {
    padding: 2rem 0 8rem;
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .impact-header {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    margin-bottom: 5rem;
  }

  .impact-headline {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: $color-black;
    margin: 0;
    :global(.dark) & { color: $color-white; }
  }

  .impact-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;

    @media (max-width: $screen-md) {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .impact-intro-label {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: $color-black;
    :global(.dark) & { color: $color-white; }
  }

  .impact-intro-text {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba($color-black, 0.8);
    :global(.dark) & { color: rgba($color-white, 0.8); }
  }

  .impact-list {
    display: flex;
    flex-direction: column;
  }

  .impact-divider {
    height: 1px;
    width: 100%;
    background: rgba($color-black, 0.1);
