---
import { getCollection } from "astro:content";
import Container from "@components/atoms/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/atoms/Link.astro";
import ProjectCard from "@components/molecules/ProjectCard.astro";
import PostCard from "@components/molecules/PostCard.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import StatusCard from "@components/molecules/StatusCard.astro";
import Expertise from "@components/organisms/Expertise.astro";
import About from "@components/organisms/About.astro";
import Testimonials from "@components/organisms/Testimonials.astro";

const blog = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
    .filter((project) => !project.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
    <Container>
        <div class="title-container" data-scroll-personality="cinematic">
            <div class="status-card-wrapper" id="hero-status-card">
                <StatusCard
                    name="Mahmoud Elgammal"
                    role="Brand Lead"
                    status="OPEN TO WORK"
                    description="Crafting digital experiences."
                />
            </div>
            <h1 class="display-title" id="hero-title">
                Transform Your Ideas<br />
                Into Interactive<br />
                Masterpieces.
            </h1>
        </div>
        <div class="content-wrapper">
            <section
                class="animate section"
                data-scroll-personality="technical"
            >
                <div class="section-header">
                    <h5 class="section-title">Recent projects</h5>
                    <Link href="/work"> See all projects </Link>
                </div>
                <ul class="project-grid">
                    {
                        projects.map((project, index) => (
                            <li>
                                <ProjectCard
                                    project={project}
                                    loading={index === 0 ? "eager" : "lazy"}
                                    fetchpriority={
                                        index === 0 ? "high" : "auto"
                                    }
                                />
                            </li>
                        ))
                    }
                </ul>
            </section>
            <About />
            <!-- <Expertise /> -->

            <section class="animate section" data-scroll-personality="default">
                <div class="section-header">
                    <h5 class="section-title">Latest posts</h5>
                    <Link href="/blog"> See all posts </Link>
                </div>
                <ul class="post-grid">
                    {
                        blog.map((post, index) => (
                            <li>
                                <PostCard
                                    post={post}
                                    loading={index === 0 ? "eager" : "lazy"}
                                    fetchpriority={
                                        index === 0 ? "high" : "auto"
                                    }
                                />
                            </li>
                        ))
                    }
                </ul>
            </section>

            <section data-scroll-personality="cinematic">
                <Testimonials />
            </section>
        </div>
    </Container>
</PageLayout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    /* ── Wait for IntroLoader curtain ── */

    /* ── Custom GSAP ASCII Scrambler ── */
    /* ── Custom GSAP ASCII Scrambler ── */
    function setupAsciiHoverEffect(wordDivs: HTMLElement[]) {
        if (window.innerWidth < 1024) return; // Skip on mobile/tablet (no hover)
        const chars = "_+-*/=<>!@#$%^&()[]{}\\/|?".split("");
        const brandMessage = "MELGAMMAL"; // Core brand identifier

        wordDivs.forEach((wordDiv) => {
            const spans = Array.from(
                wordDiv.querySelectorAll(".char-span"),
            ) as HTMLElement[];
            const originalTexts = spans.map((span) => span.textContent || "");
            let isHovered = false;

            // Lock width AFTER the entrance animation finishes to prevent layout jump during scramble
            // while preserving strictly natural font spacing.
            // Using a short timeout to ensure the DOM has fully painted the injected spans
            // PERFORMANCE: Use requestIdleCallback to batch layout reads during idle periods
            // to avoid thrashing during the entrance animation.
            const runWidthBatch = () => {
                // READ Phase: Batch all width queries first to avoid forced synchronous layouts
                const widths = spans.map(
                    (span) => span.getBoundingClientRect().width,
                );

                // WRITE Phase: Apply all width mutations together
                spans.forEach((span, i) => {
                    if (widths[i] > 0) {
                        span.style.width = `${widths[i]}px`;
                        span.style.textAlign = "center";
                    }
                });
            };

            if ("requestIdleCallback" in window) {
                window.requestIdleCallback(runWidthBatch, { timeout: 1000 });
            } else {
                setTimeout(runWidthBatch, 200);
            }

            wordDiv.addEventListener("mouseenter", () => {
                isHovered = true;

                spans.forEach((span, i) => {
                    gsap.killTweensOf(span); // Stop any outgoing animations immediately

                    // Scramble phase (continuous glitching while hovered)
                    gsap.to(span, {
                        duration: 1.5, // Arbitrary long duration, we rely on mouseleave to stop
                        ease: "none",
                        repeat: -1, // Infinite repeat while hovered
                        onUpdate: function () {
                            if (isHovered && Math.random() > 0.3) {
                                span.textContent =
                                    chars[
                                        Math.floor(Math.random() * chars.length)
                                    ];
                            }
                        },
                    });
                });
            });

            wordDiv.addEventListener("mouseleave", () => {
                isHovered = false;

                spans.forEach((span, i) => {
                    const orig = originalTexts[i];
                    gsap.killTweensOf(span); // Stop scrambling immediately

                    // Immediately resolve back to original text with a quick sequential sweep
                    gsap.to(span, {
                        duration: 0.05,
                        delay: i * 0.02,
                        onStart: () => {
                            span.textContent = orig;
                        },
                    });
                });
            });
        });
    }

    declare global {
        interface Window {
            heroAnimationContext: gsap.Context;
        }
    }

    async function animateHero() {
        // Create a root GSAP context for better memory management and ScrollTrigger reliability
        const ctx = gsap.context(() => {
            const statusCard = document.getElementById("hero-status-card");
            const heroTitle = document.getElementById("hero-title");

            const tl = gsap.timeline();

            if (heroTitle) {
                const lines = [
                    "Transform Your Ideas",
                    "Into Interactive",
                    "Masterpieces.",
                ];
                heroTitle.innerHTML = "";
                const allSpans: HTMLElement[] = [];

                lines.forEach((line) => {
                    const lineDiv = document.createElement("div");
                    lineDiv.style.display = "flex";
                    lineDiv.style.flexWrap = "wrap";

                    // Process word by word to keep them together
                    const words = line.split(" ");
                    words.forEach((word, wordIndex) => {
                        const wordDiv = document.createElement("div");
                        wordDiv.style.display = "flex";
                        wordDiv.classList.add("hover-word");
                        wordDiv.style.cursor = "default";

                        word.split("").forEach((char) => {
                            const wrapper = document.createElement("span");
                            wrapper.style.display = "inline-block";
                            wrapper.style.overflow = "hidden";
                            wrapper.style.lineHeight = "0.9"; // Tighter bounding box
                            wrapper.style.padding = "0.05em 0"; // Prevent clipping

                            const span = document.createElement("span");
                            span.classList.add("char-span");
                            span.textContent = char;
                            span.style.display = "inline-block";
                            span.style.willChange = "transform, opacity";

                            wrapper.appendChild(span);
                            wordDiv.appendChild(wrapper);
                            allSpans.push(span);
                        });

                        lineDiv.appendChild(wordDiv);

                        // Add space after word (except last word)
                        if (wordIndex < words.length - 1) {
                            const spaceSpan = document.createElement("span");
                            spaceSpan.innerHTML = "&nbsp;";
                            lineDiv.appendChild(spaceSpan);
                        }
                    });

                    heroTitle.appendChild(lineDiv);
                });

                // 1. Reveal the overall container first (avoids layout jumping)
                // Using set instead of timeline beat for LCP efficiency
                gsap.set(heroTitle, { opacity: 1 });

                // 2. Cinematic character stagger entrance
                tl.fromTo(
                    allSpans,
                    {
                        opacity: 0,
                        y: "110%", // Come from below the mask
                        rotationZ: 10,
                        rotationX: -60,
                        scale: 0.8,
                        transformPerspective: 800,
                    },
                    {
                        opacity: 1,
                        y: "0%",
                        rotationZ: 0,
                        rotationX: 0,
                        scale: 1,
                        duration: 0.8, // Faster for UX
                        stagger: 0.01, // Faster for UX
                        ease: "power4.out",
                        onComplete: () => {
                            const wordDivs = Array.from(
                                heroTitle.querySelectorAll(".hover-word"),
                            ) as HTMLElement[];
                            setupAsciiHoverEffect(wordDivs);
                        },
                    },
                    "0", // Start immediately with the timeline
                );
            }

            if (statusCard) {
                // LCP CRITICAL: Do not animate opacity from 0 for the LCP candidate.
                // We only animate a subtle entrance transform/blur to keep the feel.
                tl.fromTo(
                    statusCard,
                    {
                        y: 10,
                        filter: "blur(4px)",
                    },
                    {
                        y: 0,
                        filter: "blur(0px)",
                        duration: 0.6,
                        ease: "power2.out",
                    },
                    "0", // Start literally frame 0
                );
            }

            /* ── Scroll Reveals for Sections ── */
            // Important: using fromTo ensures reliability over `.from` when dealing with opacity
            document.querySelectorAll(".animate").forEach((el) => {
                gsap.fromTo(
                    el,
                    { opacity: 0, y: 30 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 85%",
                            toggleActions: "play none none none",
                        },
                    },
                );
            });
        });

        // Store context to clean up if needed in view transitions
        window.heroAnimationContext = ctx;
    }

    document.addEventListener("astro:page-load", () => {
        // Clean up previous context if it exists (Astro View Transitions)
        if (window.heroAnimationContext) {
            window.heroAnimationContext.revert();
        }
        animateHero();
    });
</script>

<style lang="scss">
    @use "../styles/variables" as *;
    @use "../styles/mixins" as *;

    /* ── Hero Animation Targets ── */

    #hero-status-card,
    #hero-title {
        opacity: 0; // Initially hidden, Motion will animate in
    }

    .title-container {
        position: relative;
        width: 100%;
        margin-top: 6rem; // Increased for extra mobile spacing
        margin-bottom: 2rem;
        z-index: 10;

        @include screen(md) {
            margin-top: 8rem;
            margin-bottom: 5rem;
        }
    }

    .status-card-wrapper {
        position: absolute;
        top: -4rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        pointer-events: auto;

        @include screen(md) {
            top: -5rem;
            left: 2rem;
            transform: none;
        }
    }

    .display-title {
        font-size: clamp(2.2rem, 10vw, 3.5rem); // Fluid small
        line-height: 1.1;
        font-weight: 700;
        color: $color-black;
        margin: 0;

        :global(.dark) & {
            color: $color-white;
        }

        @include screen(md) {
            font-size: clamp(4rem, 8vw, 8.2rem); // Fluid large
        }
    }

    /* ── Layout ── */

    .content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4rem;
    }

    .bio {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .section-header {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        justify-content: space-between;
    }

    .section-title {
        font-weight: 600;
        color: $color-black;

        :global(.dark) & {
            color: $color-white;
        }
    }

    .project-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;

        @include screen(lg) {
            grid-template-columns: repeat(2, 1fr);
            gap: 2.5rem;
        }
    }

    .post-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;

        @include screen(sm) {
            grid-template-columns: repeat(2, 1fr);
        }

        @include screen(lg) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .socials {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .social-item {
        display: flex;
        gap: 0.5rem;
        white-space: nowrap;
    }
</style>
