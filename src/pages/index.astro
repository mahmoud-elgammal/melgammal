---
import { getCollection } from "astro:content";
import Container from "@components/atoms/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/atoms/Link.astro";
import ProjectCard from "@components/molecules/ProjectCard.astro";
import PostCard from "@components/molecules/PostCard.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import StatusCard from "@components/molecules/StatusCard.astro";
import Expertise from "@components/organisms/Expertise.astro";
import About from "@components/organisms/About.astro";
import Testimonials from "@components/organisms/Testimonials.astro";

const blog = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
    .filter((project) => !project.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
    <Container>
        <div class="status-card-wrapper" id="hero-status-card">
            <StatusCard />
        </div>
        <h1 class="display-title" id="hero-title">
            Transform Your Ideas<br />
            Into Interactive<br />
            Masterpieces.
        </h1>
        <div class="content-wrapper">
            <About />

            <section class="animate section">
                <div class="section-header">
                    <h5 class="section-title">Recent projects</h5>
                    <Link href="/projects"> See all projects </Link>
                </div>
                <ul class="project-grid">
                    {
                        projects.map((project) => (
                            <li>
                                <ProjectCard project={project} />
                            </li>
                        ))
                    }
                </ul>
            </section>

            <Expertise />

            <section class="animate section">
                <div class="section-header">
                    <h5 class="section-title">Latest posts</h5>
                    <Link href="/blog"> See all posts </Link>
                </div>
                <ul class="post-grid">
                    {
                        blog.map((post) => (
                            <li>
                                <PostCard post={post} />
                            </li>
                        ))
                    }
                </ul>
            </section>

            <Testimonials />
        </div>
    </Container>
</PageLayout>

<script>
    import { animate, inView, stagger } from "motion";

    /* ── Wait for IntroLoader curtain ── */
    function waitForLoader(): Promise<void> {
        return new Promise((resolve) => {
            const loader = document.getElementById("intro-loader");
            if (!loader || window.getComputedStyle(loader).display === "none") {
                resolve();
                return;
            }
            const observer = new MutationObserver(() => {
                if (window.getComputedStyle(loader).display === "none") {
                    observer.disconnect();
                    resolve();
                }
            });
            observer.observe(loader, {
                attributes: true,
                attributeFilter: ["style", "class"],
            });
            setTimeout(() => {
                observer.disconnect();
                resolve();
            }, 3000);
        });
    }

    /* ── Build word spans for title animation ── */
    function buildTitleWords(heroTitle: HTMLElement): HTMLElement[] {
        const lines = [
            "Transform Your Ideas",
            "Into Interactive",
            "Masterpieces.",
        ];
        heroTitle.innerHTML = "";
        const allWords: HTMLElement[] = [];
        lines.forEach((line) => {
            const lineEl = document.createElement("div");
            lineEl.classList.add("line-container");
            line.split(" ").forEach((word) => {
                const span = document.createElement("span");
                span.classList.add("word");
                span.textContent = word;
                span.style.opacity = "0";
                span.style.transform = "translateY(110%) rotateX(-12deg)";
                span.style.filter = "blur(4px)";
                lineEl.appendChild(span);
                allWords.push(span);
            });
            heroTitle.appendChild(lineEl);
        });
        return allWords;
    }

    async function animateHero() {
        await waitForLoader();

        const statusCard = document.getElementById("hero-status-card");
        const heroTitle = document.getElementById("hero-title");

        let words: HTMLElement[] = [];
        if (heroTitle) words = buildTitleWords(heroTitle);

        if (statusCard) {
            animate(
                statusCard as any,
                { opacity: [0, 1], y: [40, 0], scale: [0.95, 1] },
                {
                    duration: 0.6,
                    delay: 0.1,
                    easing: [0.34, 1.56, 0.64, 1],
                } as any,
            );
        }
        if (words.length > 0) {
            animate(
                words as any,
                {
                    opacity: [0, 1],
                    y: ["110%", "0%"],
                    rotateX: [-12, 0],
                    filter: ["blur(4px)", "blur(0px)"],
                },
                {
                    duration: 0.65,
                    delay: stagger(0.06),
                    easing: [0.16, 1, 0.3, 1],
                } as any,
            );
        }

        /* ── Scroll Reveals for Sections ── */
        document.querySelectorAll(".animate").forEach((el) => {
            inView(el, () => {
                animate(el as any, { opacity: [0, 1], y: [20, 0] }, {
                    duration: 0.8,
                    easing: [0.16, 1, 0.3, 1],
                } as any);
            });
        });
    }

    animateHero();
</script>

<style lang="scss">
    @use "../styles/variables" as *;
    @use "../styles/mixins" as *;

    /* ── Hero Animation Targets ── */

    #hero-status-card {
        opacity: 0; // Initially hidden, Motion will animate in
    }

    .display-title {
        font-size: 2.5rem;
        line-height: 1.1;
        font-weight: 700;
        margin-bottom: 2rem;
        color: $color-black;
        margin-top: 0;

        :global(.dark) & {
            color: $color-white;
        }

        @include screen(md) {
            font-size: 8rem;
        }

        /* Word-level animation containers */
        :global(.line-container) {
            display: block;
            overflow: hidden;
            perspective: 600px;
        }

        :global(.word) {
            display: inline-block;
            margin-right: 0.3em;
            transform-origin: bottom center;
            will-change: transform, opacity;
        }
    }

    /* ── Layout ── */

    .content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4rem;
    }

    .bio {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .section-header {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        justify-content: space-between;
    }

    .section-title {
        font-weight: 600;
        color: $color-black;

        :global(.dark) & {
            color: $color-white;
        }
    }

    .project-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;

        @include screen(sm) {
            grid-template-columns: repeat(2, 1fr);
            gap: 2.5rem;
        }
    }

    .post-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;

        @include screen(sm) {
            grid-template-columns: repeat(2, 1fr);
        }

        @include screen(lg) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .socials {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .social-item {
        display: flex;
        gap: 0.5rem;
        white-space: nowrap;
    }
</style>
