---
import Head from "@components/atoms/Head.astro";
import Header from "@components/organisms/Header.astro";
import Footer from "@components/organisms/Footer.astro";
import { SITE } from "@consts";

type Props = {
    title: string;
    description: string;
};

import CommandMenu from "@components/organisms/CommandMenu.astro";
import MediaLightbox from "@components/organisms/MediaLightbox.astro";
import Cursor from "@components/atoms/Cursor.astro";

const { title, description } = Astro.props;
---

<html lang="en">
    <head>
        <Head title={`${title} | ${SITE.NAME}`} description={description} />
    </head>
    <body>
        <Header />
        <CommandMenu />
        <main id="page-main" class="page-content">
            <slot />
        </main>
        <Footer />
        <MediaLightbox />
        <Cursor />
        <script>
            import Lenis from "lenis";
            import { gsap } from "gsap";
            import { ScrollTrigger } from "gsap/ScrollTrigger";
            import {
                installAnimationLifecycle,
                registerAnimation,
                prefersReducedMotion,
                refreshScrollTriggers,
            } from "@lib/animation";

            gsap.registerPlugin(ScrollTrigger);
            installAnimationLifecycle();

            // ── Scroll Personality Presets ──
            const personalities = {
                default: { lerp: 0.12, multiplier: 1 },
                technical: { lerp: 0.22, multiplier: 1.4 },
                cinematic: { lerp: 0.05, multiplier: 0.75 },
                frozen: { lerp: 0.02, multiplier: 0.4 },
            };

            type Personality = (typeof personalities)[keyof typeof personalities];
            const scrollState: Personality = { ...personalities.default };

            // ── Lenis init (runs once per hard load — survives view transitions) ──
            let lenis: Lenis | null = null;
            let rafTickerHandler: ((time: number) => void) | null = null;

            function initLenis() {
                if (lenis) return;
                if (prefersReducedMotion()) return; // honor user preference

                lenis = new Lenis({
                    lerp: scrollState.lerp,
                    wheelMultiplier: scrollState.multiplier,
                    smoothWheel: true,
                });

                lenis.on("scroll", ScrollTrigger.update);

                rafTickerHandler = (time: number) => {
                    lenis?.raf(time * 1000);
                };
                gsap.ticker.add(rafTickerHandler);
                gsap.ticker.lagSmoothing(0);
            }

            function destroyLenis() {
                if (rafTickerHandler) {
                    gsap.ticker.remove(rafTickerHandler);
                    rafTickerHandler = null;
                }
                if (lenis) {
                    lenis.destroy();
                    lenis = null;
                }
            }

            function transitionTo(target: Personality) {
                if (!lenis) return;
                gsap.to(scrollState, {
                    lerp: target.lerp,
                    multiplier: target.multiplier,
                    duration: 1.2,
                    ease: "power2.inOut",
                    onUpdate: () => {
                        if (!lenis) return;
                        // @ts-ignore - mutating Lenis internal options for live reactivity
                        lenis.options.lerp = scrollState.lerp;
                        // @ts-ignore
                        lenis.options.wheelMultiplier = scrollState.multiplier;
                    },
                });
            }

            // ── Per-page setup: scroll personalities + ScrollTrigger refresh ──
            function setupPageAnimations() {
                if (prefersReducedMotion()) {
                    // Reveal all .animate elements instantly so nothing stays hidden
                    document
                        .querySelectorAll<HTMLElement>(".animate")
                        .forEach((el) => {
                            el.style.opacity = "1";
                            el.style.transform = "none";
                        });
                    return;
                }

                registerAnimation("page-layout:scroll-personalities", () => {
                    const sections = document.querySelectorAll(
                        "[data-scroll-personality]",
                    );

                    sections.forEach((section) => {
                        const personalityKey =
                            section.getAttribute("data-scroll-personality") ||
                            "default";
                        const target =
                            personalities[
                                personalityKey as keyof typeof personalities
                            ] || personalities.default;

                        ScrollTrigger.create({
                            trigger: section,
                            start: "top 80%",
                            end: "bottom 20%",
                            onEnter: () => transitionTo(target),
                            onEnterBack: () => transitionTo(target),
                        });
                    });
                });

                // Recompute trigger positions once images/fonts settle
                requestAnimationFrame(() => refreshScrollTriggers());
            }

            // ── Resize handling: keep ScrollTrigger in sync with viewport ──
            let resizeTimer: number | undefined;
            window.addEventListener("resize", () => {
                window.clearTimeout(resizeTimer);
                resizeTimer = window.setTimeout(() => {
                    refreshScrollTriggers();
                }, 150);
            });

            // ── Initial bootstrap ──
            initLenis();
            setupPageAnimations();

            // ── Re-bind after each view transition ──
            document.addEventListener("astro:after-swap", () => {
                // Lenis survives swaps; if it was killed (e.g. reduced-motion
                // toggled mid-session) re-initialize it now.
                initLenis();
                setupPageAnimations();
            });

            // ── React to OS-level reduced-motion changes mid-session ──
            const motionMql = window.matchMedia(
                "(prefers-reduced-motion: reduce)",
            );
            motionMql.addEventListener("change", (e) => {
                if (e.matches) {
                    destroyLenis();
                    setupPageAnimations();
                } else {
                    initLenis();
                    setupPageAnimations();
                }
            });
        </script>
    </body>
</html>

<style>
    /* ── Stacking context for the Sticky Footer reveal ── */
    /* Remove height: 100% from html, body to allow scroll */
    html,
    body {
    }

    /* ── Page Flow and Defaults ── */
    html,
    body {
        margin: 0;
        padding: 0;
    }

    /* The main content sits above the footer and scrolls normally */
    .page-content {
        position: relative;
        z-index: 2;
        background: var(
            --color-light-bg,
            #f4f4f5
        ); /* Assuming SCSS context for existing global vars, fallback to white/black if not */
    }

    :global(.dark) .page-content {
        background: var(--color-dark-bg, #09090b);
    }
</style>
