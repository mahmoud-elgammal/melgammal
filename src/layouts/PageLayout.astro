---
import Head from "@components/atoms/Head.astro";
import Header from "@components/organisms/Header.astro";
import Footer from "@components/organisms/Footer.astro";
import { SITE } from "@consts";

type Props = {
  title: string;
  description: string;
};

import IntroLoader from "@components/organisms/IntroLoader.astro";
import CommandMenu from "@components/organisms/CommandMenu.astro";
import MediaLightbox from "@components/organisms/MediaLightbox.astro";

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <Head title={`${title} | ${SITE.NAME}`} description={description} />
  </head>
  <body>
    <IntroLoader />
    <Header />
    <CommandMenu />
    <main id="page-main" class="page-content" style="opacity: 0;">
      <slot />
    </main>
    <Footer />
    <MediaLightbox />
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // ── Scroll Personality Presets ──
      const personalities = {
        default: { lerp: 0.12, multiplier: 1 },
        technical: { lerp: 0.22, multiplier: 1.4 },
        cinematic: { lerp: 0.05, multiplier: 0.75 },
        frozen: { lerp: 0.02, multiplier: 0.4 },
      };

      // Proxied state for animation
      const scrollState = { ...personalities.default };

      const lenis = new Lenis({
        lerp: scrollState.lerp,
        wheelMultiplier: scrollState.multiplier,
        smoothWheel: true,
      });

      // Synchronize Lenis with GSAP ScrollTrigger
      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // ── Dynamic Personality Transitioner ──
      function initScrollPersonalities() {
        const sections = document.querySelectorAll("[data-scroll-personality]");

        sections.forEach((section) => {
          const personalityKey =
            section.getAttribute("data-scroll-personality") || "default";
          const target =
            personalities[personalityKey as keyof typeof personalities] ||
            personalities.default;

          ScrollTrigger.create({
            trigger: section,
            start: "top 80%",
            end: "bottom 20%",
            onEnter: () => transitionTo(target),
            onEnterBack: () => transitionTo(target),
          });
        });
      }

      function transitionTo(target: { lerp: number; multiplier: number }) {
        gsap.to(scrollState, {
          lerp: target.lerp,
          multiplier: target.multiplier,
          duration: 1.2,
          ease: "power2.inOut",
          onUpdate: () => {
            // @ts-ignore - Updating Lenis internal state for real-time reactivity
            lenis.options.lerp = scrollState.lerp;
            // @ts-ignore
            lenis.options.wheelMultiplier = scrollState.multiplier;
          },
        });
      }

      /* ── Reveal page content after header entrance ── */
      function revealPage() {
        const main = document.getElementById("page-main");
        if (main && main.style.opacity !== "1") {
          gsap.fromTo(
            main,
            { opacity: 0, y: 12 },
            {
              opacity: 1,
              y: 0,
              duration: 0.6,
              ease: "power4.out",
              onComplete: () => {
                gsap.set(main, { clearProps: "all" }); // Remove stacking context
                initScrollPersonalities();
                ScrollTrigger.refresh();
              },
            },
          );
        }
      }

      function handlePageReveal() {
        const isLandingPage = window.location.pathname === "/";
        // @ts-ignore
        if (window.headerReady || isLandingPage) {
          revealPage();
        } else {
          document.addEventListener("header-ready", revealPage, { once: true });
        }
      }

      // ── View Transitions Handlers ──

      // Reset scroll proxy on navigation
      document.addEventListener("astro:before-swap", () => {
        lenis.destroy();
        ScrollTrigger.getAll().forEach((t) => t.kill());
      });

      document.addEventListener("astro:page-load", () => {
        // Re-calculate all triggers for the new DOM
        ScrollTrigger.refresh();
        handlePageReveal();
      });

      // Initial reveal call
      handlePageReveal();
    </script>
  </body>
</html>

<style>
  /* ── Stacking context for the Sticky Footer reveal ── */
  /* Remove height: 100% from html, body to allow scroll */
  html,
  body {
  }

  /* ── Page Flow and Defaults ── */
  html,
  body {
    margin: 0;
    padding: 0;
  }

  /* The main content sits above the footer and scrolls normally */
  .page-content {
    position: relative;
    z-index: 2;
    background: var(
      --color-light-bg,
      #f4f4f5
    ); /* Assuming SCSS context for existing global vars, fallback to white/black if not */
  }

  :global(.dark) .page-content {
    background: var(--color-dark-bg, #09090b);
  }
</style>
