---
import Container from "@components/atoms/Container.astro";
---

<section class="process-hero">
    <div class="vertical-title">
        <span class="word">THE</span>
        <span class="word">ARCHITECTURAL</span>
        <span class="word">JOURNEY</span>
    </div>

    <Container size="sm">
        <div class="hero-content">
            <div class="bracket-label">[MISSION_CONTROL]</div>
            <h1 class="display-impact">
                WE DON'T JUST CODE; WE ASSEMBLE DIGITAL MONOLITHS WITH
                STRUCTURAL INTEGRITY.
            </h1>
            <p class="description">
                Our process is an intentional engineering flow. We strip away
                the noise to find the fundamental truth of every project,
                building interfaces that command attention and systems that defy
                obsolescence.
            </p>
        </div>
    </Container>
</section>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .process-hero {
        position: relative;
        min-height: 80vh;
        display: flex;
        align-items: center;
        padding-top: 10rem;
        overflow: hidden;
    }

    .vertical-title {
        position: absolute;
        left: 2rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        font-size: 0.75rem;
        font-weight: 900;
        letter-spacing: 0.5em;
        writing-mode: vertical-rl;
        text-transform: uppercase;
        opacity: 0.1;
        gap: 2rem;
        pointer-events: none;

        .word {
            transform: rotate(180deg);
        }
    }

    .hero-content {
        position: relative;
        z-index: 1;

        .bracket-label {
            font-family: ui-monospace, monospace;
            font-size: 0.7rem;
            font-weight: 700;
            opacity: 0.4;
            letter-spacing: 0.2em;
            margin-bottom: 2rem;
        }

        .display-impact {
            font-size: clamp(2rem, 5vw, 4rem);
            font-weight: 900;
            line-height: 0.95;
            letter-spacing: -0.04em;
            margin-bottom: 3rem;
            text-transform: uppercase;
            color: $color-black;

            :global(.dark) & {
                color: $color-white;
            }
        }

        .description {
            font-size: 1.25rem;
            line-height: 1.6;
            opacity: 0.7;
            max-width: 50ch;
            margin: 0;
        }
    }

    @include screen(lg) {
        .vertical-title {
            font-size: 1rem;
            left: 5rem;
        }
    }
</style>
