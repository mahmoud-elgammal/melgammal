---
import Container from "@components/atoms/Container.astro";
---

<div class="blog-interaction-hud active" id="blog-hud">
    <div class="reading-progress-track">
        <div class="progress-bar" id="reading-bar"></div>
    </div>

    <Container size="xl">
        <div class="hud-content">
            <div class="hud-left">
                <a href="/blog" class="hud-btn">
                    <span class="bracket">[</span> INDEX <span class="bracket"
                        >]</span
                    >
                </a>
            </div>
            <div class="hud-center">
                <div class="scroll-status">
                    <span class="label">STABILITY_LINKed</span>
                    <span class="value" id="scroll-percent">00%</span>
                </div>
            </div>
            <div class="hud-right">
                <button class="hud-btn" id="back-to-top">
                    <span class="bracket">[</span> TOP <span class="bracket"
                        >]</span
                    >
                </button>
            </div>
        </div>
    </Container>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .blog-interaction-hud {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        background: rgba($color-light-bg, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba($color-black, 0.05);
        transition: background 0.3s ease;

        :global(.dark) & {
            background: rgba($color-dark-bg, 0.9);
            border-bottom-color: rgba($color-white, 0.05);
        }

        &.active {
            // Permanently active now as requested
        }
    }

    .reading-progress-track {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: rgba($color-black, 0.02);

        .progress-bar {
            height: 100%;
            width: 0%;
            background: $color-black;
            transition: width 0.1s linear;
            :global(.dark) & {
                background: $color-white;
            }
        }
    }

    .hud-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 3.5rem; // Slightly more compact
    }

    .hud-btn {
        background: none;
        border: none;
        font-family: ui-monospace, monospace;
        font-size: 0.65rem; // Slightly smaller
        font-weight: 700;
        letter-spacing: 0.15em;
        color: $color-black;
        cursor: pointer;
        text-decoration: none;
        padding: 0.5rem;
        transition: opacity 0.3s ease;

        &:hover {
            opacity: 0.6;
        }

        .bracket {
            opacity: 0.3;
        }

        :global(.dark) & {
            color: $color-white;
        }
    }

    .scroll-status {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
        font-family: ui-monospace, monospace;

        .label {
            font-size: 0.45rem;
            opacity: 0.4;
            letter-spacing: 0.2em;
            text-transform: uppercase;
        }

        .value {
            font-size: 0.7rem;
            font-weight: 800;
        }
    }
</style>

<script>
    import { registerAnimation } from "@lib/animation";

    document.addEventListener("astro:page-load", () => {
        // Use registerAnimation purely for its AbortSignal — gives us a
        // single signal that aborts on every view transition, killing the
        // scroll listener that would otherwise leak.
        registerAnimation("blog-interaction-hud", (_gsap, signal) => {
            const hud = document.getElementById("blog-hud");
            const bar = document.getElementById("reading-bar");
            const percent = document.getElementById("scroll-percent");
            const backToTop = document.getElementById("back-to-top");

            if (!hud) return;

            function updateProgress() {
                const totalScroll =
                    document.documentElement.scrollHeight -
                    window.innerHeight;
                const currentScroll = window.scrollY;
                const progress =
                    totalScroll > 0
                        ? (currentScroll / totalScroll) * 100
                        : 0;

                if (bar)
                    bar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
                if (percent)
                    percent.textContent = `${Math.round(progress).toString().padStart(2, "0")}%`;
            }

            window.addEventListener("scroll", updateProgress, {
                signal,
                passive: true,
            });
            updateProgress();

            if (backToTop) {
                backToTop.addEventListener(
                    "click",
                    () => {
                        window.scrollTo({ top: 0, behavior: "smooth" });
                    },
                    { signal },
                );
            }
        });
    });
</script>
