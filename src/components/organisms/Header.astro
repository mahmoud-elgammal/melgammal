---
import Container from "@components/atoms/Container.astro";
import Link from "@components/atoms/Link.astro";
import Button from "@components/atoms/Button.astro";
import LanguageSwitch from "@components/atoms/LanguageSwitch.astro";
import { NAV_SHORTCUTS } from "@lib/shortcuts";
---

<!-- Shortcut toast notification -->
<div id="shortcut-toast" class="shortcut-toast" aria-live="polite"></div>

<!-- Shortcut help panel (toggled with ?) -->
<!-- NOTE: Must stay before <header> for CSS sibling selector (~) to work -->
<div id="shortcut-panel" class="shortcut-panel" aria-hidden="true">
    <div class="shortcut-panel-inner">
        <div class="shortcut-panel-header">
            <h3>Keyboard Shortcuts</h3>
            <kbd>?</kbd> to close
        </div>
        <ul class="shortcut-list" id="shortcut-list"></ul>
    </div>
</div>

<script is:inline>
    // FOUC Fix: Immediately reveal header if already animated in this session
    // This runs before the rest of the page renders to prevent flicker
    (function () {
        if (sessionStorage.getItem("header-animated") === "true") {
            document.documentElement.classList.add("header-skip-anim");
        }
    })();
</script>

<header id="site-header" class="header-anim">
    <Container>
        <div class="header-content">
            <div class="nav-group">
                <Link href="/" underline={false}>
                    <div class="brand" id="header-brand">M. El-Gammal</div>
                </Link>
                <nav id="header-nav" class="desktop-nav">
                    {
                        NAV_SHORTCUTS.map((shortcut, index) => (
                            <>
                                <Link
                                    href={shortcut.href}
                                    class="header-nav-link"
                                    aria-keyshortcuts={shortcut.keys}
                                >
                                    {shortcut.label}
                                </Link>
                                {index < NAV_SHORTCUTS.length - 1 && (
                                    <span class="header-sep">/</span>
                                )}
                            </>
                        ))
                    }
                </nav>
            </div>

            <div class="actions-group">
                <div id="header-lang">
                    <LanguageSwitch />
                </div>
                <div id="header-cta" class="desktop-cta">
                    <Button href="/book-intro" variant="outline"
                        >Book Intro</Button
                    >
                </div>
                <button
                    id="mobile-menu-toggle"
                    class="mobile-menu-toggle"
                    aria-label="Toggle Menu"
                >
                    <span class="line line-1"></span>
                    <span class="line line-2"></span>
                </button>
            </div>
        </div>
    </Container>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu-overlay" class="mobile-menu-overlay">
        <div class="overlay-content">
            <nav class="mobile-nav">
                {
                    NAV_SHORTCUTS.map((shortcut) => (
                        <Link href={shortcut.href} class="mobile-nav-link">
                            <span class="link-label">{shortcut.label}</span>
                            <span class="link-hint">{shortcut.hint}</span>
                        </Link>
                    ))
                }
            </nav>
            <div class="overlay-footer">
                <Button href="/book-intro" variant="outline" class="w-full"
                    >Book Intro</Button
                >
            </div>
        </div>
    </div>
</header>

<script>
    import { gsap } from "gsap";
    // @ts-ignore
    import { tinykeys } from "tinykeys";
    import { NAV_SHORTCUTS } from "@lib/shortcuts";

    /* ── Utility: wait for IntroLoader to finish ── */
    function waitForLoader(): Promise<void> {
        return new Promise((resolve) => {
            const loader = document.getElementById("intro-loader");
            if (!loader || loader.style.display === "none") {
                resolve();
                return;
            }
            const observer = new MutationObserver(() => {
                if (loader.style.display === "none") {
                    observer.disconnect();
                    resolve();
                }
            });
            observer.observe(loader, {
                attributes: true,
                attributeFilter: ["style"],
            });
        });
    }

    /* ── Brand letter splitting ── */
    function splitBrandLetters(brand: HTMLElement): HTMLElement[] {
        const text = brand.textContent || "";
        brand.innerHTML = "";
        const letters: HTMLElement[] = [];

        text.split("").forEach((char) => {
            const span = document.createElement("span");
            span.classList.add("brand-letter");
            span.textContent = char === " " ? "\u00A0" : char;
            span.style.opacity = "0";
            span.style.display = "inline-block";
            brand.appendChild(span);
            letters.push(span);
        });

        return letters;
    }

    /* ── Header entrance animation ── */
    async function animateHeader() {
        const hasAnimated = sessionStorage.getItem("header-animated");
        // @ts-ignore
        if (window._headerAnimating) return;

        const header = document.getElementById("site-header");
        const brand = document.getElementById("header-brand");
        const navLinks = document.querySelectorAll(".header-nav-link");
        const seps = document.querySelectorAll(".header-sep");
        const cta = document.getElementById("header-cta");
        const lang = document.getElementById("header-lang");

        const markReady = () => {
            // @ts-ignore
            window.headerReady = true;
            document.dispatchEvent(new CustomEvent("header-ready"));
        };

        // 1. Skip animation if already seen in this session
        if (hasAnimated && brand) {
            const letters = splitBrandLetters(brand);
            brand.style.opacity = "1";
            header!.classList.remove("header-anim");
            gsap.set(letters, { opacity: 1, y: 0 });
            gsap.set([navLinks, seps, cta, lang], {
                opacity: 1,
                x: 0,
                y: 0,
                scale: 1,
            });
            markReady();
            return;
        }

        // @ts-ignore
        window._headerAnimating = true;

        await waitForLoader();

        // ── Synchronization for Landing Page ──
        if (window.location.pathname === "/") {
            await new Promise((resolve) => {
                document.addEventListener("header-start", resolve, {
                    once: true,
                });
            });
        }

        const tl = gsap.timeline({
            onComplete: () => {
                sessionStorage.setItem("header-animated", "true");
                // @ts-ignore
                window._headerAnimating = false;
                markReady();
            },
        });

        // 1. Brand name — letter unfold
        if (brand) {
            const letters = splitBrandLetters(brand);
            brand.style.opacity = "1";

            // GSAP Reveal Sequence
            tl.to(header, { opacity: 1, duration: 0.2 }); // Instant reveal of shell
            header!.classList.remove("header-anim");

            tl.fromTo(
                letters,
                { opacity: 0, y: 12 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.5,
                    stagger: 0.03,
                    ease: "power4.out",
                    onComplete: () => {
                        // Clear transforms to remove stacking context without losing visibility
                        gsap.set(letters, {
                            clearProps: "transform,translate,rotate,scale",
                        });
                    },
                },
            );
        }

        // 2. Nav links cascade from left
        if (navLinks.length > 0) {
            tl.fromTo(
                navLinks,
                { opacity: 0, x: -8 },
                {
                    opacity: 1,
                    x: 0,
                    duration: 0.4,
                    stagger: 0.06,
                    ease: "power4.out",
                    onComplete: () => {
                        gsap.set(navLinks, {
                            clearProps: "transform,translate,rotate,scale",
                        });
                        gsap.set(seps, {
                            clearProps: "transform,translate,rotate,scale",
                        });
                    },
                },
                "-=0.3",
            );
        }

        // 3. Separators fade + scale
        if (seps.length > 0) {
            tl.fromTo(
                seps,
                { opacity: 0, scale: 0.5 },
                {
                    opacity: 0.5,
                    scale: 1,
                    duration: 0.3,
                    stagger: 0.06,
                    ease: "power1.out",
                },
                "-=0.4",
            );
        }

        // 4. CTA button scales in
        if (cta) {
            tl.fromTo(
                cta,
                { opacity: 0, scale: 0.9 },
                { opacity: 1, scale: 1, duration: 0.4, ease: "back.out(1.7)" },
                "-=0.2",
            );
        }

        // 5. Language switch fades in
        if (lang) {
            tl.fromTo(
                lang,
                { opacity: 0, y: 8 },
                { opacity: 1, y: 0, duration: 0.4, ease: "power4.out" },
                "-=0.2",
            );
        }
    }

    /* ── Micro-interaction: Magnetic hover on nav links ── */
    function setupMagneticHover() {
        const links = document.querySelectorAll(
            ".header-nav-link",
        ) as NodeListOf<HTMLElement>;

        links.forEach((link) => {
            link.addEventListener("mousemove", (e: MouseEvent) => {
                const rect = link.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const distX = (e.clientX - centerX) / (rect.width / 2);
                const distY = (e.clientY - centerY) / (rect.height / 2);

                gsap.to(link, {
                    x: distX * 3,
                    y: distY * 2,
                    duration: 0.2,
                    ease: "power2.out",
                });
            });

            link.addEventListener("mouseleave", () => {
                gsap.to(link, {
                    x: 0,
                    y: 0,
                    duration: 0.4,
                    ease: "power2.out",
                });
            });
        });
    }

    /* ── Micro-interaction: Brand letter scatter on hover ── */
    function setupBrandScatter() {
        const brand = document.getElementById("header-brand");
        if (!brand) return;

        brand.addEventListener("mouseenter", () => {
            const letters = brand.querySelectorAll(".brand-letter");
            letters.forEach((letter) => {
                const randomRotate = (Math.random() - 0.5) * 6; // ±3deg
                const randomY = (Math.random() - 0.5) * 4; // ±2px
                gsap.to(letter, {
                    rotate: randomRotate,
                    y: randomY,
                    duration: 0.3,
                    ease: "power2.out",
                });
            });
        });

        brand.addEventListener("mouseleave", () => {
            const letters = brand.querySelectorAll(".brand-letter");
            gsap.to(letters, {
                rotate: 0,
                y: 0,
                duration: 0.4,
                stagger: 0.02,
                ease: "power2.out",
            });
        });
    }

    /* ── Mobile Menu Logic ── */
    function setupMobileMenu() {
        const toggle = document.getElementById("mobile-menu-toggle");
        const overlay = document.getElementById("mobile-menu-overlay");
        const header = document.getElementById("site-header");
        const links = document.querySelectorAll(".mobile-nav-link");

        if (!toggle || !overlay || !header) return;

        let isOpen = false;

        const toggleMenu = () => {
            isOpen = !isOpen;
            toggle.classList.toggle("active", isOpen);
            overlay.classList.toggle("active", isOpen);
            header.classList.toggle("menu-open", isOpen);
            document.body.style.overflow = isOpen ? "hidden" : "";

            if (isOpen) {
                gsap.fromTo(
                    ".mobile-nav-link",
                    { opacity: 0, y: 20, x: -10 },
                    {
                        opacity: 1,
                        y: 0,
                        x: 0,
                        duration: 0.5,
                        stagger: 0.08,
                        ease: "power4.out",
                        delay: 0.2,
                    },
                );
            }
        };

        toggle.addEventListener("click", toggleMenu);

        // Close on link click
        links.forEach((link) => {
            link.addEventListener("click", () => {
                if (isOpen) toggleMenu();
            });
        });
    }

    /* ── Init ── */
    function initHeader() {
        const header = document.getElementById("site-header");
        if (!header || header.dataset.initialized) return;

        header.dataset.initialized = "true";
        // @ts-ignore
        window.headerReady = false;

        animateHeader();
        setupMagneticHover();
        setupBrandScatter();
        setupMobileMenu();
    }

    // Rely solely on astro:page-load to prevent double-initialization
    document.addEventListener("astro:page-load", initHeader);

    /* ── Keyboard shortcuts ── */

    function showToast(label: string, hint: string) {
        const toast = document.getElementById("shortcut-toast");
        if (!toast) return;

        toast.textContent = `→ ${label}`;
        toast.setAttribute("data-key", hint);
        toast.classList.add("visible");

        setTimeout(() => toast.classList.remove("visible"), 1200);
    }

    function toggleHelpPanel() {
        const panel = document.getElementById("shortcut-panel");
        const header = document.querySelector("header");
        if (!panel) return;
        const isOpen = panel.classList.toggle("open");
        panel.setAttribute("aria-hidden", String(!isOpen));

        if (header) {
            header.classList.toggle("shortcuts-revealed", isOpen);
        }
    }

    // Build help panel content
    const list = document.getElementById("shortcut-list");
    if (list) {
        NAV_SHORTCUTS.forEach((s) => {
            const li = document.createElement("li");
            const kbdHtml = s.displayKeys
                .map((k) => `<kbd>${k}</kbd>`)
                .join(" ");
            li.innerHTML = `<span class="shortcut-label">${s.label}</span><div class="shortcut-keys">${kbdHtml}</div>`;
            list.appendChild(li);
        });
    }

    // Register all shortcuts from config
    const bindings: Record<string, (e: KeyboardEvent) => void> = {};

    NAV_SHORTCUTS.forEach((shortcut) => {
        bindings[shortcut.keys] = (e: KeyboardEvent) => {
            e.preventDefault();
            showToast(shortcut.label, shortcut.hint);
            setTimeout(() => {
                window.location.href = shortcut.href;
            }, 300);
        };
    });

    // ? to toggle help panel
    bindings["Shift+?"] = (e: KeyboardEvent) => {
        e.preventDefault();
        toggleHelpPanel();
    };

    tinykeys(window, bindings);
</script>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    header#site-header {
        background: transparent;
        isolation: auto;
        mix-blend-mode: difference;
        color: $color-white;
        opacity: 1; // Default visible
        transition: opacity 0.4s ease;

        // FOUC Shroud Logic: Hide entire header until animation starts
        // Except for returning users (handled by .header-skip-anim)
        &.header-anim:not(:global(.header-skip-anim)) {
            opacity: 0;
            pointer-events: none;
        }
    }

    :global(.header-skip-anim) header#site-header {
        .brand,
        .desktop-nav,
        .actions-group {
            opacity: 1 !important;
        }
    }

    header .header-content {
        display: flex;
        flex-wrap: nowrap;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        background: transparent;
    }

    .nav-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .actions-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    /* ── Desktop Nav ── */
    .desktop-nav {
        display: none;
        gap: 0;
        flex-wrap: wrap;
        font-size: 0.875rem;

        @media (min-width: 1024px) {
            display: flex;
        }
    }

    .desktop-cta {
        display: none;
        @media (min-width: 640px) {
            display: block;
        }

        // Force pure white for compatible inversion
        :global(.button.outline) {
            color: #ffffff !important;
            border-color: #ffffff !important;
            background-color: transparent !important;

            &:hover {
                background-color: #ffffff !important;
                color: #000000 !important;
            }
        }
    }

    /* ── Mobile Menu Toggle ── */
    .mobile-menu-toggle {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 10001;
        padding: 0;

        @media (min-width: 1024px) {
            display: none;
        }

        .line {
            display: block;
            width: 20px;
            height: 2px;
            background: currentColor;
            transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
            border-radius: 2px;
        }

        &.active {
            .line-1 {
                transform: translateY(3.5px) rotate(45deg);
            }
            .line-2 {
                transform: translateY(-3.5px) rotate(-45deg);
            }
        }
    }

    /* ── Mobile Overlay ── */
    .mobile-menu-overlay {
        position: fixed;
        inset: 0;
        background: $color-light-bg;
        z-index: 10000;
        display: flex;
        flex-direction: column;
        padding: 8rem 2rem 2rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s cubic-bezier(0.23, 1, 0.32, 1);

        :global(.dark) & {
            background: $color-dark-bg;
        }

        &.active {
            opacity: 1;
            pointer-events: auto;
        }

        .overlay-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
    }

    .mobile-nav {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .mobile-nav-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: $font-display;
        font-size: 2.5rem;
        font-weight: 400;
        color: $color-black;
        text-decoration: none;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);

        :global(.dark) & {
            color: $color-white;
            border-bottom-color: rgba(255, 255, 255, 0.05);
        }

        .link-hint {
            font-family: $font-mono;
            font-size: 0.75rem;
            font-weight: 400;
            opacity: 0.35;
        }
    }

    .overlay-footer {
        margin-top: auto;
        padding-top: 2rem;
    }

    /* ── Brand ── */
    .brand {
        font-family: $font-display;
        font-weight: 400;
        color: inherit;
        cursor: pointer;
        font-size: 1.25rem;
        letter-spacing: 0.05em;

        @media (min-width: 640px) {
            font-size: 1.125rem;
        }

        :global(.brand-letter) {
            display: inline-block;
        }
    }

    header #header-brand {
        // opacity removed - handled by GSAP
    }

    header .header-content :global(a.header-nav-link) {
        position: relative;
        padding: 0.25rem 0.5rem;
        text-decoration: none;

        // Underline reveal on hover
        &::after {
            content: "";
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100%;
            height: 1px;
            background: currentColor;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        }

        &:hover {
            &::after {
                transform: scaleX(1);
            }
        }
    }

    /* ── Shortcut Toast ── */
    :global(.shortcut-toast) {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: $color-black;
        color: $color-white;
        padding: 0.5rem 1.25rem;
        border-radius: 999px;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        opacity: 0;
        pointer-events: none;
        transition:
            opacity 0.3s ease,
            transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        z-index: 11000;
        white-space: nowrap;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);

        :global(.dark) & {
            background: $color-white;
            color: $color-black;
        }

        &:global(.visible) {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
    }

    /* ── Shortcut Help Panel ── */
    :global(.shortcut-panel) {
        position: fixed;
        inset: 0;
        z-index: 9500;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;

        &:global(.open) {
            opacity: 1;
            pointer-events: auto;
        }
    }

    :global(.shortcut-panel-inner) {
        background: $color-white;
        border-radius: 1rem;
        padding: 2rem;
        min-width: 320px;
        max-width: 420px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.2);

        :global(.dark) & {
            background: #292524;
        }
    }

    :global(.shortcut-panel-header) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);

        h3 {
            font-size: 1rem;
            font-weight: 700;
            margin: 0;
            color: $color-black;

            :global(.dark) & {
                color: $color-white;
            }
        }

        :global(.dark) & {
            border-color: rgba(255, 255, 255, 0.1);
        }
    }

    :global(.shortcut-list) {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;

        li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.375rem 0;
        }
    }

    :global(.shortcut-label) {
        font-size: 0.875rem;
        color: $color-black;
        opacity: 0.8;

        :global(.dark) & {
            color: $color-white;
        }
    }

    :global(kbd) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.15rem 0.4rem;
        border-radius: 99px;
        font-family:
            ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
            "Liberation Mono", monospace;
        font-size: 0.55rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        border: 1px solid rgba(0, 0, 0, 0.04);
        color: rgba(0, 0, 0, 0.35);
        line-height: 1;
        vertical-align: middle;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.06);
            color: rgba(255, 255, 255, 0.6);
        }
    }

    .nav-shortcut {
        display: inline-flex;
        margin-left: 0.5rem;
        opacity: 0.8;
        transform: scale(1);
        pointer-events: none;
        white-space: nowrap;
        vertical-align: middle;
    }

    :global(.shortcut-keys) {
        display: flex;
        gap: 0.25rem;
    }
</style>
