---

<section
    class="expertise-section animate"
    id="expertise-container"
    data-scroll-personality="technical"
>
    <div class="architectural-void" id="prism-board">
        <!-- Blueprint Grid System -->
        <div class="technical-grid"></div>

        <!-- Canvas Rendering Layer -->
        <canvas id="expertise-canvas" class="expertise-canvas"></canvas>

        <!-- Interactive Technical HUD -->
        <div class="discovery-lens" id="discovery-lens">
            <div class="lens-labels">
                <span class="label-coord" id="lens-x">X: 000</span>
                <span class="label-coord" id="lens-y">Y: 000</span>
                <span class="label-status">SYSTEM: OPTIC_ACTIVE</span>
            </div>
            <div class="lens-crosshair"></div>
        </div>
    </div>
</section>

<div class="expertise-mobile-fallback">
    <div class="section-header">
        <h5 class="section-title">Core Competencies</h5>
    </div>
    <ul class="mobile-skills-list">
        <!-- Render from server to eliminate all JS dependency on mobile -->
        {
            [
                { name: "Node.js", weight: "800", size: "lg" },
                { name: "TypeScript", weight: "600", size: "md" },
                { name: "React", weight: "300", size: "sm" },
                { name: "Prometheus", weight: "800", size: "lg" },
                { name: "Grafana", weight: "600", size: "md" },
                { name: "Docker", weight: "300", size: "sm" },
                { name: "K8s", weight: "800", size: "md" },
                { name: "k6", weight: "600", size: "sm" },
                { name: "Three.js", weight: "300", size: "lg" },
                { name: "React Native", weight: "800", size: "sm" },
                { name: "Rust", weight: "600", size: "md" },
                { name: "AWS", weight: "300", size: "md" },
                { name: "Astro.js", weight: "800", size: "lg" },
            ].map((skill) => (
                <li
                    class={`skill-pill weight-${skill.weight} size-${skill.size}`}
                >
                    {skill.name}
                </li>
            ))
        }
    </ul>
</div>

<script>
    import Matter from "matter-js";
    import { gsap } from "gsap";
    import {
        registerAnimation,
        prefersReducedMotion,
    } from "@lib/animation";

    const {
        Engine,
        Events,
        Runner,
        Bodies,
        Composite,
        Body: MatterBody,
    } = Matter;

    const SKILLS = [
        { name: "Node.js", depth: 1.25, weight: "800", size: "lg" },
        { name: "TypeScript", depth: 1, weight: "600", size: "md" },
        { name: "React", depth: 0.75, weight: "300", size: "sm" },
        { name: "Prometheus", depth: 1.25, weight: "800", size: "lg" },
        { name: "Grafana", depth: 1, weight: "600", size: "md" },
        { name: "Docker", depth: 0.75, weight: "300", size: "sm" },
        { name: "K8s", depth: 1.25, weight: "800", size: "md" },
        { name: "k6", depth: 1, weight: "600", size: "sm" },
        { name: "Three.js", depth: 0.75, weight: "300", size: "lg" },
        { name: "React Native", depth: 1.25, weight: "800", size: "sm" },
        { name: "Rust", depth: 1, weight: "600", size: "md" },
        { name: "AWS", depth: 0.75, weight: "300", size: "md" },
        { name: "Astro.js", depth: 1.25, weight: "800", size: "lg" },
    ];

    class ExpertiseCanvas {
        private board: HTMLElement;
        private boardRect!: DOMRect;
        private canvas: HTMLCanvasElement;
        private ctx: CanvasRenderingContext2D;
        private engine: any;
        private runner: any;
        private bodies: any[] = [];
        private dpr: number = 1;
        private mouse = { x: 0, y: 0, active: false };
        private theme: "light" | "dark" = "light";
        private observer: MutationObserver | null = null;
        private intersectionObserver: IntersectionObserver | null = null;
        private rafId: number | null = null;
        private isMobile: boolean = false;
        private signal: AbortSignal;

        constructor(signal: AbortSignal) {
            this.signal = signal;
            this.board = document.getElementById("prism-board")!;
            this.canvas = document.getElementById(
                "expertise-canvas",
            ) as HTMLCanvasElement;
            this.ctx = this.canvas.getContext("2d")!;
            this.theme = document.documentElement.classList.contains("dark")
                ? "dark"
                : "light";

            this.observer = new MutationObserver(() => {
                this.theme = document.documentElement.classList.contains(
                    "dark",
                )
                    ? "dark"
                    : "light";
            });
            this.observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["class"],
            });

            // PERFORMANCE: Defer init until the section is in view
            this.intersectionObserver = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            this.init();
                            this.intersectionObserver?.disconnect();
                            this.intersectionObserver = null;
                        }
                    });
                },
                { rootMargin: "200px" },
            );

            this.intersectionObserver.observe(this.board);

            // Auto-dispose when the registered animation is reverted
            this.signal.addEventListener("abort", () => this.stop());
        }

        private init() {
            this.resize();
            window.addEventListener("resize", () => this.resize(), {
                signal: this.signal,
                passive: true,
            });

            // CPU SAVER: Bypass all heavy Physics simulation if mobile viewport
            if (this.isMobile) return;

            // Physics Setup
            this.engine = Engine.create();
            this.engine.gravity.y = 0;

            const width = this.canvas.width / this.dpr;
            const height = this.canvas.height / this.dpr;

            // Create Physics Bodies
            this.bodies = SKILLS.map((skill) => {
                const fontSize = this.getFontSize(skill.size);
                this.ctx.font = `${skill.weight} ${fontSize}px "Anton"`;
                const textMetrics = this.ctx.measureText(skill.name);

                const paddingH = fontSize * 1.5;
                const paddingV = fontSize * 0.8;
                const rectW = textMetrics.width + paddingH;
                const rectH = fontSize + paddingV;

                const x = (Math.random() * 0.6 + 0.2) * width;
                const y = (Math.random() * 0.6 + 0.2) * height;

                const body = Bodies.rectangle(x, y, rectW, rectH, {
                    chamfer: { radius: 2 },
                    restitution: 0.8,
                    frictionAir: 0.04 / skill.depth,
                    label: "skill-tag",
                });

                return {
                    body,
                    skill,
                    width: rectW,
                    height: rectH,
                    revealOpacity: 0,
                };
            });

            // Boundaries
            const wallOptions = { isStatic: true, restitution: 1 };
            Composite.add(this.engine.world, [
                ...this.bodies.map((b) => b.body),
                Bodies.rectangle(
                    width / 2,
                    height + 100,
                    width,
                    200,
                    wallOptions,
                ),
                Bodies.rectangle(width / 2, -100, width, 200, wallOptions),
                Bodies.rectangle(-100, height / 2, 200, height, wallOptions),
                Bodies.rectangle(
                    width + 100,
                    height / 2,
                    200,
                    height,
                    wallOptions,
                ),
            ]);

            // Reveal Animation
            this.bodies.forEach((b, i) => {
                gsap.to(b, {
                    revealOpacity: 1,
                    duration: 1.5,
                    delay: i * 0.05,
                    ease: "power4.out",
                });
            });

            this.setupInteraction();

            this.runner = Runner.create();
            Runner.run(this.runner, this.engine);

            Events.on(this.engine, "afterUpdate", () => this.draw());
        }

        private getFontSize(size: string) {
            if (size === "lg") return this.isMobile ? 24 : 32;
            if (size === "md") return this.isMobile ? 18 : 22;
            return this.isMobile ? 14 : 16;
        }

        private resize() {
            this.isMobile = window.innerWidth < 768;
            this.dpr = window.devicePixelRatio || 1;
            this.boardRect = this.board.getBoundingClientRect();
            const rect = this.boardRect;
            this.canvas.width = rect.width * this.dpr;
            this.canvas.height = rect.height * this.dpr;
            this.canvas.style.width = `${rect.width}px`;
            this.canvas.style.height = `${rect.height}px`;
            this.ctx.scale(this.dpr, this.dpr);
        }

        private setupInteraction() {
            const lens = document.getElementById("discovery-lens");
            const coordX = document.getElementById("lens-x");
            const coordY = document.getElementById("lens-y");

            this.board.addEventListener(
                "mousemove",
                (e) => {
                    const target = e.target as HTMLElement;
                    if (target === this.canvas) {
                        this.mouse.x = e.offsetX;
                        this.mouse.y = e.offsetY;
                    } else {
                        const rect = this.boardRect;
                        this.mouse.x = e.clientX - rect.left;
                        this.mouse.y = e.clientY - rect.top;
                    }
                    this.mouse.active = true;

                    if (lens && !this.rafId) {
                        this.rafId = requestAnimationFrame(() => {
                            lens.style.transform = `translate3d(${this.mouse.x - 125}px, ${this.mouse.y - 125}px, 0)`;
                            lens.style.opacity = "1";
                            if (coordX)
                                coordX.innerText = `X: ${Math.round(this.mouse.x).toString().padStart(3, "0")}`;
                            if (coordY)
                                coordY.innerText = `Y: ${Math.round(this.mouse.y).toString().padStart(3, "0")}`;
                            this.rafId = null;
                        });
                    }
                },
                { signal: this.signal },
            );

            this.board.addEventListener(
                "mouseleave",
                () => {
                    this.mouse.active = false;
                    if (lens) lens.style.opacity = "0";
                },
                { signal: this.signal },
            );
        }

        private draw() {
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

            // Sort by depth for correct layering (back to front)
            const sortedBodies = [...this.bodies].sort(
                (a, b) => a.skill.depth - b.skill.depth,
            );

            sortedBodies.forEach(
                ({ body, skill, width, height, revealOpacity }) => {
                    const { depth } = skill;

                    // Attraction Physics
                    if (this.mouse.active) {
                        const dx = this.mouse.x - body.position.x;
                        const dy = this.mouse.y - body.position.y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        const range = 400 * depth;

                        if (dist < range) {
                            const pull = 0.001 * depth * (1 - dist / range);
                            MatterBody.applyForce(body, body.position, {
                                x: dx * pull,
                                y: dy * pull,
                            });
                        }
                    }

                    // Spacing
                    this.bodies.forEach((other) => {
                        if (other.body === body) return;
                        const dx = other.body.position.x - body.position.x;
                        const dy = other.body.position.y - body.position.y;
                        const distSq = dx * dx + dy * dy;
                        if (distSq < 12000) {
                            const push = 0.0003 / (distSq + 1);
                            MatterBody.applyForce(body, body.position, {
                                x: -dx * push,
                                y: -dy * push,
                            });
                        }
                    });

                    // Rendering Calculations
                    const focusDist = this.mouse.active
                        ? Math.sqrt(
                              Math.pow(this.mouse.x - body.position.x, 2) +
                                  Math.pow(this.mouse.y - body.position.y, 2),
                          )
                        : 500;
                    const blur = Math.max(
                        0,
                        focusDist / 150 - 1 + (1 - depth) * 2,
                    );
                    const opacity = (0.2 + depth * 0.8) * revealOpacity;
                    const scale = depth * (1 + body.speed * 0.015);
                    const skewX = body.velocity.x * 0.6;

                    this.ctx.save();
                    this.ctx.translate(body.position.x, body.position.y);
                    this.ctx.rotate(body.angle);
                    this.ctx.scale(scale, scale);
                    this.ctx.transform(
                        1,
                        0,
                        Math.tan((skewX * Math.PI) / 180),
                        1,
                        0,
                        0,
                    );

                    this.ctx.globalAlpha = opacity;

                    // Box
                    this.ctx.fillStyle =
                        this.theme === "dark" ? "#ffffff" : "#000000";
                    this.ctx.fillRect(-width / 2, -height / 2, width, height);

                    // Text
                    this.ctx.fillStyle =
                        this.theme === "dark" ? "#000000" : "#ffffff";
                    this.ctx.font = `${skill.weight} ${this.getFontSize(skill.size)}px "Anton"`;
                    this.ctx.textAlign = "center";
                    this.ctx.textBaseline = "middle";
                    this.ctx.fillText(skill.name, 0, 1); // Tiny vertical offset for optical centering

                    this.ctx.restore();
                },
            );
        }

        public stop() {
            if (this.runner) {
                Runner.stop(this.runner);
                this.runner = null;
            }
            if (this.engine) {
                Engine.clear(this.engine);
                this.engine = null;
            }
            if (this.observer) {
                this.observer.disconnect();
                this.observer = null;
            }
            if (this.intersectionObserver) {
                this.intersectionObserver.disconnect();
                this.intersectionObserver = null;
            }
            if (this.rafId) {
                cancelAnimationFrame(this.rafId);
                this.rafId = null;
            }
            // Resize listener is auto-removed via the AbortSignal
        }
    }

    document.addEventListener("astro:page-load", () => {
        registerAnimation("expertise-canvas", (_gsap, signal) => {
            // Reduced motion: skip the entire physics simulation; the static
            // mobile fallback CSS rule already shows a clean skill list on
            // small viewports, but on desktop with reduced-motion we just
            // hide the architectural void to avoid any kinetic motion.
            if (prefersReducedMotion()) {
                const board = document.getElementById("prism-board");
                if (board) board.style.display = "none";
                return;
            }

            const board = document.getElementById("prism-board");
            const canvas = document.getElementById("expertise-canvas");
            if (!board || !canvas) return;

            // eslint-disable-next-line no-new -- intentional fire-and-forget;
            // disposal is wired through the AbortSignal in the constructor.
            new ExpertiseCanvas(signal);
        });
    });
</script>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .expertise-section {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        user-select: none;
    }

    .architectural-void {
        position: relative;
        width: 100%;
        height: 400px;
        border: 1px dashed rgba($color-black, 0.15);
        border-radius: 0.5rem;
        overflow: hidden;
        background: transparent;

        @include screen(md) {
            height: 650px;
        }

        :global(.dark) & {
            background: #000;
            border-color: rgba($color-white, 0.15);
        }
    }

    .technical-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba($color-black, 0.03) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgba($color-black, 0.03) 1px,
                transparent 1px
            );
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 1;

        :global(.dark) & {
            background-image:
                linear-gradient(rgba($color-white, 0.03) 1px, transparent 1px),
                linear-gradient(
                    90deg,
                    rgba($color-white, 0.03) 1px,
                    transparent 1px
                );
        }
    }

    .expertise-canvas {
        position: absolute;
        inset: 0;
        z-index: 2;
        cursor: none;
    }

    .discovery-lens {
        position: absolute;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 100;
        opacity: 0;
        will-change: transform;

        // Refractive Optics
        backdrop-filter: blur(2px) contrast(1.2) saturate(1.2);
        mix-blend-mode: difference;
        border: 1px solid rgba($color-white, 0.5);
        box-shadow: 0 0 100px rgba($color-white, 0.1);

        .lens-crosshair {
            position: absolute;
            inset: 0;
            &::before,
            &::after {
                content: "";
                position: absolute;
                background: rgba($color-white, 0.3);
            }
            &::before {
                top: 50%;
                left: 10%;
                right: 10%;
                height: 1px;
            }
            &::after {
                left: 50%;
                top: 10%;
                bottom: 10%;
                width: 1px;
            }
        }

        .lens-labels {
            position: absolute;
            top: -50px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            gap: 2px;
            align-items: center;
            font-family: $font-mono;
            font-size: 0.65rem;
            font-weight: 700;
            color: $color-black;
            background: $color-white;
            padding: 4px 8px;
            border-radius: 2px;
            white-space: nowrap;

            :global(.dark) & {
                color: $color-white;
                background: $color-black;
                border: 1px solid rgba($color-white, 0.2);
            }

            .label-status {
                opacity: 0.6;
                font-size: 0.55rem;
            }
        }
    }

    .expertise-section {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        user-select: none;
    }

    .architectural-void {
        position: relative;
        width: 100%;
        height: 400px;
        border: 1px dashed rgba($color-black, 0.15);
        border-radius: 0.5rem;
        overflow: hidden;
        cursor: none;

        // Hide desktop physics simulation on mobile
        @include screen(max-md) {
            display: none;
        }

        @include screen(md) {
            height: 650px;
        }

        :global(.dark) & {
            background: $color-black;
            border-color: rgba($color-white, 0.15);
        }
    }

    // Server-rendered static list for mobile
    .expertise-mobile-fallback {
        display: none;

        @include screen(max-md) {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .section-header {
            margin-bottom: 0.5rem;
        }

        .mobile-skills-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;

            .skill-pill {
                padding: 0.6rem 1rem;
                border: 1px solid rgba($color-black, 0.1);
                border-radius: 4px;
                font-family: $font-display;
                background: $color-white;
                color: $color-black;
                text-transform: uppercase;

                :global(.dark) & {
                    background: transparent;
                    border-color: rgba($color-white, 0.2);
                    color: $color-white;
                }

                &.size-sm {
                    font-size: 1.1rem;
                }
                &.size-md {
                    font-size: 1.5rem;
                }
                &.size-lg {
                    font-size: 2.2rem;
                }

                &.weight-300 {
                    font-weight: 300;
                }
                &.weight-600 {
                    font-weight: 600;
                }
                &.weight-800 {
                    font-weight: 800;
                }
            }
        }
    }

