<section
    class="expertise-section animate"
    id="expertise-container"
    data-scroll-personality="technical"
>
    <div class="architectural-void" id="prism-board">
        <!-- Blueprint Grid System -->
        <div class="technical-grid"></div>

        <!-- Interactive Technical HUD -->
        <div class="discovery-lens" id="discovery-lens">
            <div class="lens-labels">
                <span class="label-coord" id="lens-x">X: 000</span>
                <span class="label-coord" id="lens-y">Y: 000</span>
                <span class="label-status">SYSTEM: OPTIC_ACTIVE</span>
            </div>
            <div class="lens-crosshair"></div>
        </div>

        <!-- Semantic Skill Elements with Depth & Rhythm -->
        <div
            class="kinetic-tag depth-front weight-bold size-lg"
            data-skill="Node.js"
        >
            Node.js
        </div>
        <div
            class="kinetic-tag depth-mid weight-medium size-md"
            data-skill="TypeScript"
        >
            TypeScript
        </div>
        <div
            class="kinetic-tag depth-back weight-light size-sm"
            data-skill="React"
        >
            React
        </div>
        <div
            class="kinetic-tag depth-front weight-bold size-lg"
            data-skill="Prometheus"
        >
            Prometheus
        </div>
        <div
            class="kinetic-tag depth-mid weight-medium size-md"
            data-skill="Grafana"
        >
            Grafana
        </div>
        <div
            class="kinetic-tag depth-back weight-light size-sm"
            data-skill="Docker"
        >
            Docker
        </div>
        <div
            class="kinetic-tag depth-front weight-bold size-md"
            data-skill="Kubernetes"
        >
            K8s
        </div>
        <div
            class="kinetic-tag depth-mid weight-medium size-sm"
            data-skill="k6"
        >
            k6
        </div>
        <div
            class="kinetic-tag depth-back weight-light size-lg"
            data-skill="Three.js"
        >
            Three.js
        </div>
        <div
            class="kinetic-tag depth-front weight-bold size-sm"
            data-skill="React Native"
        >
            React Native
        </div>
        <div
            class="kinetic-tag depth-mid weight-medium size-md"
            data-skill="Rust"
        >
            Rust
        </div>
        <div
            class="kinetic-tag depth-back weight-light size-md"
