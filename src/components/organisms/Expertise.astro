            }
        }

        .lens-labels {
            position: absolute;
            top: -50px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            gap: 2px;
            align-items: center;
            font-family:
                ui-monospace, "Cascadia Code", "Source Code Pro", Menlo,
                Consolas, monospace;
            font-size: 0.65rem;
            font-weight: 700;
            color: $color-black;
            background: $color-white;
            padding: 4px 8px;
            border-radius: 2px;
            white-space: nowrap;

            :global(.dark) & {
                color: $color-white;
                background: $color-black;
                border: 1px solid rgba($color-white, 0.2);
            }

            .label-status {
                opacity: 0.6;
                font-size: 0.55rem;
            }
        }
    }

    .kinetic-tag {
        position: absolute;
        background: $color-black;
        color: $color-white;
        border-radius: 2px; // Fixed square architectural feel
        white-space: nowrap;
        opacity: 0;
        will-change: transform, filter;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: inherit;
        border: 1px solid rgba($color-white, 0.1);
        padding: 0.6rem 1.4rem;

        :global(.dark) & {
            background: $color-white;
            color: $color-black;
            border-color: rgba($color-black, 0.1);
        }

        // Depth Layering
        &.depth-front {
            z-index: 80;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
        }
        &.depth-mid {
            z-index: 50;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }
        &.depth-back {
            z-index: 20;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        // Typographic Rhythm
        &.weight-bold {
            font-weight: 800;
            letter-spacing: -0.04em;
            transform-style: preserve-3d;
        }
        &.weight-medium {
            font-weight: 600;
            letter-spacing: -0.02em;
        }
        &.weight-light {
            font-weight: 300;
            letter-spacing: 0.02em;
        }

        &.size-lg {
            font-size: 1.25rem;
            padding: 0.75rem 1.5rem;
            @include screen(md) {
                font-size: 1.8rem;
                padding: 1rem 2.2rem;
            }
        }
        &.size-md {
            font-size: 1rem;
            padding: 0.6rem 1.2rem;
            @include screen(md) {
                font-size: 1.2rem;
                padding: 0.7rem 1.8rem;
            }
        }
        &.size-sm {
            font-size: 0.8rem;
            padding: 0.4rem 1rem;
            @include screen(md) {
                font-size: 0.9rem;
                padding: 0.5rem 1.2rem;
            }
        }
    }

    .expertise-header {
        position: relative;
        &::before {
            content: "";
            position: absolute;
            left: -1rem;
            top: 50%;
            width: 4px;
            height: 4px;
            background: $color-black;
            border-radius: 50%;
            :global(.dark) & {
                background: $color-white;
            }
        }
    }
</style>
