        background-size: 40px 40px;
        pointer-events: none;

        :global(.dark) & {
            background-image:
                linear-gradient(rgba($color-white, 0.03) 1px, transparent 1px),
                linear-gradient(
                    90deg,
                    rgba($color-white, 0.03) 1px,
                    transparent 1px
                );
        }
    }

    .discovery-lens {
        position: absolute;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 100;
        opacity: 0;
        will-change: transform;

        // Refractive Optics
        backdrop-filter: blur(2px) contrast(1.2) saturate(1.2);
