---
import Link from "../atoms/Link.astro";
---

<section class="about-section animate section">
    <div class="about-grid">
        <!-- Left Column: Intro Hook -->
        <div class="about-left" data-speed="0.1">
            <h5 class="section-title">
                <span class="status-marker"></span>
                About
            </h5>
            <p class="intro-hook reveal-text">
                Hey! I'm Mahmoud <span class="phonetic">[ma-moud]</span>, a kind
                design-driven developer based in Egypt.
            </p>
            <div class="technical-label">STATUS: BIOGRAPHIC_SCAN</div>
        </div>

        <!-- Right Column: Role & Details -->
        <div class="about-right" data-speed="-0.05">
            <h2 class="role-title reveal-text">Creative Developer</h2>

            <div class="bio-content">
                <p class="reveal-text">
                    My approach prioritizes human understanding over just lines
                    of code, bridging technology with psychology and art to
                    create more intuitive and impactful digital experiences.
                </p>
                <p class="reveal-text">
                    With a background in Psychology and a deep passion for
                    mathematics and philosophy, I’ve become a developer driven
                    by <span class="highlight">curiosity, logic, and craft</span
                    >.
                </p>
                <p class="reveal-text">
                    Off work, I explore the intersections of technology and
                    human behavior, write about design, and find inspiration in
                    creative coding and fine art.
                </p>
            </div>

            <div class="cta-wrapper animate">
                <Link href="/resume.pdf" class="resume-button" external>
                    <span class="icon">👁</span>
                    View Resume
                </Link>
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .about-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 1px dashed rgba($color-black, 0.15);
        perspective: 1000px;

        @include screen(md) {
            margin-top: 6rem;
            padding-top: 4rem;
        }

        :global(.dark) & {
            border-top-color: rgba($color-white, 0.15);
        }
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;

        @include screen(lg) {
            grid-template-columns: 1fr 2fr;
            gap: 6rem;
        }
    }

    .about-left {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        will-change: transform;

        .section-title {
            margin-bottom: 0;
            text-transform: capitalize;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            display: flex;
            align-items: center;
            gap: 0.75rem;

            .status-marker {
                width: 6px;
                height: 6px;
                background: $color-black;
                border-radius: 50%;
                :global(.dark) & {
                    background: $color-white;
                }
            }
        }

        .intro-hook {
            font-size: 1.15rem;
            line-height: 1.4;
            color: rgba($color-black, 0.9);
            max-width: 100%;
            font-weight: 500;

            @include screen(md) {
                font-size: 1.35rem;
            }

            @include screen(lg) {
                max-width: 320px;
            }

            .phonetic {
                font-family: ui-monospace, "Cascadia Code", monospace;
                font-size: 0.9rem;
                opacity: 0.4;
                font-weight: 400;
            }

            :global(.dark) & {
                color: rgba($color-white, 0.9);
            }
        }

        .technical-label {
            font-family: ui-monospace, "Cascadia Code", monospace;
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            opacity: 0.3;
            margin-top: 1rem;
        }
    }

    .about-right {
        display: flex;
        flex-direction: column;
        gap: 2rem; // Reduced from 3rem
        will-change: transform;

        .role-title {
            font-size: clamp(2.5rem, 8vw, 3.5rem); // Fluid small
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            margin: 0;
            color: $color-black;

            @include screen(md) {
                font-size: clamp(3.5rem, 6vw, 5rem); // Fluid large
            }

            :global(.dark) & {
                color: $color-white;
            }
        }

        .bio-content {
            display: flex;
            flex-direction: column;
            gap: 1.5rem; // Reduced
            max-width: 620px;

            p {
                font-size: 1.125rem; // More readable on mobile
                line-height: 1.6;
                font-weight: 500;
                color: rgba($color-black, 0.25);

                @include screen(md) {
                    font-size: 1.5rem;
                }

                :global(.dark) & {
                    color: rgba($color-white, 0.25);
                }
            }

            .highlight {
                color: $color-black;
                font-weight: 600;
                position: relative;
                z-index: 1;

                &::after {
                    content: "";
                    position: absolute;
                    bottom: 2px;
                    left: 0;
                    width: 100%;
                    height: 1px;
                    background: rgba($color-black, 0.2);
                }

                :global(.dark) & {
                    color: $color-white;
                    &::after {
                        background: rgba($color-white, 0.2);
                    }
                }
            }
        }
    }

    .cta-wrapper {
        margin-top: 1rem;
    }

    .resume-button {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 2.2rem;
        background: transparent;
        border: 1px solid rgba($color-black, 0.15);
        border-radius: 99px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        color: $color-black;
        position: relative;
        overflow: hidden;

        :global(.dark) & {
            border-color: rgba($color-white, 0.15);
            color: $color-white;
        }

        .icon {
            font-size: 1.2rem;
            opacity: 0.6;
        }

        &::before {
            content: "";
            position: absolute;
            inset: 0;
            background: $color-black;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: -1;
            :global(.dark) & {
                background: $color-white;
            }
        }

        &:hover {
            color: $color-white;
            border-color: $color-black;
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);

            &::before {
                transform: scaleX(1);
                transform-origin: left;
            }

            .icon {
                opacity: 1;
            }

            :global(.dark) & {
                color: $color-black;
                border-color: $color-white;
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
            }
        }
    }

    /* ── Split Text Animation Overrides ── */
    /* Words will start with the base color defined above and animate to full opacity */
    :global(.reveal-word) {
        display: inline-block;
        /* Custom property manipulated by GSAP */
        color: rgba(var(--text-color-rgb), var(--reveal-progress, 0.25));
        will-change: color;
    }
</style>

<script>
    import {
        registerAnimation,
        prefersReducedMotion,
    } from "@lib/animation";

    // Theme observer is bound exactly once for the whole session and never
    // re-bound across view transitions (the same html element is reused).
    let themeObserver: MutationObserver | null = null;

    function ensureThemeObserver() {
        if (themeObserver) return;
        themeObserver = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.attributeName === "class") {
                    const isDark =
                        document.documentElement.classList.contains("dark");
                    const rgbColor = isDark ? "255, 255, 255" : "0, 0, 0";
                    document.querySelectorAll(".reveal-word").forEach((el) => {
                        (el as HTMLElement).style.setProperty(
                            "--text-color-rgb",
                            rgbColor,
                        );
                    });
                }
            });
        });
        themeObserver.observe(document.documentElement, { attributes: true });
    }

    document.addEventListener("astro:page-load", () => {
        ensureThemeObserver();

        registerAnimation("about-organism:reveal-text", (gsap) => {
            const revealElements = document.querySelectorAll(".reveal-text");
            if (!revealElements.length) return;

            const isDark =
                document.documentElement.classList.contains("dark");
            const rgbColor = isDark ? "255, 255, 255" : "0, 0, 0";
            const baseOpacity = 0.25;

            revealElements.forEach((el) => {
                // Skip elements already split by an earlier mount
                if (el.classList.contains("is-split")) return;
                el.classList.add("is-split");

                const nodes = Array.from(el.childNodes);
                el.innerHTML = "";

                const allWordSpans: HTMLElement[] = [];

                nodes.forEach((node) => {
                    if (node.nodeType === Node.TEXT_NODE) {
                        const text = node.textContent || "";
                        const words = text.split(/(\s+)/);

                        words.forEach((word) => {
                            if (word.trim() === "") {
                                el.appendChild(
                                    document.createTextNode(word),
                                );
                            } else {
                                const wordSpan =
                                    document.createElement("span");
                                wordSpan.className = "reveal-word";
                                wordSpan.textContent = word;
                                wordSpan.style.setProperty(
                                    "--text-color-rgb",
                                    rgbColor,
                                );
                                wordSpan.style.setProperty(
                                    "--reveal-progress",
                                    baseOpacity.toString(),
                                );
                                el.appendChild(wordSpan);
                                allWordSpans.push(wordSpan);
                            }
                        });
                    } else if (node.nodeType === Node.ELEMENT_NODE) {
                        const wrapper = document.createElement("span");
                        wrapper.className = "reveal-word element-wrapper";
                        wrapper.style.setProperty(
                            "--text-color-rgb",
                            rgbColor,
                        );
                        wrapper.style.setProperty("--reveal-progress", "1");
                        wrapper.style.display = "inline-block";
                        wrapper.appendChild(node);
                        el.appendChild(wrapper);
                        allWordSpans.push(wrapper);
                    }
                });

                // Reduced motion: snap straight to fully revealed
                if (prefersReducedMotion()) {
                    allWordSpans.forEach((s) =>
                        s.style.setProperty("--reveal-progress", "1"),
                    );
                    return;
                }

                gsap.to(allWordSpans, {
                    "--reveal-progress": 1,
                    stagger: 0.05,
                    ease: "none",
                    scrollTrigger: {
                        trigger: el,
                        start: "top 85%",
                        end: "bottom 60%",
                        scrub: 0.5,
                    },
                });
            });
        });
    });
</script>
