---

---

<div id="cmdk-overlay" class="cmdk-overlay" aria-hidden="true">
    <div id="cmdk-modal" class="cmdk-modal">
        <div class="cmdk-header">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="cmdk-search-icon"
            >
                <circle
                    cx="11"
                    cy="11"
                    r="7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></circle>
                <path
                    d="M20 20L16.414 16.414"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
            <input
                type="text"
                id="cmdk-input"
                placeholder="What do you need?"
                autocomplete="off"
            />
        </div>
        <div id="cmdk-results" class="cmdk-results" role="listbox">
            <!-- Results injected here -->
        </div>
        <div class="cmdk-footer">
            <div class="cmdk-footer-item">
                <kbd>↑ ↓</kbd>
                <span>Navigate</span>
            </div>
            <div class="cmdk-footer-item">
                <kbd>↵</kbd>
                <span>Select</span>
            </div>
            <div class="cmdk-footer-item">
                <kbd>esc</kbd>
                <span>Close</span>
            </div>
        </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    // @ts-ignore
    import { tinykeys } from "tinykeys";
    import { getCommands, type Command } from "@lib/commands";

    const overlay = document.getElementById("cmdk-overlay");
    const modal = document.getElementById("cmdk-modal");
    const input = document.getElementById("cmdk-input") as HTMLInputElement;
    const resultsContainer = document.getElementById("cmdk-results");

    let allCommands: Command[] = [];
    let filteredCommands: Command[] = [];
    let selectedIndex = 0;
    let isOpen = false;

    function init() {
        allCommands = getCommands();

        // Globals
        tinykeys(window, {
            "$mod+k": (e: KeyboardEvent) => {
                e.preventDefault();
                toggle(true);
            },
            Escape: () => {
                if (isOpen) toggle(false);
            },
        });

        // Overlay click
        overlay?.addEventListener("click", (e) => {
            if (e.target === overlay) toggle(false);
        });

        // Input search
        input?.addEventListener("input", (e) => {
            renderResults((e.target as HTMLInputElement).value);
        });

        // Input keys
        input?.addEventListener("keydown", (e) => {
            if (e.key === "ArrowDown") {
                e.preventDefault();
                updateSelection(1);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                updateSelection(-1);
            } else if (e.key === "Enter") {
                e.preventDefault();
                executeSelected();
            }
        });

        document.addEventListener("cmdk-close", () => toggle(false));
    }

    function lockScroll(lock: boolean) {
        if (lock) {
            // Get scrollbar width to prevent layout shift
            const scrollbarWidth =
                window.innerWidth - document.documentElement.clientWidth;
            document.body.style.overflow = "hidden";
            document.body.style.paddingRight = `${scrollbarWidth}px`;
        } else {
            document.body.style.overflow = "";
            document.body.style.paddingRight = "";
        }
    }

    function toggle(open: boolean) {
        if (!overlay || !modal) return;
        isOpen = open;
        overlay.setAttribute("aria-hidden", String(!open));

        lockScroll(open);

        if (open) {
            overlay.style.display = "flex";

            // Dramatic backdrop blur fade in
            gsap.fromTo(
                overlay,
                { opacity: 0, backdropFilter: "blur(0px) saturate(100%)" },
                {
                    opacity: 1,
                    backdropFilter: "blur(24px) saturate(200%)",
                    duration: 0.6,
                    ease: "power3.out",
                },
            );

            // Architectural Modal 3D Reveal
            gsap.fromTo(
                modal,
                {
                    scale: 0.9,
                    y: 60,
                    rotationX: -15,
                    opacity: 0,
                    transformPerspective: 1200,
                },
                {
                    scale: 1,
                    y: 0,
                    rotationX: 0,
                    opacity: 1,
                    duration: 0.8,
                    ease: "expo.out",
                    clearProps: "transformPerspective",
                },
            );

            input?.focus();
            input.value = "";
            renderResults("");
        } else {
            // Rapid cinematic exit
            gsap.to(overlay, {
                opacity: 0,
                backdropFilter: "blur(0px) saturate(100%)",
                duration: 0.3,
                ease: "power2.in",
                onComplete: () => {
                    overlay.style.display = "none";
                },
            });
            gsap.to(modal, {
                scale: 0.95,
                y: 20,
                opacity: 0,
                duration: 0.3,
                ease: "power2.in",
            });
        }
    }

    function renderResults(query: string) {
        if (!resultsContainer) return;

        const q = query.toLowerCase();
        filteredCommands = allCommands.filter(
            (c) =>
                c.title.toLowerCase().includes(q) ||
                c.section.toLowerCase().includes(q) ||
                c.description?.toLowerCase().includes(q),
        );

        resultsContainer.innerHTML = "";
        selectedIndex = 0;

        if (filteredCommands.length === 0) {
            resultsContainer.innerHTML =
                '<div class="cmdk-empty">No results found. Try searching for "Home" or "Theme".</div>';
            return;
        }

        let currentSection = "";
        filteredCommands.forEach((cmd, idx) => {
            if (cmd.section !== currentSection) {
                currentSection = cmd.section;
                const sectionHeader = document.createElement("div");
                sectionHeader.className = "cmdk-section-header";
                sectionHeader.textContent = currentSection;
                resultsContainer.appendChild(sectionHeader);
            }

            const item = document.createElement("div");
            item.className = "cmdk-item";
            if (idx === 0) item.classList.add("selected");
            item.setAttribute("role", "option");
            item.dataset.index = idx.toString();

            // Content Left (Icon + Title/Desc)
            const left = document.createElement("div");
            left.className = "cmdk-item-left";

            if (cmd.icon) {
                const iconWrap = document.createElement("div");
                iconWrap.className = "cmdk-item-icon";
                iconWrap.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${cmd.icon}"/></svg>`;
                left.appendChild(iconWrap);
            }

            const titleWrap = document.createElement("div");
            titleWrap.className = "cmdk-item-title-wrap";
            titleWrap.innerHTML = `<span class="cmdk-item-title">${cmd.title}</span>`;
            if (cmd.description) {
                titleWrap.innerHTML += `<span class="cmdk-item-desc">${cmd.description}</span>`;
            }
            left.appendChild(titleWrap);
            item.appendChild(left);

            // Right (Shortcut)
            if (cmd.shortcut) {
                const shortcuts = document.createElement("div");
                shortcuts.className = "cmdk-item-shortcuts";
                const kbd = document.createElement("kbd");
                kbd.textContent = cmd.shortcut.join(" ");
                shortcuts.appendChild(kbd);
                item.appendChild(shortcuts);
            }

            item.addEventListener("mouseenter", () => setSelection(idx));
            item.addEventListener("click", () => executeSelected());

            resultsContainer.appendChild(item);
        });

        // Staggered cinematic entrance for results
        const items = resultsContainer.querySelectorAll(".cmdk-item");
        const headers = resultsContainer.querySelectorAll(
            ".cmdk-section-header",
        );

        // Reset opacities first
        gsap.set([headers, items], { opacity: 0 });

        gsap.fromTo(
            headers,
            { opacity: 0, x: -10 },
            {
                opacity: 1,
                x: 0,
                duration: 0.6,
                stagger: 0.1,
                ease: "power3.out",
                delay: 0.1,
            },
        );

        gsap.fromTo(
            items,
            { opacity: 0, y: 15, scale: 0.98 },
            {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 0.6,
                stagger: 0.03,
                ease: "back.out(1.2)",
                delay: 0.15,
            },
        );
    }

    function setSelection(index: number) {
        const items = resultsContainer?.querySelectorAll(".cmdk-item");
        items?.forEach((i) => i.classList.remove("selected"));
        selectedIndex = index;
        const selected = resultsContainer?.querySelector(
            `[data-index="${index}"]`,
        );
        if (selected) {
            selected.classList.add("selected");
            selected.scrollIntoView({ block: "nearest" });

            // Micro-interaction on selection change
            gsap.fromTo(
                selected,
                { x: -4 },
                { x: 0, duration: 0.3, ease: "back.out(2)" },
            );
        }
    }

    function updateSelection(delta: number) {
        let next = selectedIndex + delta;
        if (next < 0) next = filteredCommands.length - 1;
        if (next >= filteredCommands.length) next = 0;
        setSelection(next);
    }

    function executeSelected() {
        const cmd = filteredCommands[selectedIndex];
        if (cmd) {
            cmd.action();
            toggle(false);
        }
    }

    // Handle view transitions
    document.addEventListener("astro:page-load", () => {
        init();
    });

    // Initial load
    init();
</script>

<style lang="scss" is:global>
    @use "../../styles/variables" as *;

    .cmdk-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px) saturate(120%);
        z-index: 10000;
        display: none; // Controlled by script
        justify-content: center;
        padding-top: 15vh;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .cmdk-modal {
        position: relative;
        width: 100%;
        max-width: 680px;
        height: fit-content;
        max-height: 480px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(24px) saturate(200%);
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 0; // Architectural sharp edges
        box-shadow:
            0 40px 80px -20px rgba(0, 0, 0, 0.25),
            0 0 0 1px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        overflow: hidden;

        /* Technical Grid Overlay */
        &::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
            background-size: 20px 20px;
            pointer-events: none;
            z-index: 0;
        }

        :global(.dark) & {
            background: rgba(15, 15, 15, 0.95);
            border-color: rgba(255, 255, 255, 0.1);
            box-shadow:
                0 40px 80px -20px rgba(0, 0, 0, 0.8),
                0 0 0 1px rgba(255, 255, 255, 0.05);

            &::before {
                background-image:
                    linear-gradient(
                        rgba(255, 255, 255, 0.02) 1px,
                        transparent 1px
                    ),
                    linear-gradient(
                        90deg,
                        rgba(255, 255, 255, 0.02) 1px,
                        transparent 1px
                    );
            }
        }
    }

    .cmdk-header {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        padding: 1.5rem 1.25rem;
        gap: 1rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);

        :global(.dark) & {
            border-color: rgba(255, 255, 255, 0.05);
        }
    }

    .cmdk-search-icon {
        width: 14px;
        height: 14px;
        color: rgba(0, 0, 0, 0.3);

        :global(path) {
            stroke-width: 2;
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.3);
        }
    }

    input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-family: inherit;
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: $color-black;
        width: 100%;

        &::placeholder {
            color: rgba(0, 0, 0, 0.3);
            font-weight: 400;
        }

        :global(.dark) & {
            color: $color-white;
            &::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }
        }
    }

    .cmdk-results {
        position: relative;
        z-index: 1;
        flex: 1;
        overflow-y: auto;
        padding: 1rem 0.5rem;
        min-height: 320px;

        // Hide scrollbar but keep functionality
        scrollbar-width: none;
        &::-webkit-scrollbar {
            display: none;
        }
    }

    .cmdk-section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(0, 0, 0, 0.25);
        padding: 1.25rem 0.75rem 0.5rem;

        &::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(0, 0, 0, 0.03);
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.2);
            &::after {
                background: rgba(255, 255, 255, 0.03);
            }
        }
    }

    .cmdk-item {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.875rem 1rem;
        margin: 0.25rem 0.5rem;
        border-radius: 6px; // Sharp
        cursor: pointer;
        opacity: 0; // Initial state for entrance animation
        transition:
            background 0.2s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, background;

        &.selected {
            background: rgba(0, 0, 0, 0.05);
            transform: scale(1.02); // Architectural pop

            &::before {
                content: "";
                position: absolute;
                left: -0.25rem;
                top: 50%;
                transform: translateY(-50%);
                height: 60%;
                width: 3px;
                background: $color-black;
                border-radius: 2px;
            }

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.1);

                &::before {
                    background: $color-white;
                }
            }

            .cmdk-item-title {
                color: rgba(0, 0, 0, 1);
                :global(.dark) & {
                    color: rgba(255, 255, 255, 1);
                }
            }

            .cmdk-item-icon {
                color: rgba(0, 0, 0, 0.8);
                :global(.dark) & {
                    color: rgba(255, 255, 255, 0.8);
                }
            }
        }

        &:active {
            scale: 0.995;
        }
    }

    .cmdk-item-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cmdk-item-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 6px;
        color: rgba(0, 0, 0, 0.25);
        transition: all 0.1s ease;

        :global(svg) {
            width: 1.125rem !important; // Fixed size
            height: 1.125rem !important; // Fixed size
            min-width: 1.125rem;
            min-height: 1.125rem;
            display: block;
            stroke-width: 1.5; // Thinner, crisper icons
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.25);
        }
    }

    .cmdk-item-title-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
    }

    .cmdk-item-title {
        font-size: 0.8125rem;
        font-weight: 500;
        color: rgba(0, 0, 0, 0.7);
        line-height: 1.2;
        transition: color 0.1s ease;
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.7);
        }
    }

    .cmdk-item-desc {
        font-size: 0.6875rem;
        color: rgba(0, 0, 0, 0.35);
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.3);
        }
    }

    .cmdk-item-shortcuts {
        display: flex;
        gap: 0.25rem;

        kbd {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.15rem 0.45rem;
            border-radius: 99px;
            font-family:
                ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
                "Liberation Mono", monospace;
            font-size: 0.6rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            background: rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.05);
            color: rgba(0, 0, 0, 0.35);
            line-height: 1;

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.05);
                border-color: rgba(255, 255, 255, 0.08);
                color: rgba(255, 255, 255, 0.35);
            }
        }
    }

    .cmdk-item.selected .cmdk-item-shortcuts kbd {
        background: rgba(0, 0, 0, 0.04);
        border-color: rgba(0, 0, 0, 0.08);
        color: rgba(0, 0, 0, 0.5);

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.12);
            color: rgba(255, 255, 255, 0.5);
        }
    }

    .cmdk-empty {
        padding: 3rem 1.5rem;
        text-align: center;
        font-size: 0.875rem;
        color: rgba(0, 0, 0, 0.4);
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.4);
        }
    }

    .cmdk-footer {
        position: relative;
        z-index: 1;
        padding: 0.75rem 1.25rem;
        background: transparent;
        display: flex;
        gap: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.1);

        :global(.dark) & {
            border-color: rgba(255, 255, 255, 0.1);
        }
    }

    .cmdk-footer-item {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.6rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(0, 0, 0, 0.3);

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.25);
        }

        kbd {
            font-family: inherit;
            padding: 0.1rem 0.3rem;
            background: rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 4px;
            color: rgba(0, 0, 0, 0.4);

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.05);
                border-color: rgba(255, 255, 255, 0.1);
                color: rgba(255, 255, 255, 0.4);
            }
        }
    }
</style>
