---

---

<div id="cmdk-overlay" class="cmdk-overlay" aria-hidden="true">
    <div id="cmdk-modal" class="cmdk-modal">
        <div class="cmdk-header">
            <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="cmdk-search-icon"
            >
                <path
                    d="M7.33333 12.6667C10.2789 12.6667 12.6667 10.2789 12.6667 7.33333C12.6667 4.38781 10.2789 2 7.33333 2C4.38781 2 2 4.38781 2 7.33333C2 10.2789 4.38781 12.6667 7.33333 12.6667Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                <path
                    d="M14 14L11.1 11.1"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
            <input
                type="text"
                id="cmdk-input"
                placeholder="What do you need?"
                autocomplete="off"
            />
        </div>
        <div id="cmdk-results" class="cmdk-results" role="listbox">
            <!-- Results injected here -->
        </div>
        <div class="cmdk-footer">
            <div class="cmdk-footer-item">
                <kbd>↑ ↓</kbd>
                <span>Navigate</span>
            </div>
            <div class="cmdk-footer-item">
                <kbd>↵</kbd>
                <span>Select</span>
            </div>
            <div class="cmdk-footer-item">
                <kbd>esc</kbd>
                <span>Close</span>
            </div>
        </div>
    </div>
</div>

<script>
    import { animate, stagger } from "motion";
    // @ts-ignore
    import { tinykeys } from "tinykeys";
    import { getCommands, type Command } from "@lib/commands";

    const overlay = document.getElementById("cmdk-overlay");
    const modal = document.getElementById("cmdk-modal");
    const input = document.getElementById("cmdk-input") as HTMLInputElement;
    const resultsContainer = document.getElementById("cmdk-results");

    let allCommands: Command[] = [];
    let filteredCommands: Command[] = [];
    let selectedIndex = 0;
    let isOpen = false;

    function init() {
        allCommands = getCommands();

        // Globals
        tinykeys(window, {
            "$mod+k": (e: KeyboardEvent) => {
                e.preventDefault();
                toggle(true);
            },
            Escape: () => {
                if (isOpen) toggle(false);
            },
        });

        // Overlay click
        overlay?.addEventListener("click", (e) => {
            if (e.target === overlay) toggle(false);
        });

        // Input search
        input?.addEventListener("input", (e) => {
            renderResults((e.target as HTMLInputElement).value);
        });

        // Input keys
        input?.addEventListener("keydown", (e) => {
            if (e.key === "ArrowDown") {
                e.preventDefault();
                updateSelection(1);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                updateSelection(-1);
            } else if (e.key === "Enter") {
                e.preventDefault();
                executeSelected();
            }
        });

        document.addEventListener("cmdk-close", () => toggle(false));
    }

    function toggle(open: boolean) {
        if (!overlay || !modal) return;
        isOpen = open;
        overlay.setAttribute("aria-hidden", String(!open));

        if (open) {
            overlay.style.display = "flex";
            animate(overlay as any, { opacity: [0, 1] }, { duration: 0.2 });
            animate(
                modal as any,
                { scale: [0.98, 1], y: [8, 0], opacity: [0, 1] },
                { duration: 0.3, easing: [0.23, 1, 0.32, 1] } as any,
            );
            input?.focus();
            input.value = "";
            renderResults("");
        } else {
            animate(
                overlay as any,
                { opacity: 0 },
                { duration: 0.2 },
            ).finished.then(() => {
                overlay.style.display = "none";
            });
            animate(
                modal as any,
                { scale: 0.98, y: 8, opacity: 0 },
                { duration: 0.2 },
            );
        }
    }

    function renderResults(query: string) {
        if (!resultsContainer) return;

        const q = query.toLowerCase();
        filteredCommands = allCommands.filter(
            (c) =>
                c.title.toLowerCase().includes(q) ||
                c.section.toLowerCase().includes(q) ||
                c.description?.toLowerCase().includes(q),
        );

        resultsContainer.innerHTML = "";
        selectedIndex = 0;

        if (filteredCommands.length === 0) {
            resultsContainer.innerHTML =
                '<div class="cmdk-empty">No results found. Try searching for "Home" or "Theme".</div>';
            return;
        }

        let currentSection = "";
        filteredCommands.forEach((cmd, idx) => {
            if (cmd.section !== currentSection) {
                currentSection = cmd.section;
                const sectionHeader = document.createElement("div");
                sectionHeader.className = "cmdk-section-header";
                sectionHeader.textContent = currentSection;
                resultsContainer.appendChild(sectionHeader);
            }

            const item = document.createElement("div");
            item.className = "cmdk-item";
            if (idx === 0) item.classList.add("selected");
            item.setAttribute("role", "option");
            item.dataset.index = idx.toString();

            // Content Left (Icon + Title/Desc)
            const left = document.createElement("div");
            left.className = "cmdk-item-left";

            if (cmd.icon) {
                const iconWrap = document.createElement("div");
                iconWrap.className = "cmdk-item-icon";
                iconWrap.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${cmd.icon}"/></svg>`;
                left.appendChild(iconWrap);
            }

            const titleWrap = document.createElement("div");
            titleWrap.className = "cmdk-item-title-wrap";
            titleWrap.innerHTML = `<span class="cmdk-item-title">${cmd.title}</span>`;
            if (cmd.description) {
                titleWrap.innerHTML += `<span class="cmdk-item-desc">${cmd.description}</span>`;
            }
            left.appendChild(titleWrap);
            item.appendChild(left);

            // Right (Shortcut)
            if (cmd.shortcut) {
                const shortcuts = document.createElement("div");
                shortcuts.className = "cmdk-item-shortcuts";
                const kbd = document.createElement("kbd");
                kbd.textContent = cmd.shortcut.join(" ");
                shortcuts.appendChild(kbd);
                item.appendChild(shortcuts);
            }

            item.addEventListener("mouseenter", () => setSelection(idx));
            item.addEventListener("click", () => executeSelected());

            resultsContainer.appendChild(item);
        });

        // Stagger entrance for results
        const items = resultsContainer.querySelectorAll(".cmdk-item");
        animate(Array.from(items) as any, { opacity: [0, 1], x: [-4, 0] }, {
            duration: 0.3,
            delay: stagger(0.04),
            easing: [0.23, 1, 0.32, 1],
        } as any);
    }

    function setSelection(index: number) {
        const items = resultsContainer?.querySelectorAll(".cmdk-item");
        items?.forEach((i) => i.classList.remove("selected"));
        selectedIndex = index;
        const selected = resultsContainer?.querySelector(
            `[data-index="${index}"]`,
        );
        selected?.classList.add("selected");
        selected?.scrollIntoView({ block: "nearest" });
    }

    function updateSelection(delta: number) {
        let next = selectedIndex + delta;
        if (next < 0) next = filteredCommands.length - 1;
        if (next >= filteredCommands.length) next = 0;
        setSelection(next);
    }

    function executeSelected() {
        const cmd = filteredCommands[selectedIndex];
        if (cmd) {
            cmd.action();
            toggle(false);
        }
    }

    // Handle view transitions
    document.addEventListener("astro:page-load", () => {
        init();
    });

    // Initial load
    init();
</script>

<style lang="scss">
    @use "../../styles/variables" as *;

    .cmdk-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px) saturate(120%);
        z-index: 10000;
        display: none; // Controlled by script
        justify-content: center;
        padding-top: 15vh;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .cmdk-modal {
        width: 100%;
        max-width: 640px;
        height: fit-content;
        max-height: 480px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px) saturate(180%);
        border-radius: 0.875rem;
        box-shadow:
            0 0 0 1px rgba(0, 0, 0, 0.05),
            0 32px 64px -16px rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        overflow: hidden;

        :global(.dark) & {
            background: rgba(28, 25, 23, 0.85);
            box-shadow:
                0 0 0 1px rgba(255, 255, 255, 0.1),
                0 32px 64px -16px rgba(0, 0, 0, 0.5);
        }
    }

    .cmdk-header {
        display: flex;
        align-items: center;
        padding: 1.25rem 1rem;
        gap: 0.75rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);

        :global(.dark) & {
            border-color: rgba(255, 255, 255, 0.05);
        }
    }

    .cmdk-search-icon {
        width: 14px;
        height: 14px;
        color: rgba(0, 0, 0, 0.3);

        :global(path) {
            stroke-width: 2;
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.3);
        }
    }

    input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 1rem;
        font-weight: 500;
        color: $color-black;
        width: 100%;

        &::placeholder {
            color: rgba(0, 0, 0, 0.3);
        }

        :global(.dark) & {
            color: $color-white;
            &::placeholder {
                color: rgba(255, 255, 255, 0.3);
            }
        }
    }

    .cmdk-results {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem 0.5rem;
        min-height: 280px;

        // Hide scrollbar but keep functionality
        scrollbar-width: none;
        &::-webkit-scrollbar {
            display: none;
        }
    }

    .cmdk-section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(0, 0, 0, 0.25);
        padding: 1.25rem 0.75rem 0.5rem;

        &::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(0, 0, 0, 0.03);
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.2);
            &::after {
                background: rgba(255, 255, 255, 0.03);
            }
        }
    }

    .cmdk-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        cursor: pointer;
        opacity: 0; // Initial state for entrance animation
        transition:
            background 0.1s ease,
            transform 0.1s ease;
        will-change: transform, background;

        &.selected {
            background: rgba(255, 255, 255, 0.5);
            box-shadow:
                0 0 0 1px rgba(0, 0, 0, 0.03),
                0 4px 12px -2px rgba(0, 0, 0, 0.05);
            transform: scale(1.002) translateY(-0.5px);

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.08);
                box-shadow:
                    0 0 0 1px rgba(255, 255, 255, 0.05),
                    0 4px 12px -2px rgba(0, 0, 0, 0.2);
            }

            .cmdk-item-title {
                color: rgba(0, 0, 0, 1);
                :global(.dark) & {
                    color: rgba(255, 255, 255, 1);
                }
            }

            .cmdk-item-icon {
                color: rgba(0, 0, 0, 0.8);
                :global(.dark) & {
                    color: rgba(255, 255, 255, 0.8);
                }
            }
        }

        &:active {
            scale: 0.995;
        }
    }

    .cmdk-item-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cmdk-item-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 6px;
        color: rgba(0, 0, 0, 0.25);
        transition: all 0.1s ease;

        :global(svg) {
            width: 0.875rem !important;
            height: 0.875rem !important;
            display: block;
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.25);
        }
    }

    .cmdk-item-title-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
    }

    .cmdk-item-title {
        font-size: 0.8125rem;
        font-weight: 500;
        color: rgba(0, 0, 0, 0.7);
        line-height: 1.2;
        transition: color 0.1s ease;
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.7);
        }
    }

    .cmdk-item-desc {
        font-size: 0.6875rem;
        color: rgba(0, 0, 0, 0.35);
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.3);
        }
    }

    .cmdk-item-shortcuts {
        display: flex;
        gap: 0.25rem;

        kbd {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.15rem 0.45rem;
            border-radius: 99px;
            font-family:
                ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
                "Liberation Mono", monospace;
            font-size: 0.6rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            background: rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.05);
            color: rgba(0, 0, 0, 0.35);
            line-height: 1;

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.05);
                border-color: rgba(255, 255, 255, 0.08);
                color: rgba(255, 255, 255, 0.35);
            }
        }
    }

    .cmdk-item.selected .cmdk-item-shortcuts kbd {
        background: rgba(0, 0, 0, 0.04);
        border-color: rgba(0, 0, 0, 0.08);
        color: rgba(0, 0, 0, 0.5);

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.12);
            color: rgba(255, 255, 255, 0.5);
        }
    }

    .cmdk-empty {
        padding: 3rem 1.5rem;
        text-align: center;
        font-size: 0.875rem;
        color: rgba(0, 0, 0, 0.4);
        :global(.dark) & {
            color: rgba(255, 255, 255, 0.4);
        }
    }

    .cmdk-footer {
        padding: 0.625rem 1rem;
        background: rgba(0, 0, 0, 0.01);
        display: flex;
        gap: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.03);

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.005);
            border-color: rgba(255, 255, 255, 0.03);
        }
    }

    .cmdk-footer-item {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.6rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(0, 0, 0, 0.3);

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.25);
        }

        kbd {
            font-family: inherit;
            padding: 0.1rem 0.3rem;
            background: rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 4px;
            color: rgba(0, 0, 0, 0.4);

            :global(.dark) & {
                background: rgba(255, 255, 255, 0.05);
                border-color: rgba(255, 255, 255, 0.1);
                color: rgba(255, 255, 255, 0.4);
            }
        }
    }
</style>
