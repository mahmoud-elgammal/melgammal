---
import InteractiveMedia from "./InteractiveMedia.astro";
import CustomVideoPlayer from "./CustomVideoPlayer.astro";

interface MediaItem {
    type?: "image" | "ambient-video" | "cinematic-video";
    src: string;
    alt?: string;
    poster?: string;
    caption?: string;
}

interface Props {
    items: MediaItem[];
}

const { items } = Astro.props;
// Unique ID for GSAP hooks/counters
const swiperId = `swiper-${Math.random().toString(36).substring(2, 9)}`;

// Pre-filter the gallery for the interactive lightbox view
// Cinematic videos are excluded from the lightbox view
const lightboxGallery = items
    .filter((i) => i.type !== "cinematic-video")
    .map((i) => ({
        src: i.src,
        type: i.type || "image",
    }));

const galleryJsonString = JSON.stringify(lightboxGallery);
---

<div class="media-swiper-container" id={swiperId}>
    <!-- Upper Header: Counter and Navigation Hint -->
    <div class="swiper-header">
        <div class="swiper-counter">
            [<span class="current-slide">01</span>/<span class="total-slides"
                >{String(items.length).padStart(2, "0")}</span
            >]
        </div>
        <div class="swiper-hint">DRAG // SCROLL</div>
    </div>

    <!-- The Native Scroll Track -->
    <div class="swiper-track">
        {
            items.map((item, index) => {
                const isCinematic = item.type === "cinematic-video";

                // For Interactive Media, we need its specific index within the *lightbox gallery*, not the raw items array
                let lightboxIndex = -1;
                if (!isCinematic) {
                    lightboxIndex = lightboxGallery.findIndex(
                        (g) => g.src === item.src,
                    );
                }

                return (
                    <figure class="swiper-slide" data-index={index}>
                        <div class="media-wrapper">
                            {isCinematic ? (
                                <CustomVideoPlayer
                                    src={item.src}
                                    poster={item.poster}
                                    autoPlay={false}
                                />
                            ) : (
                                <InteractiveMedia
                                    type={
                                        item.type as "image" | "ambient-video"
                                    }
                                    src={item.src}
                                    poster={item.poster}
                                    alt={
                                        item.alt || `Gallery Media ${index + 1}`
                                    }
                                    galleryJson={galleryJsonString}
                                    galleryIndex={lightboxIndex}
                                />
                            )}
                        </div>
                        {item.caption && (
                            <figcaption class="slide-caption">
                                {item.caption}
                            </figcaption>
                        )}
                    </figure>
                );
            })
        }
    </div>

    <!-- Brutalist Track Progress Indicator -->
    <div class="track-progress">
        <div class="track-fill"></div>
    </div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;

    .media-swiper-container {
        position: relative;
        width: 100%;
        margin: 6rem 0; /* Space out from surrounding editorial text */
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* ── Header ── */
    .swiper-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding: 0 1rem;
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: $color-black;
        opacity: 0.4;
        :global(.dark) & {
            color: $color-white;
        }
    }

    .swiper-counter {
        font-size: 1rem;
        letter-spacing: 0.2em;
        font-weight: 900;
    }

    .swiper-hint {
        font-size: 0.65rem;
    }

    /* ── The Track (Native Scroll Snapping) ── */
    .swiper-track {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory; /* The core magic */
        overscroll-behavior-x: contain;
        gap: 2rem; /* Gap between slides */
        padding: 0 1rem; /* Padding at ends to see snap boundaries */

        /* Hide native scrollbar for brutalist look */
        scrollbar-width: none;
        -ms-overflow-style: none;
        &::-webkit-scrollbar {
            display: none;
        }
    }

    .swiper-slide {
        flex: 0 0 calc(100% - 2rem); /* Take up full width minus padding */
        margin: 0;
        scroll-snap-align: center;
        scroll-snap-stop: always; /* Ensure they don't skip slides on fast swipes */
        display: flex;
        flex-direction: column;
        gap: 1rem;

        @media (min-width: $screen-md) {
            flex: 0 0 85%; /* On larger screens, peek the next slide to invite scrolling */
        }
        @media (min-width: $screen-xl) {
            flex: 0 0 70%; /* Peek even more on huge screens */
        }
    }

    .media-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9; /* Enforce strictly cinematic aspect ratios */
        background: rgba($color-black, 0.05);
        border-radius: 1rem;
        overflow: hidden;
        :global(.dark) & {
            background: rgba($color-white, 0.05);
        }

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            /* Add a subtle drag hint cursor */
            cursor: grab;
            &:active {
                cursor: grabbing;
            }
        }
    }

    .slide-caption {
        font-family: ui-monospace, monospace;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        font-weight: 500;
        opacity: 0.5;
        text-align: right;
    }

    /* ── Track Progress ── */
    .track-progress {
        position: relative;
        margin: 0 1rem;
        height: 1px;
        background: rgba($color-black, 0.1);
        :global(.dark) & {
            background: rgba($color-white, 0.1);
        }
    }

    .track-fill {
        height: 100%;
        width: 0%;
        background: $color-black;
        transition: width 0.15s linear;
        :global(.dark) & {
            background: $color-white;
        }
    }
</style>

<script>
    import { registerAnimation } from "@lib/animation";

    document.addEventListener("astro:page-load", () => {
        registerAnimation("media-swiper", (_gsap, signal) => {
            const swipers = document.querySelectorAll(
                ".media-swiper-container",
            );

            swipers.forEach((swiper) => {
                const track = swiper.querySelector(
                    ".swiper-track",
                ) as HTMLElement;
                const progressFill = swiper.querySelector(
                    ".track-fill",
                ) as HTMLElement;
                const currentLabel = swiper.querySelector(
                    ".current-slide",
                ) as HTMLElement;
                const slides = track.querySelectorAll(".swiper-slide");

                if (!track || slides.length === 0) return;

                const total = slides.length;
                let maxScroll = track.scrollWidth - track.clientWidth;
                let slideWidth =
                    (slides[0] as HTMLElement).offsetWidth || 1;

                window.addEventListener(
                    "resize",
                    () => {
                        maxScroll = track.scrollWidth - track.clientWidth;
                        slideWidth =
                            (slides[0] as HTMLElement).offsetWidth || 1;
                    },
                    { passive: true, signal },
                );

                let pendingScrollRaf = 0;
                const updateScroll = () => {
                    let progress = 0;
                    if (maxScroll > 0) {
                        progress = track.scrollLeft / maxScroll;
                    }
                    if (progressFill) {
                        progressFill.style.width = `${progress * 100}%`;
                    }
                    let activeIdx = Math.round(
                        track.scrollLeft / slideWidth,
                    );
                    activeIdx = Math.max(0, Math.min(activeIdx, total - 1));
                    if (currentLabel) {
                        currentLabel.innerText = String(
                            activeIdx + 1,
                        ).padStart(2, "0");
                    }
                };

                track.addEventListener(
                    "scroll",
                    () => {
                        if (pendingScrollRaf)
                            cancelAnimationFrame(pendingScrollRaf);
                        pendingScrollRaf = requestAnimationFrame(() => {
                            pendingScrollRaf = 0;
                            updateScroll();
                        });
                    },
                    { passive: true, signal },
                );

                // ── Desktop Drag-to-Scroll Logic ──
                let isDown = false;
                let startX = 0;
                let scrollLeft = 0;

                track.addEventListener(
                    "mousedown",
                    (e) => {
                        isDown = true;
                        track.style.cursor = "grabbing";
                        track.style.scrollSnapType = "none";
                        track.style.scrollBehavior = "auto";
                        startX = e.pageX - track.offsetLeft;
                        scrollLeft = track.scrollLeft;
                    },
                    { signal },
                );

                track.addEventListener(
                    "mouseleave",
                    () => {
                        isDown = false;
                        track.style.cursor = "";
                        track.style.scrollSnapType = "x mandatory";
                    },
                    { signal },
                );

                track.addEventListener(
                    "mouseup",
                    () => {
                        isDown = false;
                        track.style.cursor = "";
                        track.style.scrollSnapType = "x mandatory";
                    },
                    { signal },
                );

                track.addEventListener(
                    "mousemove",
                    (e) => {
                        if (!isDown) return;
                        e.preventDefault();
                        const x = e.pageX - track.offsetLeft;
                        const walk = (x - startX) * 2;
                        track.scrollLeft = scrollLeft - walk;
                    },
                    { signal },
                );

                signal.addEventListener("abort", () => {
                    if (pendingScrollRaf)
                        cancelAnimationFrame(pendingScrollRaf);
                });

                updateScroll();
            });
        });
    });
</script>
