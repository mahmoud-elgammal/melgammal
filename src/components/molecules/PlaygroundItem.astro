---
interface Props {
    title: string;
    description: string;
    tags?: string[];
    demoURL?: string;
    repoURL?: string;
    date: Date;
    index: number;
}

const { title, description, tags, demoURL, repoURL, date, index } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
});

const paddedIndex = String(index + 1).padStart(2, "0");
---

<div class="playground-item" data-index={index}>
    <!-- Seam top -->
    <div class="seam-line"></div>

    <div class="item-inner">
        <!-- Index -->
        <div class="item-num" aria-hidden="true">{paddedIndex}</div>

        <!-- Content -->
        <div class="item-content">
            <!-- Meta row -->
            <div class="item-meta">
                <span class="item-date">{formattedDate}</span>
                {tags?.map((tag) => <span class="tag">{tag}</span>)}
            </div>

            <!-- Title -->
            <h3 class="item-title">
                {title}
                <span class="title-arrow" aria-hidden="true">↗</span>
            </h3>

            <!-- Description — always visible -->
            <p class="item-description">{description}</p>
        </div>

        <!-- Links -->
        <div class="item-links">
            {
                demoURL && (
                    <a
                        href={demoURL}
                        target="_blank"
                        rel="noopener"
                        class="item-link"
                    >
                        <span>DEMO</span>
                        <span class="link-arrow">↗</span>
                    </a>
                )
            }
            {
                repoURL && (
                    <a
                        href={repoURL}
                        target="_blank"
                        rel="noopener"
                        class="item-link"
                    >
                        <span>SOURCE</span>
                        <span class="link-arrow">↗</span>
                    </a>
                )
            }
        </div>
    </div>

    <!-- Hover fill -->
    <div class="hover-fill" aria-hidden="true"></div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    /* ── Item shell ── */
    .playground-item {
        position: relative;
        cursor: pointer;
        overflow: hidden;

        &:last-child::after {
            content: "";
            display: block;
            height: 1px;
            background: rgba($color-black, 0.08);
            :global(.dark) & {
                background: rgba($color-white, 0.08);
            }
        }
    }

    /* ── Seam line ── */
    .seam-line {
        height: 1px;
        background: rgba($color-black, 0.08);
        position: relative;
        overflow: hidden;
        :global(.dark) & {
            background: rgba($color-white, 0.08);
        }

        &::after {
            content: "";
            position: absolute;
            inset: 0;
            background: $color-black;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            :global(.dark) & {
                background: $color-white;
            }
        }
    }

    .playground-item:hover .seam-line::after {
        transform: scaleX(1);
    }

    /* ── Hover fill (background sweep) ── */
    .hover-fill {
        position: absolute;
        inset: 0;
        background: $color-black;
        transform: scaleY(0);
        transform-origin: bottom;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 0;
        pointer-events: none;
        :global(.dark) & {
            background: $color-white;
        }
    }

    .playground-item:hover .hover-fill {
        transform: scaleY(1);
    }

    /* ── Inner grid ── */
    .item-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 5rem 1fr auto;
        gap: 2.5rem;
        padding: 2.75rem 0;
        align-items: start;
        transition: padding 0.5s cubic-bezier(0.16, 1, 0.3, 1);

        @media (max-width: $screen-md) {
            grid-template-columns: 3.5rem 1fr;
            gap: 1.5rem;
            .item-links {
                display: none;
            }
        }
    }

    .playground-item:hover .item-inner {
        padding: 2.75rem 1rem;
    }

    /* ── Index number ── */
    .item-num {
        font-family: ui-monospace, monospace;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 0.1em;
        padding-top: 0.5rem;
        transition: all 0.4s ease;
        color: rgba($color-black, 0.2);
        :global(.dark) & {
            color: rgba($color-white, 0.2);
        }
    }

    .playground-item:hover .item-num {
        color: rgba($color-white, 0.4);
        :global(.dark) & {
            color: rgba($color-black, 0.4);
        }
    }

    /* ── Content ── */
    .item-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .item-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .item-date {
        font-family: ui-monospace, monospace;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        opacity: 0.35;
        transition: opacity 0.3s ease;
    }

    .tag {
        font-family: ui-monospace, monospace;
        font-size: 0.55rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        padding: 0.2rem 0.5rem;
        border: 1px solid rgba($color-black, 0.12);
        opacity: 0.5;
        transition: all 0.3s ease;
        :global(.dark) & {
            border-color: rgba($color-white, 0.12);
        }
    }

    .playground-item:hover .item-date,
    .playground-item:hover .tag {
        opacity: 0.5;
        color: $color-white;
        border-color: rgba($color-white, 0.25);
        :global(.dark) & {
            color: $color-black;
            border-color: rgba($color-black, 0.25);
        }
    }

    /* ── Title ── */
    .item-title {
        font-size: clamp(1.75rem, 3.5vw, 2.75rem);
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1;
        margin: 0;
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        color: $color-black;
        transition:
            color 0.4s ease,
            letter-spacing 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        :global(.dark) & {
            color: $color-white;
        }
    }

    .playground-item:hover .item-title {
        color: $color-white;
        letter-spacing: -0.02em;
        :global(.dark) & {
            color: $color-black;
        }
    }

    .title-arrow {
        font-size: 1.25rem;
        font-weight: 300;
        opacity: 0;
        transform: translate(-6px, 2px);
        display: inline-block;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .playground-item:hover .title-arrow {
        opacity: 0.6;
        transform: translate(0, 0);
    }

    /* ── Description ── */
    .item-description {
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 52ch;
        margin: 0;
        color: rgba($color-black, 0.45);
        transition: color 0.4s ease;
        :global(.dark) & {
            color: rgba($color-white, 0.45);
        }
    }

    .playground-item:hover .item-description {
        color: rgba($color-white, 0.65);
        :global(.dark) & {
            color: rgba($color-black, 0.65);
        }
    }

    /* ── Links ── */
    .item-links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-top: 0.4rem;
        align-items: flex-end;
    }

    .item-link {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
        font-family: ui-monospace, monospace;
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: rgba($color-black, 0.3);
        transition: all 0.3s ease;
        :global(.dark) & {
            color: rgba($color-white, 0.3);
        }

        .link-arrow {
            transition: transform 0.3s ease;
        }

        &:hover {
            color: $color-black;
            .link-arrow {
                transform: translate(2px, -2px);
            }
            :global(.dark) & {
                color: $color-white;
            }
        }
    }

    .playground-item:hover .item-link {
        color: rgba($color-white, 0.5);
        :global(.dark) & {
            color: rgba($color-black, 0.5);
        }

        &:hover {
            color: $color-white;
            :global(.dark) & {
                color: $color-black;
            }
        }
    }
</style>
