---
interface Props {
    title: string;
    description: string;
    tags?: string[];
    demoURL?: string;
    repoURL?: string;
    date: Date;
    index: number;
}

const { title, description, tags, demoURL, repoURL, date, index } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
});

const paddedIndex = String(index + 1).padStart(2, "0");

// Unique ID for GSAP scoping
const id = `playground-${index}`;

// Assign a brand color purely via math on index for variety (since playground items don't have predefined colors)
const colors = ["#10b981", "#3b82f6", "#8b5cf6", "#f43f5e", "#f59e0b"];
const itemColor = colors[index % colors.length];
---

<div class="playground-card" id={id} style={`--item-color: ${itemColor}`}>
    <!-- Colossal Background Index Watermark -->
    <div class="watermark-index">{paddedIndex}</div>

    <!-- Architectural Base -->
    <div class="card-visuals">
        <div class="parallax-grid technical-base"></div>
        <div class="brand-reveal-layer"></div>
    </div>

    <!-- Content Structure -->
    <div class="content-wrapper">
        <div class="meta-header">
            <span class="date">{formattedDate}</span>
            <div class="tags">
                {tags?.map((tag) => <span class="tag">{tag}</span>)}
            </div>
        </div>

        <div class="core-info">
            <!-- Kinetic Typography Title -->
            <div class="title-container">
                <h3 class="static-title">{title}</h3>
                <div class="kinetic-marquee">
                    <div class="marquee-track">
                        <span>{title.toUpperCase()} // </span>
                        <span>{title.toUpperCase()} // </span>
                        <span>{title.toUpperCase()} // </span>
                        <span>{title.toUpperCase()} // </span>
                    </div>
                </div>
            </div>

            <!-- Description that vanishes on hover -->
            <p class="description">{description}</p>
        </div>

        <!-- Heavy Structural Action Buttons (Slide in on hover) -->
        <div class="action-dock">
            {
                demoURL && (
                    <a
                        href={demoURL}
                        target="_blank"
                        rel="noopener"
                        class="dock-btn primary"
                        aria-label={`View Live Demo of ${title}`}
                    >
                        <span class="btn-text">LIVE DEMO</span>
                        <svg
                            class="btn-icon"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                )
            }
            {
                repoURL && (
                    <a
                        href={repoURL}
                        target="_blank"
                        rel="noopener"
                        class="dock-btn secondary"
                        aria-label={`View Source Code of ${title}`}
                    >
                        <span class="btn-text">SOURCE</span>
                        <svg
                            class="btn-icon github-icon"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                        </svg>
                    </a>
                )
            }
        </div>
    </div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .playground-card {
        position: relative;
        width: 100%;
        border-radius: 1.5rem;
        background: $color-white;
        border: 1px solid rgba($color-black, 0.05);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
            box-shadow 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        cursor: crosshair;

        :global(.dark) & {
            background: rgba($color-white, 0.03);
            border-color: rgba($color-white, 0.1);
        }

        &:hover {
            transform: translateY(-4px);
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.1);

            .brand-reveal-layer {
                clip-path: circle(150% at 50% 50%);
            }

            .static-title {
                opacity: 0;
                transform: translateY(-20px);
            }

            .kinetic-marquee {
                opacity: 1;
                transform: translateY(0);
            }

            .marquee-track {
                animation: scrollText 12s linear infinite;
            }

            .description {
                opacity: 0;
                transform: translateX(20px);
            }

            .watermark-index {
                opacity: 0.15;
                transform: translate(20px, -20px) scale(1.1);
            }

            .action-dock {
                opacity: 1;
                pointer-events: auto;
                transform: translateY(0);
            }
        }
    }

    /* ── Architectural Background ── */
    .card-visuals {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .technical-base {
        position: absolute;
        inset: -50%;
        background-size: 30px 30px;
        background-image:
            linear-gradient(to right, rgba(0, 0, 0, 0.03) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
        opacity: 0.5;

        :global(.dark) & {
            background-image:
                linear-gradient(
                    to right,
                    rgba(255, 255, 255, 0.03) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    to bottom,
                    rgba(255, 255, 255, 0.03) 1px,
                    transparent 1px
                );
        }
    }

    .brand-reveal-layer {
        position: absolute;
        inset: 0;
        background: var(--item-color);
        clip-path: circle(0% at 50% 100%);
        transition: clip-path 0.7s cubic-bezier(0.7, 0, 0.3, 1);
        z-index: 1;
    }

    .watermark-index {
        position: absolute;
        top: -1rem;
        right: -1rem;
        font-family: ui-monospace, monospace;
        font-size: 14rem;
        font-weight: 900;
        line-height: 1;
        color: var(--item-color);
        opacity: 0.03;
        z-index: 0;
        pointer-events: none;
        transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }

    /* ── Content ── */
    .content-wrapper {
        position: relative;
        z-index: 2;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        height: 100%;
        min-height: 320px;

        @media (max-width: $screen-sm) {
            padding: 1.5rem;
            min-height: 280px;
        }
    }

    .meta-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        transition: color 0.4s ease;

        .playground-card:hover & {
            color: $color-white;
        }
    }

    .date {
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        opacity: 0.5;
    }

    .tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .tag {
        font-family: ui-monospace, monospace;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        padding: 0.25rem 0.6rem;
        border: 1px solid currentColor;
        border-radius: 99px;
        opacity: 0.6;
    }

    .core-info {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* ── Title Typography ── */
    .title-container {
        position: relative;
        min-height: 3rem;
    }

    .static-title {
        font-size: clamp(2rem, 4vw, 2.5rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0;
        color: $color-black;
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);

        :global(.dark) & {
            color: $color-white;
        }
    }

    .kinetic-marquee {
        position: absolute;
        inset: 0;
        left: -2.5rem; /* Extend fully to the padding edge */
        width: calc(100% + 5rem);
        display: flex;
        align-items: center;
        overflow: hidden;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        mask-image: linear-gradient(
            to right,
            transparent,
            black 10%,
            black 90%,
            transparent
        );
    }

    .marquee-track {
        display: flex;
        white-space: nowrap;
        color: $color-white;
    }

    .marquee-track span {
        font-size: 4rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        line-height: 1;
        padding-right: 2rem;
        /* Text stroke effect for the aggressive marquee */
        color: transparent;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.5);

        &:hover {
            color: $color-white;
            -webkit-text-stroke: 0px;
        }
    }

    @keyframes scrollText {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(
                -50%
            ); /* Scroll halfway (since we duplicated text) */
        }
    }

    .description {
        font-size: 1rem;
        line-height: 1.6;
        color: rgba($color-black, 0.6);
        max-width: 45ch;
        margin: 0;
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);

        :global(.dark) & {
            color: rgba($color-white, 0.6);
        }
    }

    /* ── Heavy Dock Buttons ── */
    .action-dock {
        position: absolute;
        bottom: 2.5rem;
        left: 2.5rem;
        right: 2.5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        opacity: 0;
        pointer-events: none;
        transform: translateY(30px);
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);

        @media (max-width: $screen-sm) {
            bottom: 1.5rem;
            left: 1.5rem;
            right: 1.5rem;
            grid-template-columns: 1fr;
        }
    }

    .dock-btn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-radius: 0.75rem;
        text-decoration: none;
        transition: all 0.3s ease;

        &.primary {
            background: $color-white;
            color: var(--item-color);

            &:hover {
                transform: scale(1.02);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            }
        }

        &.secondary {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            color: $color-white;
            border: 1px solid rgba(255, 255, 255, 0.2);

            &:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: scale(1.02);
            }
        }

        .btn-text {
            font-family: ui-monospace, monospace;
            font-size: 0.875rem;
            font-weight: 800;
            letter-spacing: 0.1em;
        }

        .btn-icon {
            transition: transform 0.3s ease;
        }

        &:hover .btn-icon:not(.github-icon) {
            transform: translate(4px, -4px);
        }
    }
</style>
