---
import { type CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";

type Props = {
    post: CollectionEntry<"blog">;
    loading?: "eager" | "lazy";
    fetchpriority?: "high" | "low" | "auto";
};

const { post, loading = "lazy", fetchpriority = "auto" } = Astro.props;
const { title, date, image, color } = post.data;

// Default color if none provided
const brandColor = color || "#4F46E5";
const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
---

<div class="post-card">
    <a
        href={`/blog/${post.slug}`}
        class="card-link"
        aria-label={`Read ${title}`}
    >
        <div class="visual-hero" style={`--brand-bg: ${brandColor}`}>
            <div class="noise-overlay"></div>
            <div class="image-container">
                {
                    image && (
                        <Picture
                            src={image}
                            alt={title}
                            formats={["avif", "webp"]}
                            fallbackFormat="jpg"
                            widths={[300, 600]}
                            sizes="(max-width: 768px) 90vw, 400px"
                            quality={60}
                            loading={loading}
                            fetchpriority={fetchpriority}
                            class="post-image"
                        />
                    )
                }
            </div>
        </div>

        <div class="card-info">
            <h3 class="post-title">{title}</h3>
            <p class="post-date">{formattedDate}</p>
        </div>
    </a>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .post-card {
        width: 100%;
        transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);

        &:hover {
            transform: translateY(-8px);

            .visual-hero {
                box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15);
            }

            .post-image {
                transform: scale(1.03);
            }

            .post-title {
                color: $color-black;
            }
            :global(.dark) & .post-title {
                color: $color-white;
            }
        }
    }

    .card-link {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* ── Visual Section ── */
    .visual-hero {
        position: relative;
        background: var(--brand-bg);
        border-radius: 1.25rem; // Slightly more rounded
        aspect-ratio: 16 / 9; // Modern widescreen
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
        transition: all 0.5s ease;
    }

    .noise-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(0, 0, 0, 0.1) 0%,
            rgba(255, 255, 255, 0.05) 100%
        );
        z-index: 1;
    }

    .image-container {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .post-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }

    /* ── Info Section ── */
    .card-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding-left: 0.25rem;
    }

    .post-title {
        font-size: 1rem; // Smaller title for smaller cards
        font-weight: 700;
        margin: 0;
        color: rgba(0, 0, 0, 0.85);
        line-height: 1.3;
        letter-spacing: -0.01em;
        transition: color 0.3s ease;

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.85);
        }
    }

    .post-date {
        font-size: 0.8125rem;
        color: rgba(0, 0, 0, 0.4);
        margin: 0;
        font-weight: 500;

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.35);
        }
    }
</style>
