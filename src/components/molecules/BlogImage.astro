---
import { Picture } from "astro:assets";

import type { ImageMetadata } from "astro";

interface Props {
    src: ImageMetadata | string;
    alt: string;
    caption?: string;
    size?: "sm" | "md" | "lg" | "xl";
}

const { src, alt, caption, size = "md" } = Astro.props;
---

<figure class:list={["blog-image", size]} data-gallery-image>
    <div class="image-inner">
        {
            typeof src === "string" ? (
                <Picture
                    src={src}
                    alt={alt}
                    inferSize={true}
                    formats={["avif", "webp"]}
                    fallbackFormat="jpg"
                    widths={[400, 800, 1200]}
                    sizes="(max-width: 800px) 100vw, 800px"
                />
            ) : (
                <Picture
                    src={src}
                    alt={alt}
                    formats={["avif", "webp"]}
                    fallbackFormat="jpg"
                    widths={[400, 800, 1200]}
                    sizes="(max-width: 800px) 100vw, 800px"
                />
            )
        }
        <div class="corner-accents">
            <span></span><span></span><span></span><span></span>
        </div>
    </div>
    {caption && <figcaption class="image-caption">{caption}</figcaption>}
</figure>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .blog-image {
        margin: 4rem auto;
        width: 100%;

        &.sm {
            max-width: 600px;
        }
        &.md {
            max-width: 800px;
        }
        &.lg {
            max-width: 1000px;
        }
        &.xl {
            max-width: 1200px;
        }
    }

    .image-inner {
        position: relative;
        width: 100%;
        border-radius: 0.5rem;
        overflow: hidden;
        background: rgba($color-black, 0.05);
        box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.1);
        cursor: pointer;

        :global(.dark) & {
            background: rgba($color-white, 0.05);
            box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.3);
        }

        img {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        &:hover img {
            transform: scale(1.03);
        }
    }

    .corner-accents {
        position: absolute;
        inset: 0.75rem;
        pointer-events: none;
        z-index: 2;

        span {
            position: absolute;
            width: 1rem;
            height: 1rem;
            border: 1px solid rgba($color-black, 0.2);

            :global(.dark) & {
                border-color: rgba($color-white, 0.2);
            }

            &:nth-child(1) {
                top: 0;
                left: 0;
                border-right: 0;
                border-bottom: 0;
            }
            &:nth-child(2) {
                top: 0;
                right: 0;
                border-left: 0;
                border-bottom: 0;
            }
            &:nth-child(3) {
                bottom: 0;
                left: 0;
                border-right: 0;
                border-top: 0;
            }
            &:nth-child(4) {
                bottom: 0;
                right: 0;
                border-left: 0;
                border-top: 0;
            }
        }
    }

    .image-caption {
        margin-top: 1.5rem;
        font-family: ui-monospace, monospace;
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.4;
        text-align: center;
    }
</style>
