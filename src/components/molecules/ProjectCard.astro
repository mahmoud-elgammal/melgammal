---
import type { CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";

type Props = {
    project: CollectionEntry<"projects">;
    loading?: "eager" | "lazy";
    fetchpriority?: "high" | "low" | "auto";
};

const { project, loading = "lazy", fetchpriority = "auto" } = Astro.props;
const { title, tags, imageWeb, imageMobile, color } = project.data;

// Default color if none provided
const brandColor = color || "#8B5CF6";
const subtitle = tags && tags.length > 0 ? tags[0] : "Project";
---

<div class="visual-card" style={`--brand-bg: ${brandColor}`}>
    <a
        href={`/projects/${project.slug}`}
        class="card-link"
        aria-label={`View ${title}`}
    >
        <div class="visual-hero">
            <!-- Architectural Background -->
            <div class="base-layer"></div>
            <div class="technical-grid parallax-grid"></div>

            <!-- Expanding Brand Hit -->
            <div class="brand-reveal-layer"></div>

            <!-- Kinetic Marquee -->
            <div class="internal-marquee parallax-marquee">
                <div class="marquee-track">
                    <span>{title.toUpperCase()} //</span>
                    <span>{title.toUpperCase()} //</span>
                    <span>{title.toUpperCase()} //</span>
                    <span>{title.toUpperCase()} //</span>
                </div>
            </div>

            <!-- FX Layers -->
            <div class="noise-overlay"></div>

            <!-- Dynamic Lighting 3D Effect -->
            <div class="glare-container">
                <div class="glare"></div>
            </div>

            <div class="mockup-container">
                {
                    imageWeb && (
                        <div class="web-mockup">
                            <Picture
                                src={imageWeb}
                                alt={`${title} Web`}
                                formats={["avif", "webp"]}
                                fallbackFormat="jpg"
                                widths={[300, 600, 900]}
                                sizes="(max-width: 768px) 90vw, (max-width: 1200px) 45vw, 600px"
                                quality={60}
                                loading={loading}
                                fetchpriority={fetchpriority}
                            />
                        </div>
                    )
                }
                {
                    imageMobile && (
                        <div class="mobile-mockup">
                            <div class="iphone-frame">
                                <Picture
                                    src={imageMobile}
                                    alt={`${title} Mobile`}
                                    formats={["avif", "webp"]}
                                    fallbackFormat="jpg"
                                    widths={[200, 400]}
                                    sizes="(max-width: 768px) 25vw, 150px"
                                    quality={60}
                                    loading={loading}
                                    fetchpriority={fetchpriority}
                                />
                            </div>
                        </div>
                    )
                }
            </div>
        </div>

        <div class="card-info">
            <h3 class="project-name">
                <span class="project-title-text">{title}</span>
                <span class="project-arrow">
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path
                            d="M5 12h14M12 5l7 7-7 7"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </span>
            </h3>
            <p class="project-subtitle">{subtitle}</p>
        </div>
    </a>

    <!-- Precision Target Cursor (Moved outside hero to avoid clipping) -->
</div>

<style lang="scss">
    @use "../../styles/variables" as *;

    .visual-card {
        width: 100%;
        position: relative;
        transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);

        @media (min-width: 1024px) {
            cursor: none;
        }

        &:hover {
            .visual-hero {
                box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15);
            }

            .project-name {
                color: $color-black;
                transform: translateX(4px);
            }
            :global(.dark) & .project-name {
                color: $color-white;
            }

            .project-arrow {
                opacity: 1;
                transform: translateX(0);
                color: var(--brand-bg);
            }
        }
    }

    .card-link {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* ── Visual Section ── */
    .visual-hero {
        position: relative;
        background: transparent;
        border-radius: 1rem;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
        will-change: transform;

        @media (min-width: 768px) {
            border-radius: 2.25rem;
            padding: 1.5rem;
        }

        @media (min-width: 1024px) {
            padding: 3.5rem;
        }
    }

    .base-layer {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.03);
        z-index: 0;

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.03);
        }
    }

    .brand-reveal-layer {
        position: absolute;
        inset: 0;
        background: var(--brand-bg);
        z-index: 1;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.6s cubic-bezier(0.23, 1, 0.32, 1);

        @media (hover: none) {
            display: none;
        }
    }

    .visual-card:hover .brand-reveal-layer {
        opacity: 1;
    }

    .technical-grid {
        position: absolute;
        inset: -20%;
        background-image:
            linear-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
        background-size: 30px 30px;
        z-index: 2;
        opacity: 0.6;

        :global(.dark) & {
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                linear-gradient(
                    90deg,
                    rgba(255, 255, 255, 0.05) 1px,
                    transparent 1px
                );
        }
    }

    .internal-marquee {
        position: absolute;
        top: 50%;
        left: -50%;
        width: 200%;
        transform: translateY(-50%) rotate(-10deg);
        z-index: 3;
        font-family: $font-display;
        font-size: clamp(1.5rem, 6vw, 2.5rem);
        font-weight: 400;
        letter-spacing: 0.05em;
        white-space: nowrap;
        opacity: 0.04;
        pointer-events: none;
        user-select: none;
        mix-blend-mode: overlay;

        @media (min-width: 768px) {
            font-size: clamp(4rem, 10vw, 8rem);
        }

        :global(.dark) & {
            color: #fff;
            opacity: 0.08;
        }

        .marquee-track {
            display: inline-block;
            animation: marquee-scroll 30s linear infinite;

            @media (hover: none) {
                animation-play-state: paused;
            }
        }
    }

    @keyframes marquee-scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .noise-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(0, 0, 0, 0.1) 0%,
            rgba(255, 255, 255, 0.05) 100%
        );
        z-index: 4;
        pointer-events: none;
    }

    .glare-container {
        position: absolute;
        inset: 0;
        overflow: hidden;
        border-radius: 1rem;
        pointer-events: none;
        z-index: 5;
        opacity: 0;
        transition: opacity 0.4s ease;

        @media (min-width: 768px) {
            border-radius: 2.25rem;
        }

        @media (hover: none) {
            display: none;
        }
    }

    .visual-card:hover .glare-container {
        opacity: 1;
    }

    .glare {
        position: absolute;
        width: 150%;
        height: 150%;
        top: -25%;
        left: -25%;
        background: radial-gradient(
            circle at center,
            rgba(255, 255, 255, 0.3) 0%,
            rgba(255, 255, 255, 0) 50%
        );
        mix-blend-mode: overlay;
        will-change: transform;
        transform: translate(0, 0);
    }

    .mockup-container {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 6;
    }

    .web-mockup {
        width: 85%;
        border-radius: 0.375rem;
        overflow: hidden;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.35);
        background: #000;
        will-change: transform;

        @media (min-width: 768px) {
            width: 95%;
            border-radius: 0.75rem;
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.35);
        }

        img {
            width: 100%;
            height: auto;
            display: block;
        }
    }

    .mobile-mockup {
        position: absolute;
        width: 20%;
        bottom: -2%;
        right: 4%;
        will-change: transform;

        @media (min-width: 768px) {
            width: 28%;
            bottom: -10%;
            right: -2%;
        }

        .iphone-frame {
            border: 2px solid #1a1a1a;
            border-radius: 0.75rem;
            background: #000;
            overflow: hidden;
            aspect-ratio: 9/19;
            box-shadow: 0 15px 30px -8px rgba(0, 0, 0, 0.5);

            @media (min-width: 768px) {
                border: 6px solid #1a1a1a;
                border-radius: 2rem;
                box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5);
            }

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
        }
    }

    /* ── Info Section ── */
    .card-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding-left: 0.25rem;

        @media (min-width: 768px) {
            gap: 0.35rem;
            padding-left: 0.5rem;
        }
    }

    .project-name {
        font-family: $font-display;
        font-size: 1.125rem;
        font-weight: 400;
        margin: 0;
        color: rgba(0, 0, 0, 0.9);
        letter-spacing: 0.02em;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        will-change: transform, color;

        @media (min-width: 768px) {
            font-size: 1.75rem;
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.9);
        }

        .project-arrow {
            display: inline-flex;
            opacity: 0;
            transform: translateX(-15px);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            color: rgba(0, 0, 0, 0.5);

            @media (hover: none) {
                opacity: 0.6;
                transform: translateX(0);
            }

            svg {
                width: 18px;
                height: 18px;

                @media (min-width: 768px) {
                    width: 24px;
                    height: 24px;
                }
            }

            :global(.dark) & {
                color: rgba(255, 255, 255, 0.5);
            }
        }
    }

    .project-subtitle {
        font-size: 0.8125rem;
        color: rgba(0, 0, 0, 0.45);
        margin: 0;
        font-weight: 500;
        letter-spacing: 0.01em;

        @media (min-width: 768px) {
            font-size: 0.9375rem;
        }

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.4);
        }
    }

    .web-mockup,
    .mobile-mockup {
        filter: grayscale(1) contrast(1.1);
        transition: filter 0.8s cubic-bezier(0.23, 1, 0.32, 1);

        @media (hover: none) {
            filter: grayscale(0) contrast(1);
        }
    }

    .visual-card:hover .web-mockup,
    .visual-card:hover .mobile-mockup {
        filter: grayscale(0) contrast(1);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initProjectCardInteractions() {
        const cards = document.querySelectorAll(
            ".visual-card",
        ) as NodeListOf<HTMLElement>;
        if (cards.length === 0) return;

        // Ensure we don't duplicate context on Astro page load
        if ((window as any).projectCardsContext) {
            (window as any).projectCardsContext.revert();
        }

        (window as any).projectCardsContext = gsap.context(() => {
            // Check if device supports hover (desktop) vs touch
            const isTouchDevice = window.matchMedia("(hover: none)").matches;

            cards.forEach((card) => {
                const visualHero = card.querySelector(
                    ".visual-hero",
                ) as HTMLElement;
                const webMockup = card.querySelector(
                    ".web-mockup",
                ) as HTMLElement;
                const mobileMockup = card.querySelector(
                    ".mobile-mockup",
                ) as HTMLElement;

                const brandReveal = card.querySelector(
                    ".brand-reveal-layer",
                ) as HTMLElement;
                const parallaxGrid = card.querySelector(
                    ".parallax-grid",
                ) as HTMLElement;
                const glare = card.querySelector(".glare") as HTMLElement;

                let bounds: DOMRect;

                // 1. Entrance animation (simpler on mobile)
                const entranceConfig = isTouchDevice
                    ? {
                          y: 40,
                          opacity: 0,
                          scale: 0.98,
                          transformPerspective: 1200,
                      }
                    : {
                          y: 80,
                          opacity: 0,
                          rotationX: 10,
                          scale: 0.95,
                          transformPerspective: 1200,
                      };

                const exitConfig = isTouchDevice
                    ? {
                          y: 0,
                          opacity: 1,
                          scale: 1,
                          duration: 0.8,
                          ease: "power3.out",
                          scrollTrigger: {
                              trigger: card,
                              start: "top 85%",
                              toggleActions: "play none none none",
                          },
                      }
                    : {
                          y: 0,
                          opacity: 1,
                          rotationX: 0,
                          scale: 1,
                          duration: 1.2,
                          ease: "power3.out",
                          scrollTrigger: {
                              trigger: card,
                              start: "top 85%",
                              toggleActions: "play none none none",
                          },
                      };

                gsap.fromTo(card, entranceConfig, exitConfig);

                // Skip complex hover effects on touch devices
                if (isTouchDevice) return;

                // 2. High-Performance QuickTo Setups (desktop only)

                const setHeroRX = gsap.quickTo(visualHero, "rotationX", {
                    duration: 0.6,
                    ease: "power2",
                });
                const setHeroRY = gsap.quickTo(visualHero, "rotationY", {
                    duration: 0.6,
                    ease: "power2",
                });

                const setGridX = parallaxGrid
                    ? gsap.quickTo(parallaxGrid, "x", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;
                const setGridY = parallaxGrid
                    ? gsap.quickTo(parallaxGrid, "y", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;

                const setGlareX = glare
                    ? gsap.quickTo(glare, "x", {
                          duration: 0.6,
                          ease: "power2",
                      })
                    : null;
                const setGlareY = glare
                    ? gsap.quickTo(glare, "y", {
                          duration: 0.6,
                          ease: "power2",
                      })
                    : null;

                const setWebX = webMockup
                    ? gsap.quickTo(webMockup, "x", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;
                const setWebY = webMockup
                    ? gsap.quickTo(webMockup, "y", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;

                card.addEventListener("mouseenter", () => {
                    bounds = card.getBoundingClientRect();
                    window.dispatchEvent(
                        new CustomEvent("cursor:enter", {
                            detail: { text: "View" },
                        }),
                    );

                    gsap.to(visualHero, {
                        scale: 0.98,
                        duration: 0.6,
                        ease: "power3.out",
                    });

                    if (webMockup)
                        gsap.to(webMockup, { scale: 1.05, duration: 0.6 });
                    if (mobileMockup)
                        gsap.to(mobileMockup, { scale: 1.1, duration: 0.6 });
                });

                card.addEventListener("mousemove", (e: MouseEvent) => {
                    if (!bounds) bounds = card.getBoundingClientRect();

                    const x = e.clientX - bounds.left;
                    const y = e.clientY - bounds.top;

                    const xNorm = (x / bounds.width - 0.5) * 2;
                    const yNorm = (y / bounds.height - 0.5) * 2;

                    // Update Parallax
                    setHeroRX(-yNorm * 4);
                    setHeroRY(xNorm * 4);

                    if (setGridX && setGridY) {
                        setGridX(xNorm * -30);
                        setGridY(yNorm * -30);
                    }

                    if (setGlareX && setGlareY) {
                        setGlareX(xNorm * -150);
                        setGlareY(yNorm * -150);
                    }

                    if (setWebX && setWebY) {
                        setWebX(xNorm * 20);
                        setWebY(yNorm * 20);
                    }
                });

                card.addEventListener("mouseleave", () => {
                    window.dispatchEvent(new CustomEvent("cursor:leave"));
                    gsap.to(
                        [
                            visualHero,
                            webMockup,
                            mobileMockup,
                            parallaxGrid,
                            glare,
                        ],
                        {
                            x: 0,
                            y: 0,
                            scale: 1,
                            rotationX: 0,
                            rotationY: 0,
                            duration: 1,
                            ease: "power3.out",
                        },
                    );
                });
            });
        });
    }

    document.addEventListener("astro:page-load", initProjectCardInteractions);
</script>