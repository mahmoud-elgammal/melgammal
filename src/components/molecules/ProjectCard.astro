---
import type { CollectionEntry } from "astro:content";

type Props = {
    project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const { title, tags, imageWeb, imageMobile, color } = project.data;

// Default color if none provided
const brandColor = color || "#8B5CF6";
const subtitle = tags && tags.length > 0 ? tags[0] : "Project";
---

<div class="visual-card" style={`--brand-bg: ${brandColor}`}>
    <a
        href={`/projects/${project.slug}`}
        class="card-link"
        aria-label={`View ${title}`}
    >
        <div class="visual-hero">
            <!-- Architectural Background -->
            <div class="base-layer"></div>
            <div class="technical-grid parallax-grid"></div>

            <!-- Expanding Brand Hit -->
            <div class="brand-reveal-layer"></div>

            <!-- Kinetic Marquee -->
            <div class="internal-marquee parallax-marquee">
                <div class="marquee-track">
                    <span>{title.toUpperCase()} // </span>
                    <span>{title.toUpperCase()} // </span>
                    <span>{title.toUpperCase()} // </span>
                    <span>{title.toUpperCase()} // </span>
                </div>
            </div>

            <!-- FX Layers -->
            <div class="noise-overlay"></div>

            <!-- Dynamic Lighting 3D Effect -->
            <div class="glare-container">
                <div class="glare"></div>
            </div>

            <div class="mockup-container">
                {
                    imageWeb && (
                        <div class="web-mockup">
                            <img
                                src={imageWeb}
                                alt={`${title} Web`}
                                loading="lazy"
                            />
                        </div>
                    )
                }
                {
                    imageMobile && (
                        <div class="mobile-mockup">
                            <div class="iphone-frame">
                                <img
                                    src={imageMobile}
                                    alt={`${title} Mobile`}
                                    loading="lazy"
                                />
                            </div>
                        </div>
                    )
                }
            </div>
        </div>

        <div class="card-info">
            <h3 class="project-name">
                <span class="project-title-text">{title}</span>
                <span class="project-arrow">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path
                            d="M5 12h14M12 5l7 7-7 7"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </span>
            </h3>
            <p class="project-subtitle">{subtitle}</p>
        </div>
    </a>

    <!-- Precision Target Cursor (Moved outside hero to avoid clipping) -->
    <div class="action-ring">
        <span>EXPLORE</span>
    </div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .visual-card {
        width: 100%;
        position: relative; // Fix: Crucial for the absolute positioned action-ring
        transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        cursor: none; // Hide default cursor over this area for the custom badge

        &:hover {
            .visual-hero {
                box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15);
            }

            .project-name {
                color: $color-black;
                transform: translateX(4px);
            }
            :global(.dark) & .project-name {
                color: $color-white;
            }

            .project-arrow {
                opacity: 1;
                transform: translateX(0);
                color: var(--brand-bg);
            }
        }
    }

    .card-link {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* ── Visual Section ── */
    .visual-hero {
        position: relative;
        background: transparent;
        border-radius: 2.25rem;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem; // Reduced for mobile
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
        will-change: transform;

        @include screen(lg) {
            padding: 3.5rem;
        }
    }

    .base-layer {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.03);
        z-index: 0;

        :global(.dark) & {
            background: rgba(255, 255, 255, 0.03);
        }
    }

    .brand-reveal-layer {
        position: absolute;
        inset: 0;
        background: var(--brand-bg);
        z-index: 1;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .visual-card:hover .brand-reveal-layer {
        opacity: 1;
    }

    .technical-grid {
        position: absolute;
        inset: -20%;
        background-image:
            linear-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
        background-size: 30px 30px;
        z-index: 2;
        opacity: 0.6;

        :global(.dark) & {
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                linear-gradient(
                    90deg,
                    rgba(255, 255, 255, 0.05) 1px,
                    transparent 1px
                );
        }
    }

    .internal-marquee {
        position: absolute;
        top: 50%;
        left: -50%;
        width: 200%;
        transform: translateY(-50%) rotate(-10deg);
        z-index: 3;
        color: #000;
        font-size: clamp(2.5rem, 10vw, 4rem); // Scaled down for mobile
        font-weight: 900;
        white-space: nowrap;
        opacity: 0.04;
        pointer-events: none;
        user-select: none;
        mix-blend-mode: overlay;

        @include screen(md) {
            font-size: clamp(4rem, 10vw, 8rem);
        }

        :global(.dark) & {
            color: #fff;
            opacity: 0.08;
        }

        .marquee-track {
            display: inline-block;
            animation: marquee-scroll 30s linear infinite;
        }
    }

    @keyframes marquee-scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .noise-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(0, 0, 0, 0.1) 0%,
            rgba(255, 255, 255, 0.05) 100%
        );
        z-index: 4;
        pointer-events: none;
    }

    .glare-container {
        position: absolute;
        inset: 0;
        overflow: hidden;
        border-radius: 2.25rem;
        pointer-events: none;
        z-index: 5;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .visual-card:hover .glare-container {
        opacity: 1;
    }

    .glare {
        position: absolute;
        width: 150%;
        height: 150%;
        top: -25%;
        left: -25%;
        background: radial-gradient(
            circle at center,
            rgba(255, 255, 255, 0.3) 0%,
            rgba(255, 255, 255, 0) 50%
        );
        mix-blend-mode: overlay;
        will-change: transform;
        transform: translate(0, 0);
    }

    .mockup-container {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 6;
    }

    .web-mockup {
        width: 95%;
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.35);
        background: #000;
        will-change: transform;

        img {
            width: 100%;
            height: auto;
            display: block;
        }
    }

    .mobile-mockup {
        position: absolute;
        width: 28%;
        bottom: -10%;
        right: -2%;
        will-change: transform;

        .iphone-frame {
            border: 6px solid #1a1a1a;
            border-radius: 2rem;
            background: #000;
            overflow: hidden;
            aspect-ratio: 9/19;
            box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5);

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
        }
    }

    /* ── Info Section ── */
    .card-info {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-left: 0.5rem;
    }

    .project-name {
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0;
        color: rgba(0, 0, 0, 0.9);
        letter-spacing: -0.02em;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        will-change: transform, color;

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.9);
        }

        .project-arrow {
            display: inline-flex;
            opacity: 0;
            transform: translateX(-15px);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            color: rgba(
                0,
                0,
                0,
                0.5
            ); // Fallback until hover overrides with brand color

            :global(.dark) & {
                color: rgba(255, 255, 255, 0.5);
            }
        }
    }

    .project-subtitle {
        font-size: 0.9375rem;
        color: rgba(0, 0, 0, 0.45);
        margin: 0;
        font-weight: 500;
        letter-spacing: 0.01em;

        :global(.dark) & {
            color: rgba(255, 255, 255, 0.4);
        }
    }

    .web-mockup,
    .mobile-mockup {
        filter: grayscale(1) contrast(1.1);
        transition: filter 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .visual-card:hover .web-mockup,
    .visual-card:hover .mobile-mockup {
        filter: grayscale(0) contrast(1);
    }

    /* ── Action Ring (Minimalist Target) ── */
    .action-ring {
        position: absolute;
        top: 0;
        left: 0;
        width: 120px;
        height: 120px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 100;
        opacity: 0;
        transform: translate3d(0, 0, 0) scale(0);
        will-change: transform, opacity;
        mix-blend-mode: exclusion;
        color: #fff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);

        span {
            will-change: transform;
        }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initProjectCardInteractions() {
        const cards = document.querySelectorAll(
            ".visual-card",
        ) as NodeListOf<HTMLElement>;
        if (cards.length === 0) return;

        // Ensure we don't duplicate context on Astro page load
        if ((window as any).projectCardsContext) {
            (window as any).projectCardsContext.revert();
        }

        (window as any).projectCardsContext = gsap.context(() => {
            cards.forEach((card) => {
                const visualHero = card.querySelector(
                    ".visual-hero",
                ) as HTMLElement;
                const webMockup = card.querySelector(
                    ".web-mockup",
                ) as HTMLElement;
                const mobileMockup = card.querySelector(
                    ".mobile-mockup",
                ) as HTMLElement;
                const badge = card.querySelector(".action-ring") as HTMLElement;
                const brandReveal = card.querySelector(
                    ".brand-reveal-layer",
                ) as HTMLElement;
                const parallaxGrid = card.querySelector(
                    ".parallax-grid",
                ) as HTMLElement;
                const glare = card.querySelector(".glare") as HTMLElement;

                let bounds: DOMRect;

                // 1. Entrance
                gsap.fromTo(
                    card,
                    {
                        y: 80,
                        opacity: 0,
                        rotationX: 10,
                        scale: 0.95,
                        transformPerspective: 1200,
                    },
                    {
                        y: 0,
                        opacity: 1,
                        rotationX: 0,
                        scale: 1,
                        duration: 1.2,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: card,
                            start: "top 85%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                // 2. High-Performance QuickTo Setups
                const setX = gsap.quickTo(badge, "x", {
                    duration: 0.15, // Reduced for snappier 1:1 feel
                    ease: "none", // No ease for surgical tracking
                });
                const setY = gsap.quickTo(badge, "y", {
                    duration: 0.15, // Reduced for snappier 1:1 feel
                    ease: "none", // No ease for surgical tracking
                });

                const setHeroRX = gsap.quickTo(visualHero, "rotationX", {
                    duration: 0.6,
                    ease: "power2",
                });
                const setHeroRY = gsap.quickTo(visualHero, "rotationY", {
                    duration: 0.6,
                    ease: "power2",
                });

                const setGridX = parallaxGrid
                    ? gsap.quickTo(parallaxGrid, "x", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;
                const setGridY = parallaxGrid
                    ? gsap.quickTo(parallaxGrid, "y", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;

                const setGlareX = glare
                    ? gsap.quickTo(glare, "x", {
                          duration: 0.6,
                          ease: "power2",
                      })
                    : null;
                const setGlareY = glare
                    ? gsap.quickTo(glare, "y", {
                          duration: 0.6,
                          ease: "power2",
                      })
                    : null;

                const setWebX = webMockup
                    ? gsap.quickTo(webMockup, "x", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;
                const setWebY = webMockup
                    ? gsap.quickTo(webMockup, "y", {
                          duration: 0.8,
                          ease: "power2",
                      })
                    : null;

                card.addEventListener("mouseenter", () => {
                    bounds = card.getBoundingClientRect();
                    gsap.to(badge, {
                        opacity: 1,
                        scale: 1,
                        duration: 0.6,
                        ease: "back.out(1.7)",
                    });
                    gsap.to(visualHero, {
                        scale: 0.98,
                        duration: 0.6,
                        ease: "power3.out",
                    });

                    if (webMockup)
                        gsap.to(webMockup, { scale: 1.05, duration: 0.6 });
                    if (mobileMockup)
                        gsap.to(mobileMockup, { scale: 1.1, duration: 0.6 });
                });

                card.addEventListener("mousemove", (e: MouseEvent) => {
                    if (!bounds) bounds = card.getBoundingClientRect();

                    const x = e.clientX - bounds.left;
                    const y = e.clientY - bounds.top;

                    const xNorm = (x / bounds.width - 0.5) * 2;
                    const yNorm = (y / bounds.height - 0.5) * 2;

                    // Update Badge (offset by half size 60px)
                    setX(x - 60);
                    setY(y - 60);

                    // Update Parallax
                    setHeroRX(-yNorm * 4);
                    setHeroRY(xNorm * 4);

                    if (setGridX && setGridY) {
                        setGridX(xNorm * -30);
                        setGridY(yNorm * -30);
                    }

                    if (setGlareX && setGlareY) {
                        setGlareX(xNorm * -150);
                        setGlareY(yNorm * -150);
                    }

                    if (setWebX && setWebY) {
                        setWebX(xNorm * 20);
                        setWebY(yNorm * 20);
                    }
                });

                card.addEventListener("mouseleave", () => {
                    gsap.to(badge, { opacity: 0, scale: 0, duration: 0.3 });
                    gsap.to(
                        [
                            visualHero,
                            webMockup,
                            mobileMockup,
                            parallaxGrid,
                            glare,
                        ],
                        {
                            x: 0,
                            y: 0,
                            scale: 1,
                            rotationX: 0,
                            rotationY: 0,
                            duration: 1,
                            ease: "power3.out",
                        },
                    );
                });
            });
        });
    }

    document.addEventListener("astro:page-load", initProjectCardInteractions);
</script>
