---
type Props = {
  href: string;
};

const { href } = Astro.props;
---

<a href={href} class="back-to-prev">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="icon">
    <line x1="5" y1="12" x2="19" y2="12" class="line"></line>
    <polyline points="12 5 5 12 12 19" class="polyline"></polyline>
  </svg>
  <div class="text">
    <slot />
  </div>
</a>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .back-to-prev {
    position: relative;
    display: flex;
    white-space: nowrap;
    width: fit-content;
    padding: 0.375rem 0.75rem; /* py-1.5 pr-3 */
    padding-left: 1.75rem; /* pl-7 */
    flex-wrap: nowrap;
    border-radius: 0.25rem; /* rounded */
    border: 1px solid rgba(0, 0, 0, 0.15); /* border-black/15 */
    background-color: transparent;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition:
      background-color 0.3s ease-in-out,
      color 0.3s ease-in-out;

    @include hover {
      background-color: rgba(0, 0, 0, 0.05); /* bg-black/5 */
      color: $color-black;

      .line {
        transform: translateX(0) scaleX(1);
      }

      .polyline {
        transform: translateX(0);
      }
    }

    @include dark {
      border-color: rgba(255, 255, 255, 0.2); /* border-white/20 */

      @include hover {
        background-color: rgba(255, 255, 255, 0.05); /* bg-white/5 */
        color: $color-white;
      }
    }
  }

  .icon {
    position: absolute;
    top: 50%;
    left: 0.5rem; /* left-2 */
    transform: translateY(-50%);
    width: 1rem; /* size-4 */
    height: 1rem;
    stroke-width: 2;
    fill: none;
    stroke: currentColor;
  }

  .line {
    transform: translateX(0.5rem) scaleX(0); /* translate-x-2 scale-x-0 */
    transition: transform 0.3s ease-in-out;
    transform-origin: center;
  }

  .polyline {
    transform: translateX(0.25rem); /* translate-x-1 */
    transition: transform 0.3s ease-in-out;
  }

  .text {
    font-size: 0.875rem; /* text-sm */
  }
</style>
