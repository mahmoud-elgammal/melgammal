---
// Cursor.astro - A singleton global cursor atom
---

<div id="global-cursor" class="global-cursor">
    <div class="cursor-ring"></div>
    <div class="cursor-content"></div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;

    .global-cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 20px;
        height: 20px;
        pointer-events: none;
        z-index: 10000;
        mix-blend-mode: exclusion;
        opacity: 0;
        visibility: hidden;
        will-change: transform, width, height, opacity;

        @media (hover: none) and (pointer: coarse) {
            display: none !important;
        }
    }

    .cursor-ring {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        height: 100%;
        border: 1.5px solid #fff;
        border-radius: 50%;
        opacity: 0;
        transition:
            width 0.4s cubic-bezier(0.23, 1, 0.32, 1),
            height 0.4s cubic-bezier(0.23, 1, 0.32, 1),
            background 0.4s ease,
            opacity 0.3s ease;
    }

    .cursor-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    // Large Interactive States
    .global-cursor.is-expanded {
        .cursor-ring {
            opacity: 1;
            background: rgba(255, 255, 255, 0.1);
        }
        .cursor-content {
            opacity: 1;
        }
    }
</style>

<script>
    import {
        registerAnimation,
        prefersReducedMotion,
    } from "@lib/animation";

    document.addEventListener("astro:page-load", () => {
        registerAnimation("global-cursor", (gsap, signal) => {
            const el = document.getElementById("global-cursor");
            if (!el) return;

            // Reduced motion / coarse pointer / no hover: hide entirely.
            // (CSS already hides on coarse pointer; this catches a11y prefs.)
            if (prefersReducedMotion()) {
                el.style.display = "none";
                return;
            }

            const content = el.querySelector(".cursor-content") as HTMLElement;

            // Center origin so we never read client properties every frame
            gsap.set(el, { xPercent: -50, yPercent: -50 });

            const xTo = gsap.quickTo(el, "x", {
                duration: 0.2,
                ease: "power3",
            });
            const yTo = gsap.quickTo(el, "y", {
                duration: 0.2,
                ease: "power3",
            });

            let isVisible = false;

            const onMouseMove = (e: MouseEvent) => {
                if (!isVisible) {
                    isVisible = true;
                    gsap.to(el, { autoAlpha: 1, duration: 0.3 });
                }
                xTo(e.clientX);
                yTo(e.clientY);
            };

            const onMouseLeaveDoc = () => {
                if (isVisible) {
                    isVisible = false;
                    gsap.to(el, { autoAlpha: 0, duration: 0.3 });
                }
            };

            const onCursorEnter = (e: Event) => {
                const detail = (e as CustomEvent).detail || {};
                const { text, size = 110 } = detail;
                el.classList.add("is-expanded");
                if (text && content) content.innerText = text;
                gsap.to(el, {
                    width: size,
                    height: size,
                    duration: 0.6,
                    ease: "back.out(1.7)",
                });
            };

            const onCursorLeave = () => {
                el.classList.remove("is-expanded");
                if (content) content.innerText = "";
                gsap.to(el, {
                    width: 20,
                    height: 20,
                    duration: 0.4,
                    ease: "power3.out",
                });
            };

            const onMouseDown = () => {
                gsap.to(el, { scale: 0.85, duration: 0.2 });
            };

            const onMouseUp = () => {
                gsap.to(el, { scale: 1, duration: 0.3 });
            };

            window.addEventListener("mousemove", onMouseMove, { signal });
            document.addEventListener("mouseleave", onMouseLeaveDoc, {
                signal,
            });
            window.addEventListener("cursor:enter", onCursorEnter, { signal });
            window.addEventListener("cursor:leave", onCursorLeave, { signal });
            window.addEventListener("mousedown", onMouseDown, { signal });
            window.addEventListener("mouseup", onMouseUp, { signal });
        });
    });
</script>
