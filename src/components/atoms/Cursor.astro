---
// Cursor.astro - A singleton global cursor atom
---

<div id="global-cursor" class="global-cursor">
    <div class="cursor-ring"></div>
    <div class="cursor-content"></div>
</div>

<style lang="scss">
    @use "../../styles/variables" as *;

    .global-cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 20px;
        height: 20px;
        pointer-events: none;
        z-index: 10000;
        mix-blend-mode: exclusion;
        opacity: 0;
        visibility: hidden;
        will-change: transform, width, height, opacity;

        @media (hover: none) and (pointer: coarse) {
            display: none !important;
        }
    }

    .cursor-ring {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        height: 100%;
        border: 1.5px solid #fff;
        border-radius: 50%;
        opacity: 0;
        transition:
            width 0.4s cubic-bezier(0.23, 1, 0.32, 1),
            height 0.4s cubic-bezier(0.23, 1, 0.32, 1),
            background 0.4s ease,
            opacity 0.3s ease;
    }

    .cursor-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    // Large Interactive States
    .global-cursor.is-expanded {
        .cursor-ring {
            opacity: 1;
            background: rgba(255, 255, 255, 0.1);
        }
        .cursor-content {
            opacity: 1;
        }
    }
</style>

<script>
    import { gsap } from "gsap";

    class GlobalCursor {
        private el: HTMLElement;
        private ring: HTMLElement;
        private content: HTMLElement;
        private xTo: any;
        private yTo: any;
        private isVisible = false;
        private cleanupCallbacks: (() => void)[] = [];

        constructor() {
            this.el = document.getElementById("global-cursor")!;
            this.ring = this.el.querySelector(".cursor-ring")!;
            this.content = this.el.querySelector(".cursor-content")!;

            if (!this.el) return;

            // Center origin so we don't have to read client properties every frame
            gsap.set(this.el, { xPercent: -50, yPercent: -50 });

            this.xTo = gsap.quickTo(this.el, "x", {
                duration: 0.2,
                ease: "power3",
            });
            this.yTo = gsap.quickTo(this.el, "y", {
                duration: 0.2,
                ease: "power3",
            });

            this.init();
        }

        private init() {
            const onMouseMove = (e: MouseEvent) => {
                if (!this.isVisible) {
                    this.isVisible = true;
                    gsap.to(this.el, { autoAlpha: 1, duration: 0.3 });
                }
                this.xTo(e.clientX);
                this.yTo(e.clientY);
            };

            const onMouseLeaveDoc = () => {
                if (this.isVisible) {
                    this.isVisible = false;
                    gsap.to(this.el, { autoAlpha: 0, duration: 0.3 });
                }
            };

            // Global Event Listeners
            const onCursorEnter = (e: any) => {
                const { text, size = 110 } = e.detail || {};
                this.el.classList.add("is-expanded");
                if (text) {
                    this.content.innerText = text;
                }
                gsap.to(this.el, {
                    width: size,
                    height: size,
                    duration: 0.6,
                    ease: "back.out(1.7)",
                });
            };

            const onCursorLeave = () => {
                this.el.classList.remove("is-expanded");
                this.content.innerText = "";
                gsap.to(this.el, {
                    width: 20,
                    height: 20,
                    duration: 0.4,
                    ease: "power3.out",
                });
            };

            const onMouseDown = () => {
                gsap.to(this.el, { scale: 0.85, duration: 0.2 });
            };

            const onMouseUp = () => {
                gsap.to(this.el, { scale: 1, duration: 0.3 });
            };

            window.addEventListener("mousemove", onMouseMove);
            document.addEventListener("mouseleave", onMouseLeaveDoc);
            window.addEventListener("cursor:enter", onCursorEnter);
            window.addEventListener("cursor:leave", onCursorLeave);
            window.addEventListener("mousedown", onMouseDown);
            window.addEventListener("mouseup", onMouseUp);

            this.cleanupCallbacks.push(
                () => window.removeEventListener("mousemove", onMouseMove),
                () =>
                    document.removeEventListener("mouseleave", onMouseLeaveDoc),
                () => window.removeEventListener("cursor:enter", onCursorEnter),
                () => window.removeEventListener("cursor:leave", onCursorLeave),
                () => window.removeEventListener("mousedown", onMouseDown),
                () => window.removeEventListener("mouseup", onMouseUp),
            );
        }

        public destroy() {
            this.cleanupCallbacks.forEach((cb) => cb());
        }
    }

    let globalCursorInstance: GlobalCursor | null = null;

    // Initialize on page load and cleanup on transitions to prevent stacking ghost event listeners
    document.addEventListener("astro:page-load", () => {
        if (globalCursorInstance) globalCursorInstance.destroy();
        globalCursorInstance = new GlobalCursor();
    });
</script>
