---
interface Props {
    href?: string;
    variant?: "primary" | "outline";
    class?: string;
    id?: string;
    target?: string;
    rel?: string;
}

const { href, variant = "primary", class: className, id } = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag href={href} id={id} class:list={["button", variant, className]}>
    <span class="button-content">
        <slot />
    </span>
</Tag>

<script>
    import { gsap } from "gsap";

    function initButtons() {
        document.querySelectorAll(".button").forEach((btn) => {
            const target = btn as HTMLElement;

            target.addEventListener("mouseenter", () => {
                gsap.to(target, {
                    scale: 1.05,
                    duration: 0.4,
                    ease: "back.out(2)",
                });
            });

            target.addEventListener("mouseleave", () => {
                gsap.to(target, {
                    scale: 1,
                    duration: 0.4,
                    ease: "back.out(1.5)",
                });
            });

            target.addEventListener("mousedown", () => {
                gsap.to(target, {
                    scale: 0.96,
                    duration: 0.2,
                    ease: "power2.out",
                });
            });

            target.addEventListener("mouseup", () => {
                gsap.to(target, {
                    scale: 1.05,
                    duration: 0.4,
                    ease: "back.out(2)",
                });
            });
        });
    }

    initButtons();
    document.addEventListener("astro:page-load", initButtons);
</script>

<style lang="scss">
    @use "../../styles/variables" as *;
    @use "../../styles/mixins" as *;

    .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1.75rem;
        border-radius: 100px; /* Fully Rounded */
        font-weight: 700;
        letter-spacing: -0.01em;
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease;
        text-decoration: none;
        cursor: pointer;
        font-size: 0.875rem;
        line-height: 1.25rem;
        position: relative;
        overflow: hidden;
        border: 2px solid transparent;

        .button-content {
            position: relative;
            z-index: 2;
        }

        &.primary {
            background-color: $color-black;
            color: $color-white;
            border-color: $color-black;

            :global(.dark) & {
                background-color: $color-white;
                color: $color-black;
                border-color: $color-white;
            }
        }

        &.outline {
            background-color: transparent;
            border-color: rgba($color-black, 0.2);
            color: $color-black;

            &:hover {
                border-color: $color-black;
            }

            :global(.dark) & {
                color: $color-white;
                border-color: rgba($color-white, 0.2);
                &:hover {
                    border-color: $color-white;
                }
            }
        }
    }
</style>
